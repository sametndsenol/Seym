{%- comment -%}
  Seym Social — a luxe Instagram showcase. Centered handle + serif headline,
  a row of square posts (each links out), mor glow + Instagram glyph on hover.
  Keeps the homepage's white / charcoal / wine language.
{%- endcomment -%}

{%- liquid
  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    --ink:#1a1a1a; --soft:rgba(26,26,26,.55); --wine:#8E2244; --ease:cubic-bezier(.22,1,.36,1);
  }
  #shopify-section-{{ section.id }} .ssoc { background: var(--seym-paper,#fcfbf9); padding: clamp(6rem,10vh,9rem) 4.8rem; }
  #shopify-section-{{ section.id }} .ssoc__in { max-width: 160rem; margin: 0 auto; }
  #shopify-section-{{ section.id }} .ssoc__hd { text-align: center; margin-bottom: clamp(2.6rem,4vh,3.4rem); }
  #shopify-section-{{ section.id }} .ssoc__ey { font: 300 .8rem/1 'Inter',sans-serif; letter-spacing: .36em; text-transform: uppercase; color: var(--wine); margin: 0 0 1.2rem; }
  #shopify-section-{{ section.id }} .ssoc__h { font: 300 clamp(2.8rem,4.4vw,4.4rem)/1 'Cormorant Garamond',serif; color: var(--ink); margin: 0; }
  #shopify-section-{{ section.id }} .ssoc__h em { font-style: italic; }
  #shopify-section-{{ section.id }} .ssoc__sub { font: 300 1.15rem/1.6 'Inter',sans-serif; color: var(--soft); margin: 1.1rem 0 0; }
  #shopify-section-{{ section.id }} .ssoc__grid { display: grid; grid-template-columns: repeat({{ section.blocks.size | at_most: 6 | at_least: 1 }}, 1fr); gap: 1rem; }
  #shopify-section-{{ section.id }} .ssoc__cell { position: relative; aspect-ratio: 1; overflow: hidden; border-radius: 6px; display: block; }
  #shopify-section-{{ section.id }} .ssoc__cell img { width: 100%; height: 100%; object-fit: cover; transition: transform .9s var(--ease); }
  #shopify-section-{{ section.id }} .ssoc__cell::after { content:''; position:absolute; inset:0; background: radial-gradient(closest-side, rgba(142,34,68,.55), transparent 75%); opacity:0; transition: opacity .5s var(--ease); }
  #shopify-section-{{ section.id }} .ssoc__ig { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; opacity:0; transition: opacity .5s var(--ease); z-index:2; }
  #shopify-section-{{ section.id }} .ssoc__ig svg { width:30px; height:30px; stroke:#fff; fill:none; stroke-width:1.5; }
  #shopify-section-{{ section.id }} .ssoc__cell:hover img { transform: scale(1.06); }
  #shopify-section-{{ section.id }} .ssoc__cell:hover::after, #shopify-section-{{ section.id }} .ssoc__cell:hover .ssoc__ig { opacity:1; }
  #shopify-section-{{ section.id }} .ssoc__cta { text-align:center; margin-top: clamp(2.4rem,4vh,3rem); }
  #shopify-section-{{ section.id }} .ssoc__cta a { font: 400 .74rem/1 'Inter',sans-serif; letter-spacing:.3em; text-transform:uppercase; color: var(--ink); text-decoration:none; border-bottom:1px solid rgba(26,26,26,.3); padding-bottom:.5rem; transition: color .3s, border-color .3s; }
  #shopify-section-{{ section.id }} .ssoc__cta a:hover { color: var(--wine); border-color: var(--wine); }

  @media (max-width: 989px) { #shopify-section-{{ section.id }} .ssoc__grid { grid-template-columns: repeat(3,1fr); } }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .ssoc { padding: clamp(4rem,8vh,5.5rem) 2rem; }
    #shopify-section-{{ section.id }} .ssoc__grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (prefers-reduced-motion: reduce) { #shopify-section-{{ section.id }} .ssoc__cell img { transition: none; } }
</style>

<section class="ssoc" data-reveal>
  <div class="ssoc__in">
    <header class="ssoc__hd">
      {%- if section.settings.handle != blank -%}<p class="ssoc__ey">{{ section.settings.handle }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="ssoc__h">{% if is_tr %}Camdan dünyamız{% else %}{{ section.settings.heading }}{% endif %}</h2>{%- endif -%}
      {%- if section.settings.subtitle != blank -%}<p class="ssoc__sub">{% if is_tr %}Atölyeyi takip edin — İstanbul'dan her gün ışık, renk ve zanaat.{% else %}{{ section.settings.subtitle }}{% endif %}</p>{%- endif -%}
    </header>

    <div class="ssoc__grid">
      {%- for block in section.blocks -%}
        <a class="ssoc__cell" {% if block.settings.link != blank %}href="{{ block.settings.link }}" target="_blank" rel="noopener"{% endif %} {{ block.shopify_attributes }} aria-label="Instagram">
          {%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,450,600', alt: 'Seym on Instagram' }}{%- endif -%}
          <span class="ssoc__ig" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".7" fill="#fff" stroke="none"/></svg></span>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="ssoc__cta"><a href="{{ section.settings.cta_link }}" target="_blank" rel="noopener">{% if is_tr %}Instagram'da takip et{% else %}{{ section.settings.cta_label }}{% endif %} &rarr;</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Social",
  "tag": "div",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "handle", "label": "Handle / eyebrow", "default": "@seym_glass" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our world, <em>in glass</em>", "info": "Wrap a word in <em></em> for italic." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Follow the atelier — daily light, colour and craft from Istanbul." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Follow on Instagram" },
    { "type": "url", "id": "cta_link", "label": "Instagram URL" }
  ],
  "blocks": [
    { "type": "post", "name": "Post", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "url", "id": "link", "label": "Post link" }
    ] }
  ],
  "presets": [{
    "name": "Social",
    "blocks": [ { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" } ]
  }]
}
{% endschema %}
