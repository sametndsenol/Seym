{%- comment -%}
  Seym Header — White Gallery edition.
  Logo left · Nav center (absolute) · Icons right.
  White background, dark ink, gold accent on hover.
{%- endcomment -%}

<style>
  /* Header section wrapper floats transparent over the hero (no cream bar). */
  .shopify-section:has(.seym-hd) { background: transparent !important; }
  /* — Announcement bar —
     Transparent over the dark video (so the video shows through under it),
     solid black once scrolled / on non-hero pages. Text stays light/legible
     in both states. — */
  .seym-bar {
    /* Floats ON the video — fully transparent, light text kept legible with a
       soft shadow (no grey band). Turns solid black once scrolled. */
    background: #7E1E3C;
    border-bottom: none;
    text-align: center;
    padding: 0.55rem 2rem;
    position: relative; z-index: 60;
    transition: background 400ms ease;
  }
  .seym-bar--solid { background: #7E1E3C; }
  .seym-bar p {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #F5F1EA;
    margin: 0;
    text-shadow: none;
    transition: text-shadow 400ms ease, color 400ms ease;
  }
  .seym-bar--solid p { color: #F5F1EA; text-shadow: none; }
  .seym-bar a { color: inherit; text-decoration: none; }

  /* — Header shell — fixed via parent .shopify-section in lux-overrides. —
     Two states:
       · default (over the dark video) → transparent, white text
       · .seym-hd--solid (scrolled past hero, or pages with no hero)
         → ivory fill, dark ink, subtle border
     Colors transition smoothly between the two. — */
  .seym-hd {
    position: relative; z-index: 50;
    /* Floats ON the video — fully transparent. Legibility comes from soft
       text/icon shadows + a faint hero top-scrim, not a grey bar. */
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 400ms ease, border-color 400ms ease;
  }
  .seym-hd--solid {
    background: var(--seym-ivory, #F5F1EA);
    border-bottom: 1px solid rgba(13,13,13,0.07);
  }

  /* — Single row — */
  .seym-hd__row {
    max-width: 160rem; margin: 0 auto;
    padding: 0 4.8rem;
    height: 7.2rem;
    display: flex; align-items: center; justify-content: space-between;
    position: relative;
  }

  /* — Logo: text wordmark only (image is intentionally hidden so the
     mark always reads as a clean serif) — */
  .seym-hd__logo {
    display: flex; align-items: center;
    text-decoration: none; color: #1a1a1a;
    flex-shrink: 0; z-index: 2;
    transition: opacity 300ms ease;
  }
  .seym-hd__logo:hover { opacity: 0.55; }
  /* Logo image (theme settings.logo — a black monochrome wordmark PNG).
     White over the dark video by default; flips to its natural black ink in
     the solid state, smoothly. */
  .seym-hd__logo-img {
    display: block;
    height: 5.6rem;
    width: auto;
    max-width: 26rem;
    object-fit: contain;
    filter: none;
    transition: filter 400ms ease, opacity 300ms ease;
  }
  .seym-hd--solid .seym-hd__logo-img { filter: none; }
  /* Drawer / light surfaces: always ink. */
  .seym-hd__logo-img--ink { filter: none !important; }
  .seym-hd__logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 2.4rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: #1a1a1a;
    line-height: 1;
    padding-left: 0.4em;
    transition: color 400ms ease;
  }
  .seym-hd--solid .seym-hd__logo { color: #1A1A1A; }
  .seym-hd--solid .seym-hd__logo-text { color: #1A1A1A; }

  /* — Nav (centered absolutely) — */
  .seym-hd__nav {
    position: absolute; left: 50%; top: 0; bottom: 0;
    transform: translateX(-50%);
    display: flex; align-items: center;
    list-style: none; margin: 0; padding: 0;
    white-space: nowrap; gap: 0;
    height: 100%;
  }
  .seym-hd__nav li {
    display: flex; align-items: center;
    height: 100%;
  }
  .seym-hd__nav a {
    display: inline-flex; align-items: center; justify-content: center;
    height: 100%;
    padding: 0 1.8rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem; font-weight: 400;
    line-height: 1;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(13,13,13,0.94);
    text-decoration: none; position: relative;
    text-shadow: 0 1px 18px rgba(255,255,255,0.68), 0 0 3px rgba(255,255,255,0.45);
    transition: color 300ms ease, text-shadow 400ms ease;
  }
  .seym-hd--solid .seym-hd__nav a { text-shadow: none; }
  .seym-hd__nav a::after {
    content: ''; position: absolute;
    bottom: 2px; left: 1.8rem; right: 1.8rem;
    height: 1px; background: #8E2244;
    transform: scaleX(0); transform-origin: right center;
    transition: transform 500ms cubic-bezier(0.22,1,0.36,1);
  }
  /* Signature: links warm to gold + a soft gold glow on hover */
  .seym-hd__nav a:hover,
  .seym-hd__nav a[aria-current] { color: #8E2244; text-shadow: 0 0 14px rgba(142,34,68,0.45); }
  .seym-hd__nav a:hover::after,
  .seym-hd__nav a[aria-current]::after {
    transform: scaleX(1); transform-origin: left center;
  }

  /* Solid state — dark ink nav over light fill (still warms to gold) */
  .seym-hd--solid .seym-hd__nav a { color: rgba(13,13,13,0.78); }
  .seym-hd--solid .seym-hd__nav a:hover,
  .seym-hd--solid .seym-hd__nav a[aria-current] { color: #8E2244; }

  /* Signature: gold scroll-progress line along the bottom of the bar */
  .seym-hd__prog {
    position: absolute; left: 0; bottom: -1px; height: 2px; width: 0;
    background: linear-gradient(90deg, rgba(142,34,68,0), #8E2244 30%, #c06a86);
    box-shadow: 0 0 12px rgba(142,34,68,0.55);
    z-index: 3; pointer-events: none;
    transition: width 120ms linear;
  }

  /* — Icon cluster — */
  .seym-hd__icons {
    display: flex; align-items: center; gap: 0.4rem;
    flex-shrink: 0; z-index: 2;
  }
  /* — Locale selector (language + currency) — */
  .seym-loc { position: relative; margin: 0 0.7rem 0 0; }
  .seym-loc__btn {
    display: inline-flex; align-items: center; gap: 0.5rem; background: none; border: 0; cursor: pointer;
    font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(13,13,13,0.75); padding: 0.5rem 0; transition: color 300ms ease;
  }
  .seym-loc__btn:hover { color: #8E2244; }
  .seym-loc__chev { width: 1rem; height: 1rem; stroke: currentColor; fill: none; stroke-width: 1.5; transition: transform 300ms ease; }
  .seym-loc.is-open .seym-loc__chev { transform: rotate(180deg); }
  .seym-loc__panel {
    position: absolute; top: calc(100% + 1rem); right: 0; min-width: 23rem; max-height: 62vh; overflow-y: auto;
    background: #fff; border: 1px solid rgba(13,13,13,0.14); border-radius: 12px;
    box-shadow: 0 30px 70px -28px rgba(40,28,24,0.5), 0 12px 28px -18px rgba(0,0,0,0.25);
    padding: 0.8rem; z-index: 80; opacity: 0; transform: translateY(-6px); pointer-events: none;
    transition: opacity 280ms cubic-bezier(.22,1,.36,1), transform 280ms cubic-bezier(.22,1,.36,1);
  }
  .seym-loc.is-open .seym-loc__panel { opacity: 1; transform: none; pointer-events: auto; }
  .seym-loc__group { margin: 0; }
  .seym-loc__group + .seym-loc__group { margin-top: 0.8rem; padding-top: 0.8rem; border-top: 1px solid rgba(13,13,13,0.08); }
  .seym-loc__lbl { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.26em; text-transform: uppercase; color: rgba(13,13,13,0.4); margin: 0 0 0.5rem; padding: 0 0.8rem; }
  .seym-loc__opt {
    display: block; width: 100%; text-align: left; background: none; border: 0; cursor: pointer;
    font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; line-height: 1.2; color: rgba(13,13,13,0.75);
    padding: 0.7rem 0.8rem; border-radius: 7px; text-decoration: none; transition: background 200ms ease, color 200ms ease;
  }
  .seym-loc__opt:hover { background: rgba(142,34,68,0.06); color: #1a1a1a; }
  .seym-loc__opt.is-active { color: #8E2244; }
  /* Language + currency inside the mobile drawer */
  .seym-drawer__loc { margin-top: auto; padding: 2rem 2.4rem; border-top: 1px solid rgba(13,13,13,0.07); display: flex; flex-direction: column; gap: 1.2rem; }
  .seym-drawer__locrow { display: flex; flex-wrap: wrap; gap: 1.4rem 1.8rem; }
  .seym-drawer__loc-btn {
    background: none; border: 0; cursor: pointer; padding: 0;
    font-family: 'Inter', sans-serif; font-size: 1.05rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(13,13,13,0.5); text-decoration: none; transition: color 300ms ease;
  }
  .seym-drawer__loc-btn.is-active { color: #0d0d0d; }
  .seym-drawer__loc-btn:hover { color: #8E2244; }
  .seym-hd__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem;
    color: #0d0d0d; background: none; border: none;
    cursor: pointer; text-decoration: none; position: relative;
    filter: drop-shadow(0 1px 8px rgba(255,255,255,0.5));
    transition: opacity 300ms ease, color 400ms ease, filter 400ms ease;
  }
  .seym-hd--solid .seym-hd__icon { color: #0d0d0d; filter: none; }
  .seym-hd__icon:hover { opacity: 0.5; }
  .seym-hd__icon svg {
    width: 1.9rem; height: 1.9rem;
    stroke: currentColor; fill: none;
    stroke-width: 1.35; stroke-linecap: round; stroke-linejoin: round;
  }
  .seym-hd__badge {
    position: absolute; top: 5px; right: 5px;
    background: #fff; color: #0d0d0d;
    width: 1.5rem; height: 1.5rem; border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem; font-weight: 600; line-height: 1;
    transition: background 400ms ease, color 400ms ease;
  }
  .seym-hd--solid .seym-hd__badge { background: #0d0d0d; color: #fafaf7; }

  /* — Hamburger (mobile) — */
  .seym-hd__burger {
    display: none;
    flex-direction: column; justify-content: center; gap: 5px;
    width: 4rem; height: 4rem;
    background: none; border: none; cursor: pointer; padding: 1rem;
  }
  .seym-hd__burger span {
    display: block; height: 1px; background: #0d0d0d;
    transition: all 300ms ease;
  }
  .seym-hd--solid .seym-hd__burger span { background: #0d0d0d; }
  .seym-hd__burger span:nth-child(2) { width: 70%; margin-left: auto; }

  /* — Mobile drawer — */
  .seym-drawer {
    position: fixed; inset: 0;
    background: #fafaf7; z-index: 100;
    transform: translateX(-100%);
    transition: transform 600ms cubic-bezier(0.22,1,0.36,1);
    overflow-y: auto;
    display: flex; flex-direction: column;
  }
  .seym-drawer.open { transform: translateX(0); }
  .seym-drawer__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 2rem 2.4rem;
    border-bottom: 1px solid rgba(13,13,13,0.07);
    flex-shrink: 0;
  }
  .seym-drawer__close {
    background: none; border: none; color: #0d0d0d;
    cursor: pointer; width: 4rem; height: 4rem;
    display: flex; align-items: center; justify-content: center;
  }
  .seym-drawer__close svg { width: 2rem; height: 2rem; stroke: currentColor; fill: none; stroke-width: 1.4; }
  .seym-drawer__links {
    list-style: none; margin: 0; padding: 3rem 2.4rem;
    display: flex; flex-direction: column; gap: 0;
  }
  .seym-drawer__links a {
    display: block;
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(13,13,13,0.07);
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem; font-weight: 300; letter-spacing: -0.01em;
    color: #0d0d0d; text-decoration: none;
    transition: opacity 300ms ease;
  }
  .seym-drawer__links a:hover { opacity: 0.5; }
  .seym-drawer__links li:last-child a { border-bottom: none; }

  /* — Responsive — */
  @media (max-width: 989px) {
    .seym-hd__nav { display: none; }
    .seym-hd__burger { display: flex; }
    .seym-hd__row { padding: 0 2rem; }
    .seym-hd__icon[data-account] { display: none; }
    .seym-hd__icon,
    .seym-hd__burger { width: 4.4rem; height: 4.4rem; }
  }
  @media (max-width: 749px) {
    .seym-loc { display: none; }
    .seym-hd__row { height: 6rem; }
    .seym-hd--solid .seym-hd__row { height: 5rem; }
    .seym-hd__row { padding: 0 1.6rem; }
    .seym-hd__logo-text { font-size: 2rem; letter-spacing: 0.36em; }
    .seym-hd__logo-img { height: 4rem; }
    .seym-bar p { font-size: 0.8rem; letter-spacing: 0.2em; }
    .seym-bar { padding: 0.45rem 1.4rem; }
  }
</style>

{%- liquid
  # Robust EN/TR switch that doesn't depend on Markets config: link straight to
  # the root (EN) and /tr (TR) versions of the current page.
  assign locale_cur = request.locale.iso_code | default: 'en'
  assign locale_base = request.path
  if request.path == '/tr'
    assign locale_base = '/'
  elsif request.path contains '/tr/'
    assign locale_base = request.path | remove_first: '/tr'
  endif
  if locale_base == blank
    assign locale_base = '/'
  endif
-%}

{%- if section.settings.show_bar and section.settings.bar_text != blank -%}
<div class="seym-bar" id="SeymBar">
  <p>{% if locale_cur == 'tr' %}Türkiye içi ücretsiz kargo · İstanbul'da elde üflenmiş cam{% else %}{{ section.settings.bar_text }}{% endif %}</p>
</div>
{%- endif -%}

<header class="seym-hd" id="SeymHd">
  <div class="seym-hd__row">

    <a href="{{ routes.root_url }}" class="seym-hd__logo" aria-label="{{ shop.name }}">
      <img src="{{ 'seym-logo.png' | asset_url }}" class="seym-hd__logo-img" alt="{{ shop.name }}" width="244" height="106" loading="eager">
    </a>

    <nav aria-label="Main">
      <ul class="seym-hd__nav">
        {%- comment -%}
          Curated nav — only the four essential links are surfaced
          (Koleksiyon · Mağaza · Hakkımızda · İletişim). Anything else
          in the admin menu (Ev, Dijital Katalog, Basın, Başarılarımız…)
          is hidden so the bar stays calm.
        {%- endcomment -%}
        {%- for link in linklists[section.settings.menu].links -%}
          {%- assign t = link.title | downcase | strip -%}
          {%- assign show = false -%}
          {%- if t contains 'koleksiyon' or t contains 'collection' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'mağaza' or t contains 'magaza' or t contains 'store' or t contains 'shop' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'hakkımızda' or t contains 'hakkimizda' or t contains 'about' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'i̇letişim' or t contains 'iletişim' or t contains 'iletisim' or t contains 'contact' -%}{%- assign show = true -%}{%- endif -%}
          {%- if show -%}
            <li>
              <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <div class="seym-hd__icons">
        <div class="seym-loc" id="SeymLoc">
          <button type="button" class="seym-loc__btn" aria-haspopup="true" aria-expanded="false" aria-label="Language and currency">
            <span>{{ locale_cur | upcase }}{% if localization.available_countries.size > 1 %} · {{ localization.country.currency.iso_code }}{% endif %}</span>
            <svg class="seym-loc__chev" viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="seym-loc__panel">
            <div class="seym-loc__group">
              <p class="seym-loc__lbl">{{ 'sections.seym.language' | t }}</p>
              <a href="{{ locale_base }}" class="seym-loc__opt{% if locale_cur != 'tr' %} is-active{% endif %}" hreflang="en">English</a>
              <a href="/tr{{ locale_base }}" class="seym-loc__opt{% if locale_cur == 'tr' %} is-active{% endif %}" hreflang="tr">Türkçe</a>
            </div>
            {%- if localization.available_countries.size > 1 -%}
              {%- form 'localization', class: 'seym-loc__group' -%}
                <input type="hidden" name="return_to" value="{{ request.path }}">
                <p class="seym-loc__lbl">{{ 'sections.seym.currency' | t }}</p>
                {%- for country in localization.available_countries -%}
                  <button type="submit" name="country_code" value="{{ country.iso_code }}" class="seym-loc__opt{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}">{{ country.name }} · {{ country.currency.iso_code }} {{ country.currency.symbol }}</button>
                {%- endfor -%}
              {%- endform -%}
            {%- endif -%}
          </div>
        </div>
      <a href="{{ routes.search_url }}" class="seym-hd__icon" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="seym-hd__icon" data-account aria-label="Account">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="seym-hd__icon" aria-label="Cart ({{ cart.item_count }})">
        <svg viewBox="0 0 24 24"><path d="M5 7h14l-1.5 12.5a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7L5 7z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="seym-hd__badge" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="seym-hd__burger" id="SeymBurger" aria-label="Menu" aria-expanded="false" aria-controls="SeymDrawer">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>
  <span class="seym-hd__prog" id="SeymProg" aria-hidden="true"></span>
</header>

<div class="seym-drawer" id="SeymDrawer" role="dialog" aria-label="Menu" aria-hidden="true">
  <div class="seym-drawer__head">
    <a href="{{ routes.root_url }}" class="seym-hd__logo" tabindex="-1">
      <img src="{{ 'seym-logo.png' | asset_url }}" class="seym-hd__logo-img seym-hd__logo-img--ink" alt="{{ shop.name }}" width="200">
    </a>
    <button class="seym-drawer__close" id="SeymDrawerClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
    </button>
  </div>
  <nav>
    <ul class="seym-drawer__links">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- assign t = link.title | downcase | strip -%}
        {%- assign show = false -%}
        {%- if t contains 'koleksiyon' or t contains 'collection' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'mağaza' or t contains 'magaza' or t contains 'store' or t contains 'shop' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'hakkımızda' or t contains 'hakkimizda' or t contains 'about' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'i̇letişim' or t contains 'iletişim' or t contains 'iletisim' or t contains 'contact' -%}{%- assign show = true -%}{%- endif -%}
        {%- if show -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>
  <div class="seym-drawer__loc">
    <div class="seym-drawer__locrow">
      <a href="{{ locale_base }}" class="seym-drawer__loc-btn{% if locale_cur != 'tr' %} is-active{% endif %}" hreflang="en">English</a>
      <a href="/tr{{ locale_base }}" class="seym-drawer__loc-btn{% if locale_cur == 'tr' %} is-active{% endif %}" hreflang="tr">Türkçe</a>
    </div>
    {%- if localization.available_countries.size > 1 -%}
      {%- form 'localization', class: 'seym-drawer__locrow' -%}
        <input type="hidden" name="return_to" value="{{ request.path }}">
        {%- for country in localization.available_countries -%}
          <button type="submit" name="country_code" value="{{ country.iso_code }}" class="seym-drawer__loc-btn{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}">{{ country.currency.iso_code }} {{ country.currency.symbol }}</button>
        {%- endfor -%}
      {%- endform -%}
    {%- endif -%}
  </div>
</div>

<script>
(function(){
  const hd = document.getElementById('SeymHd');
  const drawer = document.getElementById('SeymDrawer');
  const burger = document.getElementById('SeymBurger');
  const closeBtn = document.getElementById('SeymDrawerClose');

  function openDrawer(){
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden','false');
    burger.setAttribute('aria-expanded','true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer(){
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden','true');
    burger.setAttribute('aria-expanded','false');
    document.body.style.overflow = '';
  }
  if(burger) burger.addEventListener('click', openDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  drawer && drawer.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', closeDrawer); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeDrawer(); });

  /* ------------------------------------------------------------
     Video-aware sticky header.
     · Pages WITH the dark hero (.shm present): header starts
       TRANSPARENT (white text over the video) and flips to the
       SOLID state once the user scrolls past ~60% of the viewport
       (i.e. leaves the dark hero).
     · Pages WITHOUT a hero: lock to the SOLID state immediately so
       dark ink reads on the light/ivory page background.
     Toggles .seym-hd--solid on #SeymHd and .seym-bar--solid on the bar.
     ------------------------------------------------------------ */
  (function(){
    var bar = document.getElementById('SeymBar');
    var prog = document.getElementById('SeymProg');
    /* The hero (.shm) is parsed AFTER this header, so detect it once the DOM
       is ready — otherwise hasHero is always false and the header never goes
       transparent over the video. */
    var hasHero = false;

    function setSolid(on){
      if(!hd) return;
      hd.classList.toggle('seym-hd--solid', on);
      if(bar) bar.classList.toggle('seym-bar--solid', on);
    }
    function setProgress(){
      if(!prog) return;
      var h = document.documentElement.scrollHeight - window.innerHeight;
      var pct = h > 0 ? (window.scrollY / h) * 100 : 0;
      prog.style.width = pct + '%';
    }

    var ticking = false;
    function update(){
      ticking = false;
      if(hasHero) setSolid(window.scrollY > window.innerHeight * 0.42);
      setProgress();
    }
    function onScroll(){
      if(!ticking){ ticking = true; requestAnimationFrame(update); }
    }
    function init(){
      hasHero = !!document.querySelector('.shm');
      if(hasHero){
        /* Force the hero full-bleed under the transparent header regardless of
           CSS :has() quirks, so the white nav reads over the video. */
        document.body.style.setProperty('padding-top','0','important');
      } else {
        setSolid(true);
      }
      update();
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else { init(); }
  })();

  /* ------------------------------------------------------------
     Nuke any app-injected country/currency pill.
     The widget may live in shadow DOM (Web Components) or be
     re-injected late by an app script, so this hunter:
       1. Walks light DOM AND every shadow root recursively
       2. Matches by short text content: a 3-letter currency
          code (TRY/USD/EUR…) OR a flag emoji
       3. Also matches <img alt="Turkey"> / src*="tr.svg"
       4. Hides the closest pill-shaped ancestor
       5. Re-runs on a 1s interval indefinitely as a safety net
     ------------------------------------------------------------ */
  var CCY  = /^(TRY|USD|EUR|GBP|CAD|AUD|JPY|CHF|SEK|NOK|DKK|AED|RUB|CNY|HKD|SGD|NZD|MXN|BRL|INR|ZAR|PLN|HUF|CZK|ILS|KRW|THB|MYR|IDR|PHP|VND|RON|BGN|HRK|ISK)$/;
  var FLAG = /[\uD83C][\uDDE6-\uDDFF][\uD83C][\uDDE6-\uDDFF]/;
  var SELF = document.getElementById('SeymHd');

  function allRoots(node, out) {
    out = out || [document];
    var walker = (node || document).querySelectorAll('*');
    for (var i = 0; i < walker.length; i++) {
      var el = walker[i];
      if (el.shadowRoot) { out.push(el.shadowRoot); allRoots(el.shadowRoot, out); }
    }
    return out;
  }

  function nuke(el) {
    if (!el || (SELF && SELF.contains(el))) return;
    /* climb to a pill-shaped wrapper */
    var target = el;
    for (var i = 0; i < 5 && target.parentElement; i++) {
      var p = target.parentElement;
      if (p.tagName === 'BODY' || p.tagName === 'HTML') break;
      var tag = target.tagName;
      if (tag === 'BUTTON' || tag === 'DETAILS' || tag === 'FORM') break;
      var pcs;
      try { pcs = getComputedStyle(p); } catch (e) { break; }
      if (pcs && (pcs.position === 'fixed' || pcs.position === 'absolute')) { target = p; break; }
      target = p;
    }
    if (SELF && SELF.contains(target)) return;
    target.style.setProperty('display', 'none', 'important');
    target.style.setProperty('visibility', 'hidden', 'important');
    target.setAttribute('data-seym-nuked', '1');
  }

  function sweep() {
    var roots = allRoots(document);
    roots.forEach(function (root) {
      /* short-text candidates */
      var els;
      try {
        els = root.querySelectorAll('button, details, summary, a, span, div');
      } catch (e) { return; }
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        if (el.hasAttribute && el.hasAttribute('data-seym-nuked')) continue;
        var txt = (el.textContent || '').trim();
        if (!txt || txt.length > 6) continue;
        if (CCY.test(txt) || FLAG.test(txt)) { nuke(el); }
      }
      /* flag image candidates */
      var imgs;
      try { imgs = root.querySelectorAll('img'); } catch (e) { imgs = []; }
      for (var j = 0; j < imgs.length; j++) {
        var img = imgs[j];
        var src = (img.getAttribute('src') || '').toLowerCase();
        var alt = (img.getAttribute('alt') || '').toLowerCase();
        if (
          /flag|country|tr\.svg|turkey|türk/i.test(src) ||
          /turkey|türk|flag/i.test(alt)
        ) { nuke(img); }
      }
      /* currency-conversion banner (long-text, app-injected) */
      var BANNER = /(exchange rates|exchange_rates|conversion rate|kurlar(?:i|ı)|d(?:ö|o)viz kuru|işlem(?:ler)? .* try|processed in (?:try|usd|eur|gbp))/i;
      var banners;
      try { banners = root.querySelectorAll('p, div, span, aside'); } catch (e) { banners = []; }
      for (var k = 0; k < banners.length; k++) {
        var b = banners[k];
        if (SELF && SELF.contains(b)) continue;
        if (b.hasAttribute && b.hasAttribute('data-seym-nuked')) continue;
        var btxt = (b.textContent || '').trim();
        if (!btxt || btxt.length > 200) continue;
        if (BANNER.test(btxt)) { nuke(b); }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', sweep);
  } else { sweep(); }
  [200, 600, 1500, 3000, 6000].forEach(function (t) { setTimeout(sweep, t); });
  setInterval(sweep, 1500);

  if ('MutationObserver' in window) {
    new MutationObserver(sweep).observe(document.documentElement, { childList: true, subtree: true });
  }
})();
</script>

<script>
(function(){
  var loc = document.getElementById('SeymLoc');
  if(!loc) return;
  var btn = loc.querySelector('.seym-loc__btn');
  btn.addEventListener('click', function(e){
    e.stopPropagation();
    var open = loc.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.addEventListener('click', function(e){
    if(!loc.contains(e.target)){ loc.classList.remove('is-open'); btn.setAttribute('aria-expanded','false'); }
  });
  document.addEventListener('keydown', function(e){ if(e.key === 'Escape'){ loc.classList.remove('is-open'); btn.setAttribute('aria-expanded','false'); } });
})();
</script>

