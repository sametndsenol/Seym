{%- comment -%}
  Seym Header — White Gallery edition.
  Logo left · Nav center (absolute) · Icons right.
  White background, dark ink, gold accent on hover.
{%- endcomment -%}

<style>
  /* — Announcement bar — */
  .seym-bar {
    background: #0d0d0d;
    border-bottom: none;
    text-align: center;
    padding: 1rem 2rem;
    position: relative; z-index: 60;
  }
  .seym-bar p {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(250,250,247,0.55);
    margin: 0;
  }
  .seym-bar a { color: inherit; text-decoration: none; }

  /* — Header shell — static height, no shrink on scroll. — */
  .seym-hd {
    position: sticky; top: 0; z-index: 50;
    background: var(--seym-ivory, #F5F1EA);
    border-bottom: 1px solid rgba(13,13,13,0.07);
  }

  /* — Single row — */
  .seym-hd__row {
    max-width: 160rem; margin: 0 auto;
    padding: 0 4.8rem;
    height: 6.4rem;
    display: flex; align-items: center; justify-content: space-between;
    position: relative;
  }

  /* — Logo: text wordmark only (image is intentionally hidden so the
     mark always reads as a clean serif) — */
  .seym-hd__logo {
    display: flex; align-items: center;
    text-decoration: none; color: #1A1A1A;
    flex-shrink: 0; z-index: 2;
    transition: opacity 300ms ease;
  }
  .seym-hd__logo:hover { opacity: 0.55; }
  .seym-hd__logo img { display: none; }
  .seym-hd__logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 2.4rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: #1A1A1A;
    line-height: 1;
    padding-left: 0.4em;
  }

  /* — Nav (centered absolutely) — */
  .seym-hd__nav {
    position: absolute; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center;
    list-style: none; margin: 0; padding: 0;
    white-space: nowrap; gap: 0;
  }
  .seym-hd__nav li {
    display: flex; align-items: center;
  }
  .seym-hd__nav a {
    display: flex; align-items: center;
    padding: 0.6rem 1.8rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem; font-weight: 400;
    line-height: 1;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    text-decoration: none; position: relative;
    transition: color 300ms ease;
  }
  .seym-hd__nav a::after {
    content: ''; position: absolute;
    bottom: 2px; left: 1.8rem; right: 1.8rem;
    height: 1px; background: #0d0d0d;
    transform: scaleX(0); transform-origin: right center;
    transition: transform 500ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-hd__nav a:hover,
  .seym-hd__nav a[aria-current] { color: #0d0d0d; }
  .seym-hd__nav a:hover::after,
  .seym-hd__nav a[aria-current]::after {
    transform: scaleX(1); transform-origin: left center;
  }

  /* — Icon cluster — */
  .seym-hd__icons {
    display: flex; align-items: center; gap: 0.4rem;
    flex-shrink: 0; z-index: 2;
  }
  .seym-hd__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem;
    color: #0d0d0d; background: none; border: none;
    cursor: pointer; text-decoration: none; position: relative;
    transition: opacity 300ms ease;
  }
  .seym-hd__icon:hover { opacity: 0.5; }
  .seym-hd__icon svg {
    width: 1.9rem; height: 1.9rem;
    stroke: currentColor; fill: none;
    stroke-width: 1.35; stroke-linecap: round; stroke-linejoin: round;
  }
  .seym-hd__badge {
    position: absolute; top: 5px; right: 5px;
    background: #0d0d0d; color: #fafaf7;
    width: 1.5rem; height: 1.5rem; border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem; font-weight: 600; line-height: 1;
  }

  /* — Hamburger (mobile) — */
  .seym-hd__burger {
    display: none;
    flex-direction: column; justify-content: center; gap: 5px;
    width: 4rem; height: 4rem;
    background: none; border: none; cursor: pointer; padding: 1rem;
  }
  .seym-hd__burger span {
    display: block; height: 1px; background: #0d0d0d;
    transition: all 300ms ease;
  }
  .seym-hd__burger span:nth-child(2) { width: 70%; margin-left: auto; }

  /* — Mobile drawer — */
  .seym-drawer {
    position: fixed; inset: 0;
    background: #fafaf7; z-index: 100;
    transform: translateX(-100%);
    transition: transform 600ms cubic-bezier(0.22,1,0.36,1);
    overflow-y: auto;
    display: flex; flex-direction: column;
  }
  .seym-drawer.open { transform: translateX(0); }
  .seym-drawer__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 2rem 2.4rem;
    border-bottom: 1px solid rgba(13,13,13,0.07);
    flex-shrink: 0;
  }
  .seym-drawer__close {
    background: none; border: none; color: #0d0d0d;
    cursor: pointer; width: 4rem; height: 4rem;
    display: flex; align-items: center; justify-content: center;
  }
  .seym-drawer__close svg { width: 2rem; height: 2rem; stroke: currentColor; fill: none; stroke-width: 1.4; }
  .seym-drawer__links {
    list-style: none; margin: 0; padding: 3rem 2.4rem;
    display: flex; flex-direction: column; gap: 0;
  }
  .seym-drawer__links a {
    display: block;
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(13,13,13,0.07);
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.2rem; font-weight: 300; letter-spacing: -0.01em;
    color: #0d0d0d; text-decoration: none;
    transition: opacity 300ms ease;
  }
  .seym-drawer__links a:hover { opacity: 0.5; }
  .seym-drawer__links li:last-child a { border-bottom: none; }

  /* — Responsive — */
  @media (max-width: 989px) {
    .seym-hd__nav { display: none; }
    .seym-hd__burger { display: flex; }
    .seym-hd__row { padding: 0 2rem; }
    .seym-hd__icon[data-account] { display: none; }
  }
  @media (max-width: 749px) {
    .seym-hd__row { height: 5.8rem; }
    .seym-hd.scrolled .seym-hd__row { height: 4.8rem; }
  }
</style>

{%- if section.settings.show_bar and section.settings.bar_text != blank -%}
<div class="seym-bar">
  <p>{{ section.settings.bar_text }}</p>
</div>
{%- endif -%}

<header class="seym-hd" id="SeymHd">
  <div class="seym-hd__row">

    <a href="{{ routes.root_url }}" class="seym-hd__logo" aria-label="{{ shop.name }}">
      <span class="seym-hd__logo-text">Seym</span>
    </a>

    <nav aria-label="Main">
      <ul class="seym-hd__nav">
        {%- comment -%}
          Curated nav — only the four essential links are surfaced
          (Koleksiyon · Mağaza · Hakkımızda · İletişim). Anything else
          in the admin menu (Ev, Dijital Katalog, Basın, Başarılarımız…)
          is hidden so the bar stays calm.
        {%- endcomment -%}
        {%- for link in linklists[section.settings.menu].links -%}
          {%- assign t = link.title | downcase | strip -%}
          {%- assign show = false -%}
          {%- if t contains 'koleksiyon' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'mağaza' or t contains 'magaza' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'hakkımızda' or t contains 'hakkimizda' -%}{%- assign show = true -%}{%- endif -%}
          {%- if t contains 'i̇letişim' or t contains 'iletişim' or t contains 'iletisim' -%}{%- assign show = true -%}{%- endif -%}
          {%- if show -%}
            <li>
              <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <div class="seym-hd__icons">
      <a href="{{ routes.search_url }}" class="seym-hd__icon" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg>
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="seym-hd__icon" data-account aria-label="Account">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="seym-hd__icon" aria-label="Cart ({{ cart.item_count }})">
        <svg viewBox="0 0 24 24"><path d="M5 7h14l-1.5 12.5a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7L5 7z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="seym-hd__badge" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="seym-hd__burger" id="SeymBurger" aria-label="Menu" aria-expanded="false" aria-controls="SeymDrawer">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>
</header>

<div class="seym-drawer" id="SeymDrawer" role="dialog" aria-label="Menu" aria-hidden="true">
  <div class="seym-drawer__head">
    <a href="{{ routes.root_url }}" class="seym-hd__logo" tabindex="-1">
      <span class="seym-hd__logo-text" style="font-size:1.9rem">Seym</span>
    </a>
    <button class="seym-drawer__close" id="SeymDrawerClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
    </button>
  </div>
  <nav>
    <ul class="seym-drawer__links">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- assign t = link.title | downcase | strip -%}
        {%- assign show = false -%}
        {%- if t contains 'koleksiyon' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'mağaza' or t contains 'magaza' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'hakkımızda' or t contains 'hakkimizda' -%}{%- assign show = true -%}{%- endif -%}
        {%- if t contains 'i̇letişim' or t contains 'iletişim' or t contains 'iletisim' -%}{%- assign show = true -%}{%- endif -%}
        {%- if show -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>
</div>

<script>
(function(){
  const hd = document.getElementById('SeymHd');
  const drawer = document.getElementById('SeymDrawer');
  const burger = document.getElementById('SeymBurger');
  const closeBtn = document.getElementById('SeymDrawerClose');

  function openDrawer(){
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden','false');
    burger.setAttribute('aria-expanded','true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer(){
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden','true');
    burger.setAttribute('aria-expanded','false');
    document.body.style.overflow = '';
  }
  if(burger) burger.addEventListener('click', openDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  drawer && drawer.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', closeDrawer); });
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeDrawer(); });
})();
</script>

{% schema %}
{
  "name": "Seym Header",
  "tag": "header",
  "class": "shopify-section-header shopify-section-header-sticky",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "bar_text", "label": "Announcement text",
      "default": "Complimentary shipping within Türkiye · Hand-blown in Istanbul" },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Seym Header" }]
}
{% endschema %}
