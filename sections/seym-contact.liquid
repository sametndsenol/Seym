    },
    {
      "type": "text",
      "id": "direct_label",
      "label": "Direct label",
      "default": "Direct"
    },
    {
      "type": "text",
      "id": "direct_email",
      "label": "Email",
      "default": ""
    },
    {
      "type": "text",
      "id": "direct_phone",
      "label": "Phone",
      "default": ""
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
