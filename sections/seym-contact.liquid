            "phone": "(0252) 311 18 88"
          }
        },
        {
          "type": "showroom",
          "settings": {
            "name": "JW Marriott Hotel İstanbul Marmara Sea",
            "address": "Ataköy 2-5-6. Kısım, Kısım Mah. Rauf Orbay Cd. 2/1 L B, 34158 Bakırköy / İstanbul",
