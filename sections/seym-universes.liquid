{%- comment -%}
  Seym Universes — immersive collection grid with overlay labels.
{%- endcomment -%}

<style>
  .seym-uni {
    background: #fff;
    padding: 64px 0 80px;
  }
  .seym-uni__wrap { max-width: 132rem; margin: 0 auto; padding: 0 4rem; }
  .seym-uni__header { text-align: center; margin-bottom: 4rem; }
  .seym-uni__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.45);
    margin: 0 0 1rem;
  }
  .seym-uni__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #1A1A1A;
    margin: 0;
    font-style: italic;
  }
  .seym-uni__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  .seym-uni__card {
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
    overflow: hidden;
  }
  .seym-uni__img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .seym-uni__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.22,1,0.36,1);
  }
  .seym-uni__card:hover .seym-uni__img img { transform: scale(1.08); }
  .seym-uni__label-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.4rem 1.8rem;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }
  .seym-uni__label {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #F5F1EA;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    background: rgba(26,26,26,0.25);
    padding: 0.5rem 1.2rem;
  }
  .seym-uni__arrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.7);
    transition: transform 280ms ease, color 220ms ease;
  }
  .seym-uni__card:hover .seym-uni__arrow {
    transform: translateX(4px);
    color: #F5F1EA;
  }

  @media (max-width: 749px) {
    .seym-uni__wrap { padding: 0 2rem; }
    .seym-uni__grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
    .seym-uni { padding: 48px 0 56px; }
  }
</style>

<section class="seym-uni" data-reveal>
  <div class="seym-uni__wrap">
    <header class="seym-uni__header" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="seym-uni__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="seym-uni__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>

    <div class="seym-uni__grid" data-reveal-child>
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign card_url = block.settings.link | default: col.url | default: '#' -%}
        {%- assign card_label = block.settings.label | default: col.title -%}
        <a class="seym-uni__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="seym-uni__img">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                 loading: 'lazy', widths: '300,500,700,900',
                 sizes: '(max-width: 749px) 50vw, 33vw',
                 alt: card_label }}
            {%- elsif col.image != blank -%}
              {{ col.image | image_url: width: 800 | image_tag:
                 loading: 'lazy', widths: '300,500,700,900',
                 sizes: '(max-width: 749px) 50vw, 33vw',
                 alt: card_label }}
            {%- elsif col.products.first.featured_image != blank -%}
              {{ col.products.first.featured_image | image_url: width: 800 | image_tag:
                 loading: 'lazy', widths: '300,500,700,900',
                 sizes: '(max-width: 749px) 50vw, 33vw',
                 alt: card_label }}
            {%- endif -%}
          </div>
          <div class="seym-uni__label-wrap">
            <span class="seym-uni__label">{{ card_label }}</span>
            <span class="seym-uni__arrow">→</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Universes",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR COLLECTIONS" }
  ],
  "blocks": [
    {
      "type": "universe",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Custom link" }
      ]
    }
  ],
  "presets": [{
    "name": "Universes",
    "blocks": [
      { "type": "universe", "settings": { "label": "Flos" } },
      { "type": "universe", "settings": { "label": "Solis" } },
      { "type": "universe", "settings": { "label": "Glacies" } },
      { "type": "universe", "settings": { "label": "Luminis" } },
      { "type": "universe", "settings": { "label": "Maris" } },
      { "type": "universe", "settings": { "label": "Luna" } }
    ]
  }]
}
{% endschema %}
