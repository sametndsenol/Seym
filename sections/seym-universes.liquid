{%- comment -%}
  Daum Universes — collection thumbnails with label below, simple and clean.
{%- endcomment -%}

<style>
  .sun {
    background: #fff;
    padding: 56px 0 72px;
  }
  .sun__wrap { max-width: 128rem; margin: 0 auto; padding: 0 4rem; }
  .sun__hd { text-align: center; margin-bottom: 3.6rem; }
  .sun__ey {
    font: 300 0.68rem/1 'Inter', sans-serif;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.4);
    margin: 0 0 0.8rem;
  }
  .sun__h {
    font: 300 clamp(2.4rem,3.6vw,3.8rem)/1.05 'Cormorant Garamond', serif;
    font-style: italic;
    letter-spacing: -0.01em;
    color: #1A1A1A;
    margin: 0;
  }
  .sun__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 2rem;
  }
  .sun__card {
    text-decoration: none;
    color: inherit;
  }
  .sun__img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .sun__img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.22,1,0.36,1);
  }
  .sun__card:hover .sun__img img { transform: scale(1.06); }
  .sun__label {
    display: block;
    text-align: center;
    font: 300 0.66rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.55);
    transition: color .2s;
  }
  .sun__card:hover .sun__label { color: #1A1A1A; }

  @media(max-width:749px){
    .sun__wrap { padding: 0 2rem; }
    .sun__grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .sun { padding: 40px 0 48px; }
  }
</style>

<section class="sun" data-reveal>
  <div class="sun__wrap">
    <header class="sun__hd">
      {%- if section.settings.eyebrow != blank -%}<p class="sun__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sun__h">{{ section.settings.heading }}</h2>{%- endif -%}
    </header>
    <div class="sun__grid" data-reveal-child>
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign card_url = block.settings.link | default: col.url | default: '#' -%}
        {%- assign card_label = block.settings.label | default: col.title -%}
        <a class="sun__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="sun__img">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,450,600', sizes: '(max-width:749px) 50vw, 20vw', alt: card_label }}
            {%- elsif col.image != blank -%}
              {{ col.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,450,600', sizes: '(max-width:749px) 50vw, 20vw', alt: card_label }}
            {%- elsif col.products.first.featured_image != blank -%}
              {{ col.products.first.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,450,600', sizes: '(max-width:749px) 50vw, 20vw', alt: card_label }}
            {%- endif -%}
          </div>
          <span class="sun__label">{{ card_label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Universes",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Travel through" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR UNIVERSES" }
  ],
  "blocks": [
    {
      "type": "universe",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Custom link" }
      ]
    }
  ],
  "presets": [{
    "name": "Universes",
    "blocks": [
      { "type": "universe", "settings": { "label": "Flos" } },
      { "type": "universe", "settings": { "label": "Solis" } },
      { "type": "universe", "settings": { "label": "Maris" } },
      { "type": "universe", "settings": { "label": "Luna" } }
    ]
  }]
}
{% endschema %}
