{%- comment -%}
  Seym Universes — editorial collection banners (Flos / Solis / Maris / Luna).
  Serif name + uppercase eyebrow, refined framing, restrained hover.
{%- endcomment -%}

{%- liquid
  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} .sun {
    background: var(--seym-ivory, #F5F1EA);
    padding: clamp(7rem, 11vh, 11rem) 0;
  }
  #shopify-section-{{ section.id }} .sun__wrap {
    max-width: 150rem;
    margin: 0 auto;
    padding: 0 4.8rem;
  }
  #shopify-section-{{ section.id }} .sun__hd {
    text-align: center;
    margin-bottom: clamp(3.6rem, 6vh, 5.6rem);
  }
  #shopify-section-{{ section.id }} .sun__ey {
    font: 300 0.78rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    margin: 0 0 1.2rem;
  }
  #shopify-section-{{ section.id }} .sun__h {
    font: 300 clamp(2.8rem, 5vw, 5.2rem)/1.02 'Cormorant Garamond', serif;
    letter-spacing: -0.01em;
    color: var(--seym-ink, #0D0D0D);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .sun__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3.2rem 2.4rem;
  }
  #shopify-section-{{ section.id }} .sun__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .sun__frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--seym-ivory-2, #FAFAF7);
    margin-bottom: 1.6rem;
  }
  #shopify-section-{{ section.id }} .sun__frame::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(13,13,13,0.08);
    pointer-events: none;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .sun__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sun__card:hover .sun__frame img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .sun__ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font: 300 2rem/1 'Cormorant Garamond', serif;
    color: rgba(13,13,13,0.12);
  }

  #shopify-section-{{ section.id }} .sun__meta { text-align: center; }
  #shopify-section-{{ section.id }} .sun__kicker {
    display: block;
    font: 300 0.82rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.4);
    margin-bottom: 0.7rem;
  }
  #shopify-section-{{ section.id }} .sun__name {
    display: block;
    font: 400 2.2rem/1.1 'Cormorant Garamond', serif;
    color: var(--seym-ink, #0D0D0D);
    margin-bottom: 0.9rem;
  }
  #shopify-section-{{ section.id }} .sun__explore {
    display: inline-block;
    position: relative;
    font: 300 0.82rem/1 'Inter', sans-serif;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    padding-bottom: 0.5rem;
    transition: color .35s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sun__explore::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 2.4rem;
    height: 1px;
    background: var(--seym-wine, #8E2244);
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    transition: transform .5s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sun__card:hover .sun__explore { color: var(--seym-wine, #8E2244); }
  #shopify-section-{{ section.id }} .sun__card:hover .sun__explore::after { transform: translateX(-50%) scaleX(1); }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .sun__grid { grid-template-columns: repeat(2, 1fr); gap: 2.8rem 2rem; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sun { padding: clamp(4.5rem, 9vh, 6rem) 0; }
    #shopify-section-{{ section.id }} .sun__wrap { padding: 0 2rem; }
    #shopify-section-{{ section.id }} .sun__grid { gap: 2.4rem 1.6rem; }
    #shopify-section-{{ section.id }} .sun__name { font-size: 1.35rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .sun__frame img,
    #shopify-section-{{ section.id }} .sun__explore,
    #shopify-section-{{ section.id }} .sun__explore::after { transition: none; }
    #shopify-section-{{ section.id }} .sun__card:hover .sun__frame img { transform: none; }
  }
</style>

<section class="sun" data-reveal>
  <div class="sun__wrap">
    <header class="sun__hd">
      {%- if section.settings.eyebrow != blank -%}<p class="sun__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sun__h">{% if is_tr %}EVRENLERİMİZ{% else %}{{ section.settings.heading }}{% endif %}</h2>{%- endif -%}
    </header>
    <div class="sun__grid" data-reveal-child>
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign card_url = block.settings.link | default: col.url | default: '#' -%}
        {%- assign card_label = block.settings.label | default: col.title -%}
        <a class="sun__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="sun__frame">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300,450,600,800', sizes: '(max-width:749px) 50vw, 24vw', alt: card_label }}
            {%- elsif col.image != blank -%}
              {{ col.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300,450,600,800', sizes: '(max-width:749px) 50vw, 24vw', alt: card_label }}
            {%- elsif col.products.first.featured_image != blank -%}
              {{ col.products.first.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300,450,600,800', sizes: '(max-width:749px) 50vw, 24vw', alt: card_label }}
            {%- else -%}
              <span class="sun__ph">{{ card_label | slice: 0 }}</span>
            {%- endif -%}
          </div>
          <span class="sun__meta">
            {%- if section.settings.kicker != blank -%}<span class="sun__kicker">{% if is_tr %}Koleksiyon{% else %}{{ section.settings.kicker }}{% endif %}</span>{%- endif -%}
            <span class="sun__name">{{ card_label }}</span>
            <span class="sun__explore">{% if is_tr %}Keşfet{% else %}{{ section.settings.explore_label | default: 'Explore' }}{% endif %}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Universes",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Travel through" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR UNIVERSES" },
    { "type": "text", "id": "kicker", "label": "Card kicker (above name)", "default": "Collection" },
    { "type": "text", "id": "explore_label", "label": "Hover affordance label", "default": "Explore" }
  ],
  "blocks": [
    {
      "type": "universe",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Custom link" }
      ]
    }
  ],
  "presets": [{
    "name": "Universes",
    "blocks": [
      { "type": "universe", "settings": { "label": "Flos" } },
      { "type": "universe", "settings": { "label": "Solis" } },
      { "type": "universe", "settings": { "label": "Maris" } },
      { "type": "universe", "settings": { "label": "Luna" } }
    ]
  }]
}
{% endschema %}
