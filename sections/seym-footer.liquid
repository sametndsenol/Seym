{%- comment -%}
  Seym Footer — compact, dark, with social. Brand + blurb + social icons,
  two slim link columns, atelier contact, and a thin bottom bar.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .sf {
    background: #0d0d0d; color: rgba(250,250,247,.7);
    padding: clamp(4rem,6vh,5.5rem) 4.8rem clamp(1.6rem,3vh,2.2rem);
    font-family: 'Inter', sans-serif;
  }
  #shopify-section-{{ section.id }} .sf__in { max-width: 150rem; margin: 0 auto; }
  #shopify-section-{{ section.id }} .sf__top {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 3rem;
    padding-bottom: clamp(2.4rem,4vh,3.2rem); border-bottom: 1px solid rgba(250,250,247,.1);
  }
  #shopify-section-{{ section.id }} .sf__brand { font: 400 1.6rem/1 'Cormorant Garamond', serif; letter-spacing: .28em; text-transform: uppercase; color: #fafaf7; margin: 0 0 1.2rem; }
  #shopify-section-{{ section.id }} .sf__blurb { font-size: .92rem; line-height: 1.7; color: rgba(250,250,247,.55); max-width: 34ch; margin: 0 0 1.6rem; }
  #shopify-section-{{ section.id }} .sf__social { display: flex; gap: 1rem; }
  #shopify-section-{{ section.id }} .sf__social a {
    width: 3.8rem; height: 3.8rem; border: 1px solid rgba(250,250,247,.2); border-radius: 999px;
    display: inline-flex; align-items: center; justify-content: center; color: rgba(250,250,247,.8);
    transition: background .35s ease, border-color .35s ease, color .35s ease;
  }
  #shopify-section-{{ section.id }} .sf__social a:hover { background: #8E2244; border-color: #8E2244; color: #fff; }
  #shopify-section-{{ section.id }} .sf__social svg { width: 1.7rem; height: 1.7rem; stroke: currentColor; fill: none; stroke-width: 1.4; }
  #shopify-section-{{ section.id }} .sf__col h3 { font: 400 .68rem/1 'Inter',sans-serif; letter-spacing: .28em; text-transform: uppercase; color: rgba(250,250,247,.5); margin: 0 0 1.4rem; }
  #shopify-section-{{ section.id }} .sf__col ul { list-style: none; margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} .sf__col li { margin: 0 0 .8rem; }
  #shopify-section-{{ section.id }} .sf__col a, #shopify-section-{{ section.id }} .sf__contact a { color: rgba(250,250,247,.7); text-decoration: none; font-size: .92rem; transition: color .3s ease; }
  #shopify-section-{{ section.id }} .sf__col a:hover, #shopify-section-{{ section.id }} .sf__contact a:hover { color: #fafaf7; }
  #shopify-section-{{ section.id }} .sf__contact p { font-size: .92rem; line-height: 1.8; color: rgba(250,250,247,.6); margin: 0; }
  #shopify-section-{{ section.id }} .sf__bottom {
    display: flex; align-items: center; justify-content: center; padding-top: clamp(1.4rem,2.5vh,2rem);
    font-size: .72rem; letter-spacing: .24em; text-transform: uppercase; color: rgba(250,250,247,.4);
  }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .sf__top { grid-template-columns: 1fr 1fr; gap: 2.6rem 2rem; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sf { padding: 3.5rem 2rem 1.6rem; }
    #shopify-section-{{ section.id }} .sf__top { grid-template-columns: 1fr; gap: 2.2rem; }
  }
</style>

<footer class="sf">
  <div class="sf__in">
    <div class="sf__top">
      <div class="sf__brand-col">
        <p class="sf__brand">{{ shop.name | default: 'Seym' }}</p>
        {%- if section.settings.blurb != blank -%}<p class="sf__blurb">{{ section.settings.blurb }}</p>{%- endif -%}
        <div class="sf__social">
          {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".7" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
          {%- if section.settings.pinterest != blank -%}<a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.2-5s-.3-.6-.3-1.5c0-1.4.8-2.4 1.8-2.4.9 0 1.3.6 1.3 1.4 0 .9-.6 2.2-.9 3.4-.2 1 .5 1.8 1.5 1.8 1.8 0 3-2.3 3-5 0-2.1-1.4-3.6-3.9-3.6-2.8 0-4.6 2.1-4.6 4.4 0 .8.2 1.4.6 1.8.2.2.2.3.1.5l-.2.9c-.1.3-.3.4-.5.2-1-.4-1.5-1.6-1.5-2.9 0-2.4 2-5.2 6-5.2 3.2 0 5.3 2.3 5.3 4.8 0 3.3-1.8 5.7-4.5 5.7-.9 0-1.8-.5-2.1-1l-.6 2.2c-.2.7-.6 1.5-1 2A10 10 0 1 0 12 2z" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
          {%- if section.settings.tiktok != blank -%}<a href="{{ section.settings.tiktok }}" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M16 3c.3 2.2 1.8 3.9 4 4.2v3c-1.5 0-2.9-.5-4-1.3V15a6 6 0 1 1-6-6c.3 0 .7 0 1 .1v3.1a3 3 0 1 0 2 2.8V3h3z" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
          {%- if section.settings.facebook != blank -%}<a href="{{ section.settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M14 9h3V6h-3c-2 0-3 1.3-3 3v2H9v3h2v7h3v-7h2.5l.5-3H14V9z" fill="currentColor" stroke="none"/></svg></a>{%- endif -%}
        </div>
      </div>

      <div class="sf__col">
        {%- if section.settings.menu_1 != blank -%}
          <h3>{{ section.settings.menu_1_title }}</h3>
          <ul>{%- for link in linklists[section.settings.menu_1].links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}</ul>
        {%- endif -%}
      </div>

      <div class="sf__col">
        {%- if section.settings.menu_2 != blank -%}
          <h3>{{ section.settings.menu_2_title }}</h3>
          <ul>{%- for link in linklists[section.settings.menu_2].links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}</ul>
        {%- endif -%}
      </div>

      <div class="sf__col sf__contact">
        <h3>{{ section.settings.contact_title }}</h3>
        {%- if section.settings.address != blank -%}<p>{{ section.settings.address }}</p>{%- endif -%}
        {%- if section.settings.email != blank -%}<p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>{%- endif -%}
      </div>
    </div>

    <div class="sf__bottom">© {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Seym Glass Studio' }}</div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "An Istanbul atelier creating handcrafted, mouth-blown glass objects inspired by mythology and nature." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "pinterest", "label": "Pinterest" },
    { "type": "url", "id": "tiktok", "label": "TikTok" },
    { "type": "url", "id": "facebook", "label": "Facebook" },
    { "type": "header", "content": "Links" },
    { "type": "text", "id": "menu_1_title", "label": "Column 1 title", "default": "Explore" },
    { "type": "link_list", "id": "menu_1", "label": "Column 1 menu", "default": "main-menu" },
    { "type": "text", "id": "menu_2_title", "label": "Column 2 title", "default": "Information" },
    { "type": "link_list", "id": "menu_2", "label": "Column 2 menu", "default": "footer" },
    { "type": "header", "content": "Atelier" },
    { "type": "text", "id": "contact_title", "label": "Contact title", "default": "Atelier" },
    { "type": "text", "id": "address", "label": "Address", "default": "Çengelköy, Istanbul, Türkiye" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@seym.com.tr" }
  ]
}
{% endschema %}
