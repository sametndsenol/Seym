{%- comment -%}
  Seym footer — purpose-built minimalist colophon for Midnight Gallery.
  Replaces Dawn's footer.liquid mess. No third-party app blocks. No customizer.
{%- endcomment -%}

<style>
  .seym-newsletter {
    background: #122749;
    color: #efecec;
    padding: 9rem 4rem;
    text-align: center;
    border-top: 1px solid rgba(239, 236, 236, 0.08);
  }
  .seym-newsletter__inner { max-width: 64rem; margin: 0 auto; }
  .seym-newsletter h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3rem, 4vw, 4.6rem);
    letter-spacing: -0.022em;
    margin: 0 0 1.6rem;
    color: #efecec;
  }
  .seym-newsletter p {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(239, 236, 236, 0.7);
    margin: 0 0 3rem;
  }
  .seym-newsletter__form {
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(239, 236, 236, 0.4);
    max-width: 48rem;
    margin: 0 auto;
  }
  .seym-newsletter__form input[type="email"] {
    flex: 1;
    background: transparent;
    border: none;
    color: #efecec;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    padding: 1.4rem 0;
    outline: none;
  }
  .seym-newsletter__form input::placeholder {
    color: rgba(239, 236, 236, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 1rem;
  }
  .seym-newsletter__form button {
    background: transparent;
    border: none;
    color: #efecec;
    cursor: pointer;
    padding: 1.4rem;
    transition: opacity 0.3s ease;
  }
  .seym-newsletter__form button:hover { opacity: 0.7; }
  .seym-newsletter__form button svg { width: 2rem; height: 2rem; stroke: currentColor; fill: none; stroke-width: 1.4; }

  .seym-footer {
    background: #0a1424;
    color: #efecec;
    padding: 9rem 4rem 3rem;
  }
  .seym-footer__inner {
    max-width: 156rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.4fr 1fr 1fr 1.4fr;
    gap: 6rem;
    align-items: flex-start;
  }
  .seym-footer__col h3 {
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 1rem;
    font-weight: 500;
    color: #efecec;
    margin: 0 0 2rem;
  }
  .seym-footer__brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 1.6rem;
    color: #efecec;
  }
  .seym-footer__brand-desc,
  .seym-footer__address {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.3rem;
    line-height: 1.75;
    color: rgba(239, 236, 236, 0.7);
    max-width: 38rem;
  }
  .seym-footer__address a {
    color: rgba(239, 236, 236, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(239, 236, 236, 0.2);
    transition: border-color 0.3s ease;
  }
  .seym-footer__address a:hover { border-color: #efecec; }

  .seym-footer__menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .seym-footer__menu a {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.3rem;
    color: rgba(239, 236, 236, 0.7);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.3s ease, transform 0.3s ease;
    display: inline-block;
  }
  .seym-footer__menu a:hover {
    color: #efecec;
    transform: translateX(2px);
  }

  .seym-footer__social {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .seym-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(239, 236, 236, 0.18);
    color: #efecec;
    text-decoration: none;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .seym-footer__social a:hover {
    background: #efecec;
    color: #0a1424;
    border-color: #efecec;
  }
  .seym-footer__social svg {
    width: 1.5rem;
    height: 1.5rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.4;
  }

  .seym-footer__bottom {
    max-width: 156rem;
    margin: 6rem auto 0;
    padding-top: 3rem;
    border-top: 1px solid rgba(239, 236, 236, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: rgba(239, 236, 236, 0.5);
  }
  .seym-footer__legal {
    display: flex;
    gap: 2.4rem;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .seym-footer__legal a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .seym-footer__legal a:hover { color: #efecec; }

  @media (max-width: 989px) {
    .seym-footer { padding: 6rem 2rem 2.4rem; }
    .seym-footer__inner { grid-template-columns: 1fr 1fr; gap: 3.6rem; }
    .seym-footer__bottom { flex-direction: column; align-items: flex-start; }
    .seym-newsletter { padding: 6rem 2rem; }
  }
  @media (max-width: 600px) {
    .seym-footer__inner { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>

<section class="seym-newsletter">
  <div class="seym-newsletter__inner">
    <h2>Be the first to step inside.</h2>
    <p>Receive private invitations to new collection openings and atelier releases. Not frequent. Just meaningful.</p>
    {%- form 'customer', class: 'seym-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Email" required>
      <button type="submit" aria-label="Subscribe">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <line x1="4" y1="12" x2="20" y2="12"/>
          <polyline points="14 6 20 12 14 18"/>
        </svg>
      </button>
    {%- endform -%}
  </div>
</section>

<footer class="seym-footer">
  <div class="seym-footer__inner">

    <div class="seym-footer__col">
      <p class="seym-footer__brand-name">Seym Glass Studio</p>
      <p class="seym-footer__brand-desc">An Istanbul-based atelier creating handcrafted, mouth-blown glass objects inspired by mythology and nature. Founded in 2022.</p>
      <ul class="seym-footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <li><a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/></svg>
          </a></li>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <li><a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9"/><path d="M11 7c2.5 0 4 1.6 4 4 0 2-1 4-3 4-1 0-1.6-.6-1.6-1.6"/><path d="M10.5 9.5L8.5 18.5"/></svg>
          </a></li>
        {%- endif -%}
        {%- unless settings.social_instagram_link != blank or settings.social_pinterest_link != blank -%}
          <li><a href="https://www.instagram.com/seym.glass/" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/></svg>
          </a></li>
        {%- endunless -%}
      </ul>
    </div>

    <div class="seym-footer__col">
      <h3>Explore</h3>
      <ul class="seym-footer__menu">
        {%- for link in linklists.main-menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <div class="seym-footer__col">
      <h3>Information</h3>
      <ul class="seym-footer__menu">
        {%- for link in linklists.footer.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    </div>

    <div class="seym-footer__col">
      <h3>Atelier</h3>
      <p class="seym-footer__address">
        Çengelköy<br>
        Istanbul, Türkiye<br><br>
        <a href="mailto:info@seym.com.tr">info@seym.com.tr</a>
      </p>
    </div>

  </div>

  <div class="seym-footer__bottom">
    <span>© {{ 'now' | date: '%Y' }} Seym Glass Studio</span>
    <ul class="seym-footer__legal">
      {%- if shop.privacy_policy -%}<li><a href="{{ shop.privacy_policy.url }}">Privacy</a></li>{%- endif -%}
      {%- if shop.refund_policy -%}<li><a href="{{ shop.refund_policy.url }}">Returns</a></li>{%- endif -%}
      {%- if shop.terms_of_service -%}<li><a href="{{ shop.terms_of_service.url }}">Terms</a></li>{%- endif -%}
      {%- if shop.shipping_policy -%}<li><a href="{{ shop.shipping_policy.url }}">Shipping</a></li>{%- endif -%}
    </ul>
  </div>
</footer>

{% schema %}
{
  "name": "Seym Footer",
  "tag": "footer",
  "settings": []
}
{% endschema %}
