{%- comment -%}
  Seym Craft Strip — cinematic full-width editorial quote.
  A large italic statement that reinforces the handcrafted luxury story.
  Place between major content sections to create rhythmic pauses.
{%- endcomment -%}

<style>
  .seym-craft {
    padding: 12rem 5rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  /* Atmospheric gradient behind the text */
  .seym-craft::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(27, 54, 93, 0.35), transparent 70%);
    pointer-events: none;
  }

  .seym-craft__inner {
    max-width: 88rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Gold horizontal rule — top */
  .seym-craft__rule {
    width: 6rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c9a578, transparent);
    margin: 0 auto 5rem;
    opacity: 0.7;
  }

  .seym-craft__eyebrow {
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.36em;
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(239, 236, 236, 0.45);
    margin: 0 0 3.2rem;
    display: block;
  }

  .seym-craft__quote {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3rem, 4.4vw, 5.6rem);
    line-height: 1.18;
    letter-spacing: -0.018em;
    color: #efecec;
    margin: 0 0 4rem;
  }

  /* Gold word highlights — wrap certain words in <em> inside the quote */
  .seym-craft__quote em {
    font-style: italic;
    color: #c9a578;
    font-weight: 400;
  }

  .seym-craft__attribution {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(239, 236, 236, 0.38);
    margin: 0;
  }

  /* Bottom rule */
  .seym-craft__rule--bottom {
    margin: 5rem auto 0;
  }

  @media (max-width: 749px) {
    .seym-craft { padding: 8rem 2.4rem; }
    .seym-craft__quote { font-size: clamp(2.6rem, 7vw, 4rem); }
  }
</style>

<div class="seym-craft scroll-trigger animate--fade-in">
  <div class="seym-craft__inner">

    <div class="seym-craft__rule"></div>

    {%- if section.settings.eyebrow != blank -%}
      <span class="seym-craft__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <blockquote class="seym-craft__quote">
      {{ section.settings.quote | default: 'Each piece begins as breath — shaped by fire, cooled by time, and carried into the world as something that has never existed before.' }}
    </blockquote>

    {%- if section.settings.attribution != blank -%}
      <p class="seym-craft__attribution">{{ section.settings.attribution }}</p>
    {%- endif -%}

    <div class="seym-craft__rule seym-craft__rule--bottom"></div>

  </div>
</div>

{% schema %}
{
  "name": "Seym Craft Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Art of Glass"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "Quote / statement",
      "default": "<p>Each piece begins as breath — shaped by fire, cooled by time, and carried into the world as something that has never existed before.</p>"
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution (optional)",
      "default": "Seym Glass Studio — Istanbul Atelier"
    }
  ],
  "presets": [
    {
      "name": "Seym Craft Strip",
      "settings": {
        "eyebrow": "The Art of Glass",
        "attribution": "Seym Glass Studio — Istanbul Atelier"
      }
    }
  ]
}
{% endschema %}
