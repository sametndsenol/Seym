{%- comment -%}
  Seym Press — editorial "As seen in print" collage. Oversized serif headline
  + press/award names (blocks, kind = press|award) on one side; a scrapbook of
  tilted clippings on the other. Sits on a warm paper band; pairs with the
  gift banner directly below to form one press+gift moment.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --ink: #1a1a1a; --soft: rgba(26,26,26,.55); --line: rgba(26,26,26,.12);
    --wine: #8E2244; --gold: #c9a96e; --ease: cubic-bezier(.22,1,.36,1);
  }
  #shopify-section-{{ section.id }} .sps { background: var(--seym-warm,#f3efe8); padding: clamp(6rem,10vh,10rem) 0 clamp(2rem,4vh,3rem); }
  #shopify-section-{{ section.id }} .sps__wrap {
    max-width: 150rem; margin: 0 auto; padding: 0 4.8rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
  }
  #shopify-section-{{ section.id }} .sps__h {
    font: 500 clamp(4rem,8vw,9rem)/.82 'Cormorant Garamond', serif; letter-spacing: -.01em; color: var(--ink); margin: 0;
  }
  #shopify-section-{{ section.id }} .sps__h em { font-style: italic; color: var(--wine); }
  #shopify-section-{{ section.id }} .sps__ey {
    font: 300 .76rem/1 'Inter',sans-serif; letter-spacing: .34em; text-transform: uppercase; color: var(--soft); margin: 1.8rem 0 1rem;
  }
  #shopify-section-{{ section.id }} .sps__names { display: flex; flex-wrap: wrap; gap: 1.2rem 2rem; }
  #shopify-section-{{ section.id }} .sps__name { font: 400 1.35rem/1.2 'Cormorant Garamond', serif; color: var(--soft); transition: color .4s var(--ease); }
  #shopify-section-{{ section.id }} .sps__name--award { color: var(--wine); }
  #shopify-section-{{ section.id }} .sps__star { color: var(--gold); }

  #shopify-section-{{ section.id }} .sps__collage { position: relative; height: clamp(34rem,42vw,46rem); }
  #shopify-section-{{ section.id }} .sps__clip {
    position: absolute; border-radius: 3px; overflow: hidden; border: 7px solid #fff;
    box-shadow: 0 26px 54px -24px rgba(0,0,0,.42); transition: transform .7s var(--ease);
  }
  #shopify-section-{{ section.id }} .sps__clip img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .sps__clip--1 { width: 47%; aspect-ratio: 4/5; top: 0; left: 6%; transform: rotate(-6deg); }
  #shopify-section-{{ section.id }} .sps__clip--2 { width: 44%; aspect-ratio: 4/5; top: 16%; right: 8%; transform: rotate(5deg); z-index: 2; }
  #shopify-section-{{ section.id }} .sps__clip--3 { width: 41%; aspect-ratio: 4/5; bottom: 0; left: 32%; transform: rotate(2deg); }
  #shopify-section-{{ section.id }} .sps__collage:hover .sps__clip--1 { transform: rotate(-8deg) translateY(-6px); }
  #shopify-section-{{ section.id }} .sps__collage:hover .sps__clip--2 { transform: rotate(6deg) translateY(-6px); }
  #shopify-section-{{ section.id }} .sps__collage:hover .sps__clip--3 { transform: rotate(3deg) translateY(-6px); }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .sps__wrap { grid-template-columns: 1fr; gap: 2rem; }
    #shopify-section-{{ section.id }} .sps__collage { height: 40rem; order: 2; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sps { padding: clamp(4rem,8vh,5.5rem) 0 2rem; }
    #shopify-section-{{ section.id }} .sps__wrap { padding: 0 2rem; }
    #shopify-section-{{ section.id }} .sps__collage { height: 32rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .sps__clip { transition: none; }
  }
</style>

<section class="sps" data-reveal>
  <div class="sps__wrap">
    <div class="sps__body">
      <h2 class="sps__h">
        {%- if section.settings.heading_1 != blank -%}{{ section.settings.heading_1 }}<br>{%- endif -%}
        {%- if section.settings.heading_2 != blank -%}<em>{{ section.settings.heading_2 }}</em>{%- endif -%}
      </h2>
      {%- if section.settings.eyebrow != blank -%}<p class="sps__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <div class="sps__names">
        {%- for block in section.blocks -%}
          {%- if block.settings.kind == 'award' -%}
            <span class="sps__name sps__name--award" {{ block.shopify_attributes }}><span class="sps__star" aria-hidden="true">&#9733;</span> {{ block.settings.name }}</span>
          {%- else -%}
            <span class="sps__name" {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="sps__collage">
      {%- assign img1 = section.settings.image_1 | default: section.settings.image -%}
      {%- if img1 != blank -%}<div class="sps__clip sps__clip--1">{{ img1 | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300,500,700', alt: '' }}</div>{%- endif -%}
      {%- if section.settings.image_2 != blank -%}<div class="sps__clip sps__clip--2">{{ section.settings.image_2 | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300,500,700', alt: '' }}</div>{%- endif -%}
      {%- if section.settings.image_3 != blank -%}<div class="sps__clip sps__clip--3">{{ section.settings.image_3 | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300,500,700', alt: '' }}</div>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "heading_1", "label": "Heading line 1", "default": "As seen" },
    { "type": "text", "id": "heading_2", "label": "Heading line 2 (italic)", "default": "in print." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "As featured in" },
    { "type": "image_picker", "id": "image_1", "label": "Clipping 1" },
    { "type": "image_picker", "id": "image_2", "label": "Clipping 2" },
    { "type": "image_picker", "id": "image_3", "label": "Clipping 3" },
    { "type": "image_picker", "id": "image", "label": "(legacy) Feature image" }
  ],
  "blocks": [
    {
      "type": "publication",
      "name": "Publication",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "select", "id": "kind", "label": "Category", "default": "press",
          "options": [ { "value": "press", "label": "Press" }, { "value": "award", "label": "Award" } ] }
      ]
    }
  ],
  "presets": [{
    "name": "Press",
    "blocks": [
      { "type": "publication", "settings": { "name": "Homeart", "kind": "press" } },
      { "type": "publication", "settings": { "name": "Design Turkey", "kind": "press" } },
      { "type": "publication", "settings": { "name": "A' Design Award", "kind": "award" } }
    ]
  }]
}
{% endschema %}
