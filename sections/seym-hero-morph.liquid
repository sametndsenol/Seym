{%- comment -%}
  Seym Hero Morph — full-screen video that morphs into the center card
  of a triptych as the user scrolls. 250vh scroll runway, sticky stage.
  Side cards RISE FROM BELOW into their slot. Hero text fades, triptych
  captions appear. Final state: three portrait 1:2 cards, centered in the
  stage with the white background showing around them.

  Motion is scroll-driven but SMOOTHED: scroll sets a target progress and
  the rendered progress lerps toward it each rAF frame for buttery glide.
  rAF idles when settled and restarts on scroll.

  Mobile (<=749px): no morph — hero stacks above triptych cards.
  Reduced motion: morph skipped — final triptych shown statically.
{%- endcomment -%}

<style>
  #SeymHM-{{ section.id }}.shm {
    height: 250vh;
    position: relative;
    background: #0a0a0a;
    --shm-ease: cubic-bezier(0.22,1,0.36,1);
  }
  #SeymHM-{{ section.id }} .shm__stage {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
    background: #0a0a0a;
  }

  /* --- Side cards --- */
  #SeymHM-{{ section.id }} .shm__side {
    position: relative;
    flex: 0 0 0%;
    align-self: center;
    overflow: hidden;
    border-radius: 2px;
    will-change: flex-basis, height;
  }
  /* Inner riser: clipped by the column, translates up from below */
  #SeymHM-{{ section.id }} .shm__side-inner {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    opacity: 0;
    will-change: transform, opacity;
  }
  #SeymHM-{{ section.id }} .shm__side-link {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
    z-index: 3;
  }
  #SeymHM-{{ section.id }} .shm__side-media {
    position: absolute; inset: 0;
    overflow: hidden;
  }
  #SeymHM-{{ section.id }} .shm__side img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--shm-ease);
    will-change: transform;
  }
  #SeymHM-{{ section.id }} .shm__side-inner::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0) 40%,
      rgba(0,0,0,0.18) 62%,
      rgba(0,0,0,0.58) 100%);
    z-index: 1;
    pointer-events: none;
  }
  #SeymHM-{{ section.id }} .shm__side-link:hover ~ .shm__side-inner img,
  #SeymHM-{{ section.id }} .shm__side:hover img { transform: scale(1.04); }
  #SeymHM-{{ section.id }} .shm__side-txt {
    position: absolute;
    z-index: 2;
    bottom: 2.4rem; left: 2.2rem; right: 2.2rem;
    opacity: 0;
  }
  #SeymHM-{{ section.id }} .shm__side-ey {
    display: block;
    font: 300 0.66rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin: 0 0 0.55rem;
  }
  #SeymHM-{{ section.id }} .shm__side-name {
    font: 300 1.55rem/1.2 'Cormorant Garamond', serif;
    letter-spacing: 0.04em;
    color: #fff; margin: 0 0 0.55rem;
  }
  #SeymHM-{{ section.id }} .shm__side-price {
    display: block;
    font: 300 0.82rem/1.2 'Inter', sans-serif;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.82);
    margin: 0 0 1rem;
  }
  #SeymHM-{{ section.id }} .shm__side-cta {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    font: 400 0.62rem/1 'Inter', sans-serif;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #fff;
    position: relative;
    padding-bottom: 0.4rem;
  }
  #SeymHM-{{ section.id }} .shm__side-cta::after {
    content: '';
    position: absolute; left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: rgba(255,255,255,0.55);
    transform: scaleX(1);
    transform-origin: left;
    transition: transform 0.5s var(--shm-ease), background 0.5s var(--shm-ease);
  }
  #SeymHM-{{ section.id }} .shm__side:hover .shm__side-cta::after { background: #fff; }

  /* --- Center (video) card --- */
  #SeymHM-{{ section.id }} .shm__center {
    position: relative;
    flex: 0 0 100%;
    align-self: center;
    z-index: 2;
    overflow: hidden;
    border-radius: 2px;
    will-change: flex-basis, height;
  }
  #SeymHM-{{ section.id }} .shm__center-link {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
    z-index: 1;
  }
  #SeymHM-{{ section.id }} .shm__center video,
  #SeymHM-{{ section.id }} .shm__center .shm__center-poster,
  #SeymHM-{{ section.id }} .shm__center img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  #SeymHM-{{ section.id }} .shm__center-poster {
    z-index: 0;
    background-size: cover;
    background-position: center;
  }
  #SeymHM-{{ section.id }} .shm__center video { z-index: 0; }
  #SeymHM-{{ section.id }} .shm__center-grad {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0.28) 0%, rgba(0,0,0,0.08) 28%,
      rgba(0,0,0,0.06) 55%, rgba(0,0,0,0.52) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Hero text — centered, fades out on scroll */
  #SeymHM-{{ section.id }} .shm__hero-txt {
    position: absolute;
    z-index: 3;
    bottom: 12vh;
    left: 0; right: 0;
    text-align: center;
    color: #fff;
    will-change: opacity, transform;
    pointer-events: none;
  }
  #SeymHM-{{ section.id }} .shm__hero-txt > * { pointer-events: auto; }
  #SeymHM-{{ section.id }} .shm__hero-ey {
    font: 300 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin: 0 0 1.6rem;
  }
  #SeymHM-{{ section.id }} .shm__hero-h {
    font: 300 clamp(3.4rem,6vw,6.5rem)/0.98 'Cormorant Garamond', serif;
    letter-spacing: 0.05em;
    margin: 0 0 1.8rem; color: #fff;
  }
  /* Thin animated divider under the masthead */
  #SeymHM-{{ section.id }} .shm__hero-rule {
    width: 1px;
    height: 0;
    margin: 0 auto 2.2rem;
    background: rgba(255,255,255,0.4);
  }
  #SeymHM-{{ section.id }} .shm__hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: 400 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #fff; text-decoration: none;
    border: 1px solid rgba(255,255,255,0.45);
    padding: 0 2.8rem;
    min-height: 48px;
    transition: background .35s var(--shm-ease), border-color .35s var(--shm-ease);
  }
  #SeymHM-{{ section.id }} .shm__hero-cta:hover { background: rgba(255,255,255,0.12); border-color: #fff; }

  /* Initial entrance (load) — refined ease-up */
  #SeymHM-{{ section.id }} .shm__hero-ey,
  #SeymHM-{{ section.id }} .shm__hero-h,
  #SeymHM-{{ section.id }} .shm__hero-rule,
  #SeymHM-{{ section.id }} .shm__hero-cta {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 1s var(--shm-ease), transform 1.1s var(--shm-ease), height 1.1s var(--shm-ease), background .35s var(--shm-ease), border-color .35s var(--shm-ease);
  }
  #SeymHM-{{ section.id }}.is-entered .shm__hero-ey { opacity: 1; transform: none; transition-delay: .1s; }
  #SeymHM-{{ section.id }}.is-entered .shm__hero-h  { opacity: 1; transform: none; transition-delay: .22s; }
  #SeymHM-{{ section.id }}.is-entered .shm__hero-rule { height: 42px; transition-delay: .42s; opacity: 1; transform: none; }
  #SeymHM-{{ section.id }}.is-entered .shm__hero-cta { opacity: 1; transform: none; transition-delay: .52s; }

  /* Scroll cue — slim line + label, fades as morph begins */
  #SeymHM-{{ section.id }} .shm__cue {
    position: absolute;
    left: 50%;
    bottom: 2.6rem;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    color: rgba(255,255,255,0.6);
    will-change: opacity;
    pointer-events: none;
  }
  #SeymHM-{{ section.id }} .shm__cue-label {
    font: 300 0.58rem/1 'Inter', sans-serif;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }
  #SeymHM-{{ section.id }} .shm__cue-line {
    position: relative;
    width: 1px;
    height: 46px;
    background: rgba(255,255,255,0.2);
    overflow: hidden;
  }
  #SeymHM-{{ section.id }} .shm__cue-line::after {
    content: '';
    position: absolute;
    left: 0; top: 0;
    width: 100%; height: 40%;
    background: rgba(255,255,255,0.85);
    animation: shmCue 2.4s var(--shm-ease) infinite;
  }
  @keyframes shmCue {
    0%   { transform: translateY(-110%); }
    60%  { transform: translateY(260%); }
    100% { transform: translateY(260%); }
  }

  /* Triptych center caption — hidden initially, fades in */
  #SeymHM-{{ section.id }} .shm__trip-txt {
    position: absolute; inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    padding: 0 2rem 2.4rem;
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
  }
  #SeymHM-{{ section.id }} .shm__trip-txt > * { pointer-events: auto; }
  #SeymHM-{{ section.id }} .shm__trip-ey {
    font: 300 0.66rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.62);
    margin: 0 0 0.7rem;
  }
  #SeymHM-{{ section.id }} .shm__trip-h {
    font: 300 clamp(1.9rem,2.4vw,2.8rem)/1.05 'Cormorant Garamond', serif;
    letter-spacing: 0.04em;
    color: #fff;
    margin: 0 0 0.55rem;
  }
  #SeymHM-{{ section.id }} .shm__trip-price {
    font: 300 0.9rem/1.2 'Inter', sans-serif;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.85);
    margin: 0 0 1.2rem;
  }
  #SeymHM-{{ section.id }} .shm__trip-cta {
    font: 400 0.62rem/1 'Inter', sans-serif;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #fff;
    position: relative;
    padding-bottom: 0.4rem;
    min-height: 24px;
    display: inline-flex; align-items: center;
    text-decoration: none;
  }
  #SeymHM-{{ section.id }} .shm__trip-cta::after {
    content: '';
    position: absolute; left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: rgba(255,255,255,0.55);
    transform: scaleX(1);
    transform-origin: left;
    transition: background .5s var(--shm-ease);
  }
  #SeymHM-{{ section.id }} .shm__center:hover .shm__trip-cta::after { background: #fff; }
  #SeymHM-{{ section.id }} .shm__center:hover img,
  #SeymHM-{{ section.id }} .shm__center:hover video { /* video scale handled below */ }

  /* --- Gaps (animated via JS) --- */
  #SeymHM-{{ section.id }} .shm__gap { flex: 0 0 0; will-change: flex-basis; }
  #SeymHM-{{ section.id }} .shm__pad { flex: 0 0 0; will-change: flex-basis; }

  /* --- Reduced motion: skip morph, show final triptych statically --- */
  @media (prefers-reduced-motion: reduce) {
    #SeymHM-{{ section.id }}.shm { height: auto; background: #faf9f7; }
    #SeymHM-{{ section.id }} .shm__stage {
      position: relative;
      height: auto;
      background: #faf9f7 !important;
      gap: 1.2rem;
      padding: 1.6rem;
      align-items: stretch;
    }
    #SeymHM-{{ section.id }} .shm__center,
    #SeymHM-{{ section.id }} .shm__side {
      flex: 1 1 0 !important;
      height: auto !important;
      aspect-ratio: 1 / 2;
    }
    #SeymHM-{{ section.id }} .shm__side-inner {
      transform: none !important;
      opacity: 1 !important;
    }
    #SeymHM-{{ section.id }} .shm__side-txt,
    #SeymHM-{{ section.id }} .shm__trip-txt { opacity: 1 !important; }
    #SeymHM-{{ section.id }} .shm__hero-txt,
    #SeymHM-{{ section.id }} .shm__cue { display: none; }
    #SeymHM-{{ section.id }} .shm__gap,
    #SeymHM-{{ section.id }} .shm__pad { display: none; }
    #SeymHM-{{ section.id }} .shm__hero-ey,
    #SeymHM-{{ section.id }} .shm__hero-h,
    #SeymHM-{{ section.id }} .shm__hero-rule,
    #SeymHM-{{ section.id }} .shm__hero-cta { transition: none; }
  }

  /* --- Mobile: no morph, stack as portrait 1:2 cards --- */
  @media(max-width:749px){
    #SeymHM-{{ section.id }}.shm { height: auto; background: #faf9f7; }
    #SeymHM-{{ section.id }} .shm__stage {
      position: relative;
      height: auto;
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
      padding: 1rem;
      background: #faf9f7 !important;
    }
    #SeymHM-{{ section.id }} .shm__center {
      position: relative;
      inset: auto;
      flex: 0 0 auto !important;
      aspect-ratio: 1 / 2;
      max-height: 88vh;
      height: auto !important;
      z-index: 1;
    }
    #SeymHM-{{ section.id }} .shm__side {
      flex: 0 0 auto !important;
      aspect-ratio: 1 / 2;
      max-height: 88vh;
      height: auto !important;
    }
    #SeymHM-{{ section.id }} .shm__side-inner {
      transform: none !important;
      opacity: 1 !important;
    }
    #SeymHM-{{ section.id }} .shm__side-txt { opacity: 1 !important; }
    #SeymHM-{{ section.id }} .shm__hero-txt {
      bottom: 8vh; padding: 0 2rem;
      opacity: 1 !important; transform: none !important;
    }
    #SeymHM-{{ section.id }} .shm__hero-ey,
    #SeymHM-{{ section.id }} .shm__hero-h,
    #SeymHM-{{ section.id }} .shm__hero-cta { opacity: 1; transform: none; }
    #SeymHM-{{ section.id }} .shm__hero-rule { height: 42px; }
    #SeymHM-{{ section.id }} .shm__trip-txt,
    #SeymHM-{{ section.id }} .shm__cue { display: none; }
    #SeymHM-{{ section.id }} .shm__gap,
    #SeymHM-{{ section.id }} .shm__pad { display: none; }
  }
</style>

<section class="shm" id="SeymHM-{{ section.id }}">
  <div class="shm__stage" id="SeymHMStage-{{ section.id }}">
    <div class="shm__pad" id="shm-padL-{{ section.id }}"></div>

    {%- comment -%} Left side card {%- endcomment -%}
    {%- assign left = section.blocks[0] -%}
    <div class="shm__side shm__side--l" id="shm-sideL-{{ section.id }}">
      <div class="shm__side-inner" id="shm-innerL-{{ section.id }}">
        <div class="shm__side-media">
          {%- if left.settings.image != blank -%}
            {{ left.settings.image | image_url: width: 1000 | image_tag:
               loading: 'lazy', widths: '400,600,800,1000',
               sizes: '(max-width:749px) 100vw, 33vw' }}
          {%- endif -%}
        </div>
        <div class="shm__side-txt" id="shm-capL-{{ section.id }}">
          {%- if left.settings.eyebrow != blank -%}<span class="shm__side-ey">{{ left.settings.eyebrow }}</span>{%- endif -%}
          {%- if left.settings.title != blank -%}<h3 class="shm__side-name">{{ left.settings.title }}</h3>{%- endif -%}
          {%- if left.settings.price != blank -%}<span class="shm__side-price">{{ left.settings.price }}</span>{%- endif -%}
          {%- if left.settings.side_cta != blank -%}<span class="shm__side-cta">{{ left.settings.side_cta }}</span>{%- endif -%}
        </div>
      </div>
      {%- if left.settings.link != blank -%}
        <a class="shm__side-link" href="{{ left.settings.link }}" aria-label="{{ left.settings.title | default: 'View' | escape }}"></a>
      {%- endif -%}
    </div>

    <div class="shm__gap" id="shm-gapL-{{ section.id }}"></div>

    {%- comment -%} Center — video {%- endcomment -%}
    {%- assign center = section.blocks[1] -%}
    <div class="shm__center" id="shm-center-{{ section.id }}">
      {%- if section.settings.video_asset != blank -%}
        {%- if center.settings.image != blank -%}
          <div class="shm__center-poster" style="background-image:url('{{ center.settings.image | image_url: width: 1920 }}');"></div>
        {%- endif -%}
        <video autoplay muted loop playsinline preload="auto"
          {%- if center.settings.image != blank %} poster="{{ center.settings.image | image_url: width: 1920 }}"{% endif %}>
          <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
        </video>
      {%- elsif center.settings.image != blank -%}
        {{ center.settings.image | image_url: width: 2000 | image_tag:
           loading: 'eager', widths: '800,1200,1600,2000', sizes: '100vw' }}
      {%- endif -%}
      {%- if center.settings.link != blank -%}
        <a class="shm__center-link" href="{{ center.settings.link }}" aria-label="{{ center.settings.title | default: 'View collection' | escape }}"></a>
      {%- endif -%}
      <div class="shm__center-grad"></div>

      <div class="shm__hero-txt" id="shm-heroTxt-{{ section.id }}">
        {%- if section.settings.hero_eyebrow != blank -%}<p class="shm__hero-ey">{{ section.settings.hero_eyebrow }}</p>{%- endif -%}
        {%- if section.settings.hero_heading != blank -%}<h1 class="shm__hero-h">{{ section.settings.hero_heading }}</h1>{%- endif -%}
        <span class="shm__hero-rule" aria-hidden="true"></span>
        {%- if section.settings.hero_cta != blank and section.settings.hero_link != blank -%}
          <a href="{{ section.settings.hero_link }}" class="shm__hero-cta">{{ section.settings.hero_cta }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.scroll_cue != blank -%}
        <div class="shm__cue" id="shm-cue-{{ section.id }}" aria-hidden="true">
          <span class="shm__cue-label">{{ section.settings.scroll_cue }}</span>
          <span class="shm__cue-line"></span>
        </div>
      {%- endif -%}

      <div class="shm__trip-txt" id="shm-tripTxt-{{ section.id }}">
        {%- if center.settings.eyebrow != blank -%}<span class="shm__trip-ey">{{ center.settings.eyebrow }}</span>{%- endif -%}
        {%- if center.settings.title != blank -%}<h2 class="shm__trip-h">{{ center.settings.title }}</h2>{%- endif -%}
        {%- if center.settings.price != blank -%}<span class="shm__trip-price">{{ center.settings.price }}</span>{%- endif -%}
        {%- if center.settings.cta_label != blank -%}
          {%- if center.settings.link != blank -%}
            <a class="shm__trip-cta" href="{{ center.settings.link }}">{{ center.settings.cta_label }}</a>
          {%- else -%}
            <span class="shm__trip-cta">{{ center.settings.cta_label }}</span>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>

    <div class="shm__gap" id="shm-gapR-{{ section.id }}"></div>

    {%- comment -%} Right side card {%- endcomment -%}
    {%- assign right = section.blocks[2] -%}
    <div class="shm__side shm__side--r" id="shm-sideR-{{ section.id }}">
      <div class="shm__side-inner" id="shm-innerR-{{ section.id }}">
        <div class="shm__side-media">
          {%- if right.settings.image != blank -%}
            {{ right.settings.image | image_url: width: 1000 | image_tag:
               loading: 'lazy', widths: '400,600,800,1000',
               sizes: '(max-width:749px) 100vw, 33vw' }}
          {%- endif -%}
        </div>
        <div class="shm__side-txt" id="shm-capR-{{ section.id }}">
          {%- if right.settings.eyebrow != blank -%}<span class="shm__side-ey">{{ right.settings.eyebrow }}</span>{%- endif -%}
          {%- if right.settings.title != blank -%}<h3 class="shm__side-name">{{ right.settings.title }}</h3>{%- endif -%}
          {%- if right.settings.price != blank -%}<span class="shm__side-price">{{ right.settings.price }}</span>{%- endif -%}
          {%- if right.settings.side_cta != blank -%}<span class="shm__side-cta">{{ right.settings.side_cta }}</span>{%- endif -%}
        </div>
      </div>
      {%- if right.settings.link != blank -%}
        <a class="shm__side-link" href="{{ right.settings.link }}" aria-label="{{ right.settings.title | default: 'View' | escape }}"></a>
      {%- endif -%}
    </div>

    <div class="shm__pad" id="shm-padR-{{ section.id }}"></div>
  </div>
</section>

<script>
(function(){
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;                       // static final triptych via CSS
  if (window.innerWidth < 750) return;      // mobile stacked fallback

  var sec    = document.getElementById('SeymHM-{{ section.id }}');
  var stage  = document.getElementById('SeymHMStage-{{ section.id }}');
  var center = document.getElementById('shm-center-{{ section.id }}');
  var sideL  = document.getElementById('shm-sideL-{{ section.id }}');
  var sideR  = document.getElementById('shm-sideR-{{ section.id }}');
  var innerL = document.getElementById('shm-innerL-{{ section.id }}');
  var innerR = document.getElementById('shm-innerR-{{ section.id }}');
  var gapL   = document.getElementById('shm-gapL-{{ section.id }}');
  var gapR   = document.getElementById('shm-gapR-{{ section.id }}');
  var padL   = document.getElementById('shm-padL-{{ section.id }}');
  var padR   = document.getElementById('shm-padR-{{ section.id }}');
  var heroT  = document.getElementById('shm-heroTxt-{{ section.id }}');
  var tripT  = document.getElementById('shm-tripTxt-{{ section.id }}');
  var capL   = document.getElementById('shm-capL-{{ section.id }}');
  var capR   = document.getElementById('shm-capR-{{ section.id }}');
  var cue    = document.getElementById('shm-cue-{{ section.id }}');

  if (!sec || !center) return;

  // Entrance on load
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){ sec.classList.add('is-entered'); });
  });

  function lerp(a, b, t) { return a + (b - a) * t; }
  // Spec easing cubic-bezier(0.22,1,0.36,1) ~ easeOutQuint-ish curve
  function ease(t) { t = clamp(t); return 1 - Math.pow(1 - t, 3.2); }
  function clamp(v) { return v < 0 ? 0 : (v > 1 ? 1 : v); }
  function seg(p, a, b) { return clamp((p - a) / (b - a)); }

  // Final portrait card: 1:2 aspect, height capped at 80vh of the stage.
  function portraitHeight() {
    return Math.min(window.innerHeight * 0.8, (window.innerWidth * 0.3333) * 2);
  }

  // ---- Smoothing / inertia ----
  var target = 0;       // raw scroll-derived progress 0..1
  var cur    = 0;       // rendered (lerped) progress
  var rafId  = null;
  var running = false;

  function readTarget() {
    var scrollable = sec.offsetHeight - window.innerHeight;
    if (scrollable <= 0) { target = 0; return; }
    var scrolled = -sec.getBoundingClientRect().top;
    target = clamp(scrolled / scrollable);
  }

  function render(p) {
    // Center card: shrink 100% -> 33.33%
    var contract = ease(seg(p, 0.06, 0.62));
    center.style.flex = '0 0 ' + lerp(100, 33.33, contract) + '%';

    // Side slots open early so layout settles before the rise completes.
    var slot = ease(seg(p, 0.12, 0.6));
    var sideBasis = lerp(0, 33.33, slot);
    sideL.style.flex = '0 0 ' + sideBasis + '%';
    sideR.style.flex = '0 0 ' + sideBasis + '%';

    // Rise from below with a soft stagger (left slightly leads right).
    var riseL = ease(seg(p, 0.40, 0.96));
    var riseR = ease(seg(p, 0.46, 1.0));
    innerL.style.transform = 'translateY(' + lerp(100, 0, riseL) + '%)';
    innerR.style.transform = 'translateY(' + lerp(100, 0, riseR) + '%)';
    innerL.style.opacity = lerp(0, 1, ease(seg(p, 0.40, 0.7)));
    innerR.style.opacity = lerp(0, 1, ease(seg(p, 0.46, 0.76)));

    // Final portrait shape — heights settle to 1:2 over the last stretch.
    var shape = ease(seg(p, 0.55, 0.98));
    var ph = portraitHeight();
    var cardH = lerp(window.innerHeight, ph, shape);
    center.style.height = cardH + 'px';
    sideL.style.height  = cardH + 'px';
    sideR.style.height  = cardH + 'px';

    // Gaps & padding breathe open with the contraction.
    var frame = ease(seg(p, 0.1, 0.7));
    gapL.style.flex = '0 0 ' + lerp(0, 1.6, frame) + 'rem';
    gapR.style.flex = '0 0 ' + lerp(0, 1.6, frame) + 'rem';
    padL.style.flex = '0 0 ' + lerp(0, 2.4, frame) + 'rem';
    padR.style.flex = '0 0 ' + lerp(0, 2.4, frame) + 'rem';

    // Hero text gracefully fades + lifts away early.
    var heroFade = seg(p, 0.0, 0.3);
    heroT.style.opacity = lerp(1, 0, ease(heroFade));
    heroT.style.transform = 'translateY(' + lerp(0, -36, ease(heroFade)) + 'px)';

    // Scroll cue fades the moment morph begins.
    if (cue) cue.style.opacity = lerp(1, 0, ease(seg(p, 0.0, 0.12)));

    // Captions / prices fade in last.
    tripT.style.opacity = lerp(0, 1, ease(seg(p, 0.72, 0.96)));
    var capOp = lerp(0, 1, ease(seg(p, 0.78, 1.0)));
    capL.style.opacity = capOp;
    capR.style.opacity = capOp;

    // Background: smooth black -> ivory. Cubic interpolation avoids banding.
    var bg = ease(seg(p, 0.05, 0.6));
    var r = Math.round(lerp(10, 250, bg));
    var g = Math.round(lerp(10, 249, bg));
    var b = Math.round(lerp(10, 247, bg));
    stage.style.background = 'rgb(' + r + ',' + g + ',' + b + ')';
  }

  function tick() {
    var diff = target - cur;
    if (Math.abs(diff) < 0.0006) {
      cur = target;
      render(cur);
      running = false;
      rafId = null;
      return;                       // idle — stop churning
    }
    cur += diff * 0.12;             // inertial glide
    render(cur);
    rafId = requestAnimationFrame(tick);
  }

  function kick() {
    readTarget();
    if (!running) {
      running = true;
      rafId = requestAnimationFrame(tick);
    }
  }

  var queued = false;
  function onScroll() {
    if (queued) return;
    queued = true;
    requestAnimationFrame(function(){ queued = false; kick(); });
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', function(){ readTarget(); render(cur); kick(); });

  // Initial paint at rest.
  readTarget();
  cur = target;
  render(cur);
})();
</script>

