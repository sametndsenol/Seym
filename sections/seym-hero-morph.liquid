{%- comment -%}
  Seym Hero — Daum-style. Full-screen video at the top; on scroll the video
  shrinks AS A WHOLE (no side-crop, no bars) and recedes while two banners
  arrive from the sides, settling into three EQUAL rounded cards with the
  video centred. Each card blooms a soft halo in its own (configurable)
  glass colour on hover. Scroll-driven motion is lerp-smoothed.
  Mobile / reduced-motion: no morph — clean stacked cards.
{%- endcomment -%}

{%- liquid
  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
-%}

{%- assign left = section.blocks[0] -%}
{%- assign center = section.blocks[1] -%}
{%- assign right = section.blocks[2] -%}

<style>
  #SeymHM-{{ section.id }}.shm { height: 190vh; position: relative; background: var(--seym-paper,#fcfbf9); }
  #SeymHM-{{ section.id }} .shm__stage {
    position: sticky; top: 0; height: 100vh; height: 100dvh; overflow: hidden;
    display: flex; align-items: center; justify-content: center; gap: 0; background: var(--seym-paper,#fcfbf9);
  }
  #SeymHM-{{ section.id }} .shm__card {
    position: relative; flex: 0 0 auto; background: var(--seym-warm,#f3efe8); overflow: visible;
    will-change: width, height, transform;
  }
  #SeymHM-{{ section.id }} .shm__card::before {
    content: ''; position: absolute; inset: -26px; z-index: -1; border-radius: 34px;
    background: radial-gradient(closest-side, var(--glow), transparent 72%);
    opacity: 0; filter: blur(28px); transition: opacity .7s cubic-bezier(.22,1,.36,1);
  }
  #SeymHM-{{ section.id }} .shm__card:hover::before { opacity: .7; }
  #SeymHM-{{ section.id }} .shm__clip { position: absolute; inset: 0; overflow: hidden; }
  /* Subtle vignette — gives depth and keeps a bright (e.g. white studio)
     video from reading as a flat block against the coloured banners. */
  #SeymHM-{{ section.id }} .shm__clip::after {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1;
    background: radial-gradient(125% 120% at 50% 42%, transparent 56%, rgba(0,0,0,.30));
  }
  #SeymHM-{{ section.id }} .shm__clip img,
  #SeymHM-{{ section.id }} .shm__clip video {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform 1.2s cubic-bezier(.22,1,.36,1);
  }
  #SeymHM-{{ section.id }} .shm__card:hover .shm__clip img,
  #SeymHM-{{ section.id }} .shm__card:hover .shm__clip video { transform: scale(1.05); }
  #SeymHM-{{ section.id }} .shm__scrim {
    position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.58), rgba(0,0,0,0) 46%);
  }
  #SeymHM-{{ section.id }} .shm__link { position: absolute; inset: 0; z-index: 7; pointer-events: auto; cursor: pointer; }
  #SeymHM-{{ section.id }} .shm__card[data-link] { cursor: pointer; }
  #SeymHM-{{ section.id }} .shm__top {
    position: absolute; top: 0; left: 0; right: 0; height: 22vh; z-index: 6; pointer-events: none;
    background: linear-gradient(to bottom, rgba(252,251,249,.62), rgba(252,251,249,0));
  }

  #SeymHM-{{ section.id }} .shm__cap {
    position: absolute; left: 1.8rem; right: 1.8rem; bottom: 1.8rem; z-index: 3; color: #fff; opacity: 0;
  }
  #SeymHM-{{ section.id }} .shm__cap--c { text-align: center; left: 0; right: 0; }
  #SeymHM-{{ section.id }} .shm__cap .shm__ey {
    font: 300 .82rem/1 'Inter',sans-serif; letter-spacing: .34em; text-transform: uppercase;
    color: var(--seym-gold,#b0935f); margin: 0 0 .7rem;
  }
  #SeymHM-{{ section.id }} .shm__cap--c .shm__ey { color: #fff; letter-spacing: .4em; text-shadow: 0 1px 12px rgba(0,0,0,.5); }
  #SeymHM-{{ section.id }} .shm__cap .shm__name {
    font: 400 2.6rem/1.1 'Cormorant Garamond',serif; margin: 0 0 .9rem; color: #fff;
  }
  #SeymHM-{{ section.id }} .shm__cap--c .shm__name { font-weight: 300; font-size: 2.4rem; letter-spacing: .1em; margin: 0; }
  #SeymHM-{{ section.id }} .shm__cap-logo {
    position: relative; inset: auto; display: block; object-fit: contain;
    height: clamp(2.6rem, 3.4vw, 3.8rem); width: auto; margin: .3rem auto 0;
    filter: brightness(0) invert(1) drop-shadow(0 2px 16px rgba(0,0,0,.6));
  }
  #SeymHM-{{ section.id }} .shm__cap .shm__cta {
    font: 400 .78rem/1 'Inter',sans-serif; letter-spacing: .3em; text-transform: uppercase; color: #fff;
    border-bottom: 1px solid rgba(255,255,255,.55); padding-bottom: .3rem; display: inline-block;
  }

  /* Hero masthead over the full-screen video */
  #SeymHM-{{ section.id }} .shm__hero {
    position: absolute; left: 0; right: 0; bottom: 13vh; text-align: center; z-index: 5; color: #fff;
    will-change: opacity, transform;
  }
  #SeymHM-{{ section.id }} .shm__hero-ey {
    font: 300 .72rem/1 'Inter',sans-serif; letter-spacing: .42em; text-transform: uppercase;
    color: rgba(255,255,255,.82); margin: 0 0 1.6rem;
  }
  #SeymHM-{{ section.id }} .shm__hero-h {
    font: 300 clamp(3.4rem,8vw,8rem)/.9 'Cormorant Garamond',serif; letter-spacing: .14em; margin: 0; color: #fff;
  }
  #SeymHM-{{ section.id }} .shm__hero-logo {
    position: relative; inset: auto; display: block; object-fit: contain;
    height: clamp(5rem, 9vw, 10rem); width: auto; max-width: 86vw; margin: 0 auto;
    filter: brightness(0) invert(1) drop-shadow(0 2px 18px rgba(0,0,0,.45));
  }
  #SeymHM-{{ section.id }} .shm__hero-rule { display: block; width: 1px; height: 50px; background: rgba(255,255,255,.5); margin: 1.8rem auto; }
  #SeymHM-{{ section.id }} .shm__hero-cta {
    display: inline-block; font: 400 .7rem/1 'Inter',sans-serif; letter-spacing: .32em; text-transform: uppercase;
    color: #fff; text-decoration: none; border: 1px solid rgba(255,255,255,.5); padding: 1.1rem 2.7rem;
    transition: background .3s ease,border-color .3s ease;
  }
  #SeymHM-{{ section.id }} .shm__hero-cta:hover { background: rgba(255,255,255,.12); border-color: #fff; }
  #SeymHM-{{ section.id }} .shm__cue {
    position: absolute; left: 50%; bottom: 2.2rem; transform: translateX(-50%); z-index: 5;
    color: rgba(255,255,255,.65); font: 300 .6rem/1 'Inter',sans-serif; letter-spacing: .34em; text-transform: uppercase;
  }

  /* Mobile / reduced-motion: no morph, clean stack */
  @media (max-width: 749px), (prefers-reduced-motion: reduce) {
    #SeymHM-{{ section.id }}.shm { height: auto; }
    #SeymHM-{{ section.id }} .shm__stage {
      position: relative; height: auto; flex-direction: column; gap: 1rem; padding: 1rem;
      background: var(--seym-paper,#fcfbf9) !important;
    }
    #SeymHM-{{ section.id }} .shm__card {
      width: 100% !important; height: auto !important; aspect-ratio: 4/5; border-radius: 12px !important; overflow: hidden;
    }
    #SeymHM-{{ section.id }} .shm__clip { border-radius: 12px !important; }
    #SeymHM-{{ section.id }} .shm__cap { opacity: 1 !important; }
    #SeymHM-{{ section.id }} .shm__scrim { opacity: .5 !important; }
    #SeymHM-{{ section.id }} .shm__hero, #SeymHM-{{ section.id }} .shm__cue { display: none; }
  }
</style>

<section class="shm" id="SeymHM-{{ section.id }}">
  <div class="shm__stage" id="shmStage-{{ section.id }}">

    {%- comment -%} Top scrim — darkens the header zone over the (possibly
      light) video so the white nav is always legible; fades as the morph
      begins and the header turns solid. {%- endcomment -%}
    <div class="shm__top" id="shmTop-{{ section.id }}"></div>

    {%- comment -%} Left banner {%- endcomment -%}
    <article class="shm__card" id="shmL-{{ section.id }}" data-link="{{ left.settings.link }}" style="--glow: {{ left.settings.glow | default: 'rgba(72,98,182,.85)' }};">
      <div class="shm__clip">
        {%- if left.settings.image != blank -%}{{ left.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400,700,1000', sizes: '40vw', alt: left.settings.title }}{%- endif -%}
        <div class="shm__scrim"></div>
      </div>
      {%- if left.settings.link != blank -%}<a class="shm__link" href="{{ left.settings.link }}" aria-label="{{ left.settings.title | escape }}"></a>{%- endif -%}
      <div class="shm__cap" id="shmCapL-{{ section.id }}">
        {%- if left.settings.eyebrow != blank -%}<span class="shm__ey">{% if is_tr %}{% if left.settings.eyebrow contains 'eatured' %}Öne Çıkan{% else %}Koleksiyon{% endif %}{% else %}{{ left.settings.eyebrow }}{% endif %}</span>{%- endif -%}
        {%- if left.settings.title != blank -%}<h3 class="shm__name">{{ left.settings.title }}</h3>{%- endif -%}
        {%- if left.settings.cta_label != blank -%}<span class="shm__cta">{% if is_tr %}Keşfet{% else %}{{ left.settings.cta_label }}{% endif %}</span>{%- endif -%}
      </div>
    </article>

    {%- comment -%} Center video {%- endcomment -%}
    <article class="shm__card" id="shmC-{{ section.id }}" data-link="{{ center.settings.link }}" style="--glow: {{ center.settings.glow | default: 'rgba(28,150,131,.9)' }};">
      <div class="shm__clip">
        {%- if section.settings.video_asset != blank -%}
          <video id="shmVid-{{ section.id }}" autoplay muted playsinline preload="auto"{% if center.settings.image != blank %} poster="{{ center.settings.image | image_url: width: 1600 }}"{% endif %}>
            <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
          </video>
        {%- elsif center.settings.image != blank -%}
          {{ center.settings.image | image_url: width: 1600 | image_tag: loading: 'eager', widths: '600,1000,1400,1600', sizes: '60vw', alt: 'SEYM' }}
        {%- endif -%}
        <div class="shm__scrim" id="shmCScrim-{{ section.id }}" style="opacity:.2"></div>
      </div>
      {%- if center.settings.link != blank -%}<a class="shm__link" href="{{ center.settings.link }}" aria-label="{{ center.settings.title | default: 'SEYM' | escape }}"></a>{%- endif -%}

      <div class="shm__hero" id="shmHero-{{ section.id }}">
        {%- if section.settings.hero_eyebrow != blank -%}<p class="shm__hero-ey">{{ section.settings.hero_eyebrow }}</p>{%- endif -%}
        <img class="shm__hero-logo" src="{{ 'seym-logo.png' | asset_url }}" alt="{{ section.settings.hero_heading | default: 'SEYM' }}">
        <span class="shm__hero-rule" aria-hidden="true"></span>
        {%- if section.settings.hero_cta != blank and section.settings.hero_link != blank -%}<a class="shm__hero-cta" href="{{ section.settings.hero_link }}">{% if is_tr %}Koleksiyonu keşfet{% else %}{{ section.settings.hero_cta }}{% endif %}</a>{%- endif -%}
      </div>
      {%- if section.settings.scroll_cue != blank -%}<div class="shm__cue" id="shmCue-{{ section.id }}">{{ section.settings.scroll_cue }}</div>{%- endif -%}

      <div class="shm__cap shm__cap--c" id="shmCapC-{{ section.id }}">
        {%- if center.settings.eyebrow != blank -%}<span class="shm__ey">{% if is_tr %}{% if center.settings.eyebrow contains 'eatured' %}Öne Çıkan{% else %}Koleksiyon{% endif %}{% else %}{{ center.settings.eyebrow }}{% endif %}</span>{%- endif -%}
        <img class="shm__cap-logo" src="{{ 'seym-logo.png' | asset_url }}" alt="{{ center.settings.title | default: 'SEYM' | escape }}" loading="lazy">
      </div>
    </article>

    {%- comment -%} Right banner {%- endcomment -%}
    <article class="shm__card" id="shmR-{{ section.id }}" data-link="{{ right.settings.link }}" style="--glow: {{ right.settings.glow | default: 'rgba(150,38,72,.9)' }};">
      <div class="shm__clip">
        {%- if right.settings.image != blank -%}{{ right.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400,700,1000', sizes: '40vw', alt: right.settings.title }}{%- endif -%}
        <div class="shm__scrim"></div>
      </div>
      {%- if right.settings.link != blank -%}<a class="shm__link" href="{{ right.settings.link }}" aria-label="{{ right.settings.title | escape }}"></a>{%- endif -%}
      <div class="shm__cap" id="shmCapR-{{ section.id }}">
        {%- if right.settings.eyebrow != blank -%}<span class="shm__ey">{% if is_tr %}{% if right.settings.eyebrow contains 'eatured' %}Öne Çıkan{% else %}Koleksiyon{% endif %}{% else %}{{ right.settings.eyebrow }}{% endif %}</span>{%- endif -%}
        {%- if right.settings.title != blank -%}<h3 class="shm__name">{{ right.settings.title }}</h3>{%- endif -%}
        {%- if right.settings.cta_label != blank -%}<span class="shm__cta">{% if is_tr %}Keşfet{% else %}{{ right.settings.cta_label }}{% endif %}</span>{%- endif -%}
      </div>
    </article>

  </div>
</section>

<script>
(function(){
  if (window.matchMedia('(max-width:749px)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var sid='{{ section.id }}';
  var shm=document.getElementById('SeymHM-'+sid), stage=document.getElementById('shmStage-'+sid);
  var cL=document.getElementById('shmL-'+sid), cC=document.getElementById('shmC-'+sid), cR=document.getElementById('shmR-'+sid);
  var hero=document.getElementById('shmHero-'+sid), cue=document.getElementById('shmCue-'+sid), cScrim=document.getElementById('shmCScrim-'+sid), topScrim=document.getElementById('shmTop-'+sid);
  var capL=document.getElementById('shmCapL-'+sid), capC=document.getElementById('shmCapC-'+sid), capR=document.getElementById('shmCapR-'+sid);
  if(!shm||!cC) return;
  var headerH=150;
  function measureHeader(){var hw=document.querySelector('.seym-header-wrap')||document.querySelector('.seym-hd'); if(hw){var h=hw.getBoundingClientRect().height; if(h>0) headerH=Math.round(h);}}
  function lerp(a,b,t){return a+(b-a)*t}
  function clamp(v){return v<0?0:v>1?1:v}
  function seg(p,a,b){return clamp((p-a)/(b-a))}
  function ease(t){t=clamp(t);return 1-Math.pow(1-t,3)}
  function clipR(el,r){var c=el.querySelector('.shm__clip'); el.style.borderRadius=r+'px'; if(c)c.style.borderRadius=r+'px';}

  function render(p){
    var vw=window.innerWidth, vh=window.innerHeight, e=ease(p);
    var marg=lerp(0,6,e), gap=lerp(0,8,e), rad=lerp(0,22,e);
    /* leave breathing room above (clear of the fixed header) + below */
    var padTop=lerp(0,headerH+22,e), padBot=lerp(0,30,e);
    var availH=vh-padTop-padBot;
    var finalW=Math.min((vw-2*marg-2*gap)/3, (availH*0.98)*0.8);
    var sideGrow=ease(seg(p,0.12,0.92));
    var sideW=finalW*sideGrow;
    var centerW=vw-2*marg-2*gap-2*sideW;
    var cardH=lerp(vh, finalW*1.25, e);
    stage.style.gap=gap+'px'; stage.style.paddingLeft=marg+'px'; stage.style.paddingRight=marg+'px';
    stage.style.paddingTop=padTop+'px'; stage.style.paddingBottom=padBot+'px';
    cC.style.width=centerW+'px'; cC.style.height=cardH+'px';
    cL.style.width=sideW+'px'; cR.style.width=sideW+'px'; cL.style.height=cardH+'px'; cR.style.height=cardH+'px';
    cL.style.opacity=sideGrow; cR.style.opacity=sideGrow;
    clipR(cC,rad); clipR(cL,rad); clipR(cR,rad);
    var sh=e*e, shadow='0 '+(36*sh).toFixed(1)+'px '+(82*sh).toFixed(1)+'px -'+(48*sh).toFixed(0)+'px rgba(40,28,24,'+(0.32*sh).toFixed(3)+')';
    cC.style.boxShadow=shadow; cL.style.boxShadow=shadow; cR.style.boxShadow=shadow;
    var rec=Math.sin(clamp(p/0.7)*Math.PI)*0.015; cC.style.transform='scale('+(1-rec)+')';
    var hf=ease(seg(p,0,0.26)); if(hero){hero.style.opacity=1-hf; hero.style.transform='translateY('+(-30*hf)+'px)';}
    if(cue) cue.style.opacity=1-ease(seg(p,0,0.12));
    if(topScrim) topScrim.style.opacity=1-ease(seg(p,0,0.32));
    if(cScrim) cScrim.style.opacity=lerp(.2,.58,e);
    if(capC) capC.style.opacity=ease(seg(p,0.68,0.95));
    var co=ease(seg(p,0.74,1)); if(capL)capL.style.opacity=co; if(capR)capR.style.opacity=co;
  }
  var target=0,cur=0,run=false;
  function readT(){var s=shm.offsetHeight-window.innerHeight; target=s<=0?0:clamp(-shm.getBoundingClientRect().top/s);}
  function tick(){var d=target-cur; if(Math.abs(d)<0.0005){cur=target;render(cur);run=false;return;} cur+=d*0.09; render(cur); requestAnimationFrame(tick);}
  function kick(){readT(); if(!run){run=true; requestAnimationFrame(tick);}}
  window.addEventListener('scroll',function(){requestAnimationFrame(kick)},{passive:true});
  window.addEventListener('resize',function(){measureHeader();readT();render(cur)},{passive:true});
  window.addEventListener('load',function(){measureHeader();readT();render(cur)});
  measureHeader(); readT(); cur=target; render(cur);
})();
</script>

<script>
(function(){
  /* Make each hero banner clickable as a WHOLE (robust against any overlay /
     stacking quirk). Real links inside (e.g. the masthead CTA) still work. */
  var sid='{{ section.id }}';
  ['shmL-'+sid,'shmC-'+sid,'shmR-'+sid].forEach(function(id){
    var card=document.getElementById(id); if(!card) return;
    var lnk=card.getAttribute('data-link'); if(!lnk) return;
    card.style.cursor='pointer';
    card.addEventListener('click', function(e){
      if(e.target.closest('a')) return;
      window.location.href = lnk;
    });
  });
})();
</script>

<script>
(function(){
  /* Hero video: forward, then REWIND back to the start, then forward — no hard
     loop cut. Reverse is SEEK-PACED (each frame waits for the previous seek to
     land) and only runs once the clip is buffered, so it stays smooth instead of
     stalling. If not yet buffered, it cleanly restarts that cycle. */
  var v = document.getElementById('shmVid-{{ section.id }}');
  if(!v) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches){ v.loop = true; return; }
  v.loop = false;
  var REV_SPEED = 0.8;     /* rewind speed vs forward (1 = same, lower = slower) */
  var dir = 1, t0 = 0, from = 0, seeking = false;
  function isBuffered(){
    try { return v.buffered.length > 0 && v.buffered.end(v.buffered.length - 1) >= (v.duration - 0.3); }
    catch(e){ return false; }
  }
  function playForward(){ dir = 1; var p = v.play(); if(p && p.catch){ p.catch(function(){}); } }
  v.addEventListener('seeking', function(){ seeking = true; });
  v.addEventListener('seeked', function(){ seeking = false; });
  function revLoop(ts){
    if(dir !== -1) return;
    if(!t0){ t0 = ts; from = v.currentTime; }
    var target = from - ((ts - t0) / 1000) * REV_SPEED;   /* time-paced, can't run away */
    if(target <= 0.04){ v.currentTime = 0; playForward(); return; }
    if(!seeking){ v.currentTime = target; }               /* skip while a seek is pending */
    requestAnimationFrame(revLoop);
  }
  function atEnd(){
    if(dir !== 1) return;
    if(isBuffered()){ dir = -1; t0 = 0; try { v.pause(); } catch(e){} requestAnimationFrame(revLoop); }
    else { v.currentTime = 0; playForward(); }
  }
  v.addEventListener('ended', atEnd);
  v.addEventListener('timeupdate', function(){
    if(dir === 1 && v.duration && v.currentTime >= v.duration - 0.18){ atEnd(); }
  });
  playForward();
})();
</script>

{% schema %}
{
  "name": "Hero",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "video_asset", "label": "Video filename (center)", "default": "product-showcase.mp4" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "Art de la Table" },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "default": "SEYM" },
    { "type": "text", "id": "hero_cta", "label": "Hero CTA", "default": "Discover the collection" },
    { "type": "url", "id": "hero_link", "label": "Hero CTA link" },
    { "type": "text", "id": "scroll_cue", "label": "Scroll cue", "default": "Scroll" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (poster for center)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "cta_label", "label": "Button text", "default": "Discover", "info": "The small label shown on the banner (e.g. Discover)." },
        { "type": "url", "id": "link", "label": "Banner link (URL)", "info": "Where this banner goes when clicked — the whole banner is the link. Pick a collection or page." },
        { "type": "text", "id": "glow", "label": "Hover glow colour (rgba/hex)", "info": "e.g. rgba(150,38,72,.9)" }
      ]
    }
  ],
  "presets": [{
    "name": "Hero",
    "blocks": [
      { "type": "card", "settings": { "eyebrow": "Collection", "title": "Flos", "glow": "rgba(72,98,182,.85)" } },
      { "type": "card", "settings": { "eyebrow": "Art de la Table", "title": "SEYM", "glow": "rgba(28,150,131,.9)" } },
      { "type": "card", "settings": { "eyebrow": "Featured", "title": "Maris Vase", "glow": "rgba(150,38,72,.9)" } }
    ]
  }]
}
{% endschema %}
