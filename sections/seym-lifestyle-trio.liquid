{%- comment -%}
  Seym Lifestyle Trio
  Three large lifestyle/category cards in a row. Tall portrait images
  with overlay text. Wine accent on hover. Drives to category/collection.
{%- endcomment -%}

<style>
  .seym-trio {
    background: var(--seym-ivory, #F5F1EA);
    color: var(--seym-ink, #1A1A1A);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
  }

  .seym-trio__intro {
    text-align: center;
    max-width: 78rem;
    margin: 0 auto 5.5rem;
    padding: 0 2.4rem;
  }

  .seym-trio__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.6rem;
    position: relative;
    padding: 0 2.4rem;
  }
  .seym-trio__eyebrow::before,
  .seym-trio__eyebrow::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 1.6rem;
    height: 1px;
    background: var(--seym-wine, #8E2244);
  }
  .seym-trio__eyebrow::before { left: 0; }
  .seym-trio__eyebrow::after { right: 0; }

  .seym-trio__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3rem, 3.8vw, 4.8rem);
    line-height: 1.06;
    letter-spacing: -0.012em;
    margin: 0 0 1.4rem;
    color: #1A1A1A;
  }
  .seym-trio__heading em {
    font-style: italic;
    color: var(--seym-wine, #8E2244);
  }

  .seym-trio__sub {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(26,26,26,0.65);
    margin: 0;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }

  .seym-trio__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
    max-width: 168rem;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .seym-trio__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: rgba(26,26,26,0.05);
    isolation: isolate;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 800ms cubic-bezier(0.22,1,0.36,1),
                transform 800ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-trio__card.visible { opacity: 1; transform: none; }
  .seym-trio__card:nth-child(2) { transition-delay: 120ms; }
  .seym-trio__card:nth-child(3) { transition-delay: 240ms; }

  .seym-trio__card img,
  .seym-trio__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1600ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-trio__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(160deg,
        rgba(142,34,68,0.16) 0%,
        rgba(197,71,48,0.12) 60%,
        rgba(26,26,26,0.06) 100%);
    color: rgba(245,241,234,0.85);
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 5.6rem;
    font-weight: 300;
  }

  .seym-trio__card:hover img,
  .seym-trio__card:hover .seym-trio__placeholder {
    transform: scale(1.05);
  }

  /* Wine veil that comes up on hover */
  .seym-trio__card::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(26,26,26,0) 0%,
        rgba(26,26,26,0.15) 45%,
        rgba(142, 34, 68, 0.78) 100%);
    z-index: 1;
    transition: background 500ms ease;
    pointer-events: none;
  }
  .seym-trio__card:hover::after {
    background:
      linear-gradient(180deg,
        rgba(142, 34, 68, 0.18) 0%,
        rgba(142, 34, 68, 0.45) 50%,
        rgba(110, 26, 53, 0.92) 100%);
  }

  .seym-trio__content {
    position: absolute;
    z-index: 2;
    inset: auto 3rem 3rem 3rem;
    color: #F5F1EA;
    pointer-events: none;
  }

  .seym-trio__tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.78);
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(245,241,234,0.4);
  }

  .seym-trio__label {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(2.4rem, 2.6vw, 3.4rem);
    line-height: 1.06;
    letter-spacing: -0.005em;
    color: #F5F1EA;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0,0,0,0.35);
  }

  .seym-trio__sub-label {
    margin-top: 0.6rem;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.5;
    color: rgba(245,241,234,0.78);
    max-width: 30ch;
  }

  .seym-trio__discover {
    margin-top: 1.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #F5F1EA;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(245,241,234,0.55);
    transition: padding-right 280ms ease, border-color 220ms ease;
  }
  .seym-trio__discover::after {
    content: '→';
    transition: transform 280ms ease;
    display: inline-block;
  }
  .seym-trio__card:hover .seym-trio__discover {
    padding-right: 0.6rem;
    border-color: #F5F1EA;
  }
  .seym-trio__card:hover .seym-trio__discover::after {
    transform: translateX(4px);
  }

  /* ---- Tablet / mobile ---- */
  @media (max-width: 989px) {
    .seym-trio { padding: {{ section.settings.padding_top | divided_by: 1.3 | floor }}px 0 {{ section.settings.padding_bottom | divided_by: 1.3 | floor }}px; }
    .seym-trio__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 2.4rem;
    }
    .seym-trio__card { aspect-ratio: 4 / 3; }
    .seym-trio__intro { margin-bottom: 4rem; }
  }

  @media (max-width: 540px) {
    .seym-trio__card { aspect-ratio: 1 / 1; }
    .seym-trio__content { inset: auto 2rem 2rem 2rem; }
    .seym-trio__label { font-size: 2.2rem; }
  }
</style>

<section class="seym-trio" id="SeymTrio-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subtitle != blank -%}
    <div class="seym-trio__intro">
      {%- if section.settings.eyebrow != blank -%}
        <span class="seym-trio__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="seym-trio__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="seym-trio__sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="seym-trio__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'card' -%}
        {%- assign cat = block.settings.collection -%}
        {%- assign tile_label = block.settings.label | default: cat.title -%}
        {%- assign tile_url = block.settings.link | default: cat.url -%}
        {%- if tile_url == blank -%}{%- assign tile_url = '#' -%}{%- endif -%}

        <a class="seym-trio__card" href="{{ tile_url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image
               | image_url: width: 1200
               | image_tag:
                 loading: 'lazy',
                 widths: '400, 600, 900, 1200, 1600',
                 sizes: '(max-width: 989px) 92vw, 32vw',
                 alt: block.settings.image.alt | default: tile_label }}
          {%- elsif cat.image != blank -%}
            {{ cat.image
               | image_url: width: 1200
               | image_tag:
                 loading: 'lazy',
                 widths: '400, 600, 900, 1200, 1600',
                 sizes: '(max-width: 989px) 92vw, 32vw',
                 alt: tile_label }}
          {%- else -%}
            <div class="seym-trio__placeholder">{{ tile_label | slice: 0 }}</div>
          {%- endif -%}

          <div class="seym-trio__content">
            {%- if block.settings.tag != blank -%}
              <span class="seym-trio__tag">{{ block.settings.tag }}</span>
            {%- endif -%}
            <h3 class="seym-trio__label">{{ tile_label }}</h3>
            {%- if block.settings.sub_label != blank -%}
              <p class="seym-trio__sub-label">{{ block.settings.sub_label }}</p>
            {%- endif -%}
            <span class="seym-trio__discover">{{ block.settings.cta_label | default: 'Discover' }}</span>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
(function () {
  var cards = document.querySelectorAll('#SeymTrio-{{ section.id }} .seym-trio__card');
  if (!cards.length || !('IntersectionObserver' in window)) {
    cards.forEach(function (c) { c.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.15 });
  cards.forEach(function (c) { obs.observe(c); });
})();
</script>

{% schema %}
{
  "name": "Lifestyle Trio",
  "tag": "section",
  "class": "shopify-section seym-trio-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In Your Space"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (em allowed)",
      "default": "Lived with, <em>not displayed</em>."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Seym pieces are made for daily companionship. A bowl on the breakfast table. A vase by the window. A vessel beside your reading chair."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 140
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Lifestyle card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (optional — links to it if no URL override)"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Top tag (small all-caps)",
          "default": "On The Table"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Card title",
          "default": "Vessels & vases"
        },
        {
          "type": "text",
          "id": "sub_label",
          "label": "Sub-label",
          "default": "Hand-blown forms for everyday companionship."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Discover"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override (optional)"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Lifestyle Trio",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "tag": "On The Table",
            "label": "Vessels & vases",
            "sub_label": "Hand-blown forms for everyday companionship.",
            "cta_label": "Discover"
          }
        },
        {
          "type": "card",
          "settings": {
            "tag": "By The Window",
            "label": "Light catchers",
            "sub_label": "Pieces that read the sun. Different at every hour.",
            "cta_label": "Discover"
          }
        },
        {
          "type": "card",
          "settings": {
            "tag": "Beside The Chair",
            "label": "Sculptural objects",
            "sub_label": "Quiet companions to contemporary living spaces.",
            "cta_label": "Discover"
          }
        }
      ]
    }
  ]
}
{% endschema %}
