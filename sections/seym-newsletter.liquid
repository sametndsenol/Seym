{%- comment -%}
  Seym Newsletter — "Join the Atelier" email signup.
  Premium minimal moment on dark ground with an inline hairline field.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} {
    --nl-ivory: #F5F1EA;
    --nl-dark: #0A0A0A;
    --nl-wine: #8E2244;
    --nl-gold: #C9A96E;
    --nl-ease: cubic-bezier(0.22,1,0.36,1);
  }

  .seym-nl {
    background: var(--nl-dark);
    color: var(--nl-ivory);
    padding: clamp(7rem, 11vh, 11rem) 0;
  }
  .seym-nl__wrap {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 4.8rem;
    text-align: center;
  }
  .seym-nl__eyebrow {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.5);
    margin: 0 0 1.8rem;
  }
  .seym-nl__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 5vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
    color: var(--nl-ivory);
    margin: 0 0 1.4rem;
  }
  .seym-nl__heading em { font-style: italic; }
  .seym-nl__sub {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(245,241,234,0.55);
    max-width: 46ch;
    margin: 0 auto clamp(3rem, 5vh, 4rem);
  }

  /* Form — inline hairline-underline field */
  .seym-nl__form { width: 100%; }
  .seym-nl__field {
    display: flex;
    align-items: stretch;
    gap: 1.6rem;
    max-width: 48rem;
    margin: 0 auto;
    border-bottom: 1px solid rgba(245,241,234,0.22);
    transition: border-color 0.5s var(--nl-ease);
  }
  .seym-nl__field:focus-within { border-color: rgba(245,241,234,0.6); }
  .seym-nl__input {
    flex: 1;
    min-width: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 16px;
    letter-spacing: 0.02em;
    padding: 1rem 0;
    min-height: 44px;
    border: none;
    background: transparent;
    color: var(--nl-ivory);
    outline: none;
  }
  .seym-nl__input::placeholder { color: rgba(245,241,234,0.4); }
  .seym-nl__btn {
    flex-shrink: 0;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 1rem 0;
    min-height: 44px;
    background: transparent;
    color: var(--nl-ivory);
    border: none;
    cursor: pointer;
  }
  .seym-nl__btn-text { position: relative; }
  .seym-nl__btn-text::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.35rem;
    width: 100%;
    height: 1px;
    background: var(--nl-ivory);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--nl-ease), background 0.5s var(--nl-ease);
  }
  .seym-nl__btn:hover .seym-nl__btn-text::after,
  .seym-nl__btn:focus-visible .seym-nl__btn-text::after {
    transform: scaleX(1);
    background: var(--nl-gold);
  }
  .seym-nl__btn:hover .seym-nl__btn-text,
  .seym-nl__btn:focus-visible .seym-nl__btn-text {
    color: var(--nl-gold);
  }

  /* Form feedback */
  .seym-nl__msg {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    line-height: 1.6;
    margin: 1.6rem auto 0;
    max-width: 48rem;
  }
  .seym-nl__msg--success { color: var(--nl-gold); }
  .seym-nl__msg--error { color: #E0879C; }

  @media (max-width: 749px) {
    .seym-nl { padding: clamp(4.5rem, 9vh, 6rem) 0; }
    .seym-nl__wrap { padding: 0 2rem; }
    .seym-nl__field {
      flex-direction: column;
      gap: 0;
      border-bottom: none;
    }
    .seym-nl__input {
      width: 100%;
      border-bottom: 1px solid rgba(245,241,234,0.22);
      transition: border-color 0.5s var(--nl-ease);
    }
    .seym-nl__input:focus { border-color: rgba(245,241,234,0.6); }
    .seym-nl__btn {
      width: 100%;
      text-align: center;
      margin-top: 1.6rem;
      padding: 1.1rem 0;
      border: 1px solid rgba(245,241,234,0.4);
      transition: border-color 0.5s var(--nl-ease), color 0.5s var(--nl-ease);
    }
    .seym-nl__btn:hover { border-color: var(--nl-gold); color: var(--nl-gold); }
    .seym-nl__btn-text::after { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .seym-nl__field,
    .seym-nl__input,
    .seym-nl__btn-text,
    .seym-nl__btn-text::after { transition: none; }
  }
</style>

<section class="seym-nl" data-reveal>
  <div class="seym-nl__wrap">
    {%- if section.settings.eyebrow != blank -%}
      <p class="seym-nl__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="seym-nl__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="seym-nl__sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- form 'customer', id: 'SeymNewsletter', class: 'seym-nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="seym-nl__field">
        <input class="seym-nl__input" type="email" name="contact[email]"
          aria-label="{{ section.settings.placeholder | default: 'Your email address' }}"
          placeholder="{{ section.settings.placeholder | default: 'Your email address' }}" required>
        <button class="seym-nl__btn" type="submit">
          <span class="seym-nl__btn-text">{{ section.settings.btn_label | default: 'Subscribe' }}</span>
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="seym-nl__msg seym-nl__msg--success">{{ section.settings.success_text | default: 'Thank you — welcome to the atelier.' }}</p>
      {%- elsif form.errors -%}
        <p class="seym-nl__msg seym-nl__msg--error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsletter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Atelier" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Be the first to discover new collections, studio stories, and limited editions." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thank you — welcome to the atelier." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
