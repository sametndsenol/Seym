{%- comment -%}
  Seym Page section — thin wrapper over the seym-page-body snippet.
  Used when the page has been explicitly assigned this template in
  admin. For the default page.json route, the router section
  picks the snippet directly based on page.handle.
{%- endcomment -%}

{%- render 'seym-page-body',
    eyebrow: section.settings.eyebrow,
    title_html: section.settings.title_override,
    lead: section.settings.lead,
    back_label: section.settings.back_label,
    back_link: section.settings.back_link,
    cta_label: section.settings.cta_label,
    cta_link: section.settings.cta_link,
    padding_top: section.settings.padding_top,
    padding_bottom: section.settings.padding_bottom -%}

{% schema %}
{
  "name": "Seym Page",
  "tag": "section",
  "class": "shopify-section seym-pg-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (wine accent)" },
    { "type": "text", "id": "title_override", "label": "Title override (em allowed). Leave blank to use page title." },
    { "type": "textarea", "id": "lead", "label": "Lead paragraph (italic, under title)" },
    { "type": "header", "content": "Footer links" },
    { "type": "text", "id": "back_label", "label": "Left link label", "default": "About Seym" },
    { "type": "url", "id": "back_link", "label": "Left link URL" },
    { "type": "text", "id": "cta_label", "label": "Right link label" },
    { "type": "url", "id": "cta_link", "label": "Right link URL" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top",    "label": "Padding top",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [ { "name": "Seym Page" } ]
}
{% endschema %}
