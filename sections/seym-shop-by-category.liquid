{%- comment -%}
  Seym Shop By Category
  Amara-style editorial category grid. Large imagery, minimal label below,
  generous whitespace. Mobile: 2 columns. Desktop: 4 (or configurable).
{%- endcomment -%}

<style>
  .seym-shop-cats {
    background: var(--seym-ivory, #F5F1EA);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .seym-shop-cats__intro {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 6.5rem;
    padding: 0 2.4rem;
  }

  .seym-shop-cats__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.6);
    margin-bottom: 2rem;
  }

  .seym-shop-cats__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 3.6vw, 4.4rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: #1A1A1A;
    margin: 0;
  }

  .seym-shop-cats__sub {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.45rem;
    line-height: 1.7;
    color: rgba(26,26,26,0.62);
    max-width: 56ch;
    margin: 1.8rem auto 0;
  }

  .seym-shop-cats__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 4.5rem 3.2rem;
    max-width: 154rem;
    margin: 0 auto;
    padding: 0 4rem;
  }

  .seym-shop-cats__tile {
    display: block;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 800ms cubic-bezier(0.22,1,0.36,1),
                transform 800ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-shop-cats__tile.visible { opacity: 1; transform: none; }
  .seym-shop-cats__tile:nth-child(2) { transition-delay: 90ms; }
  .seym-shop-cats__tile:nth-child(3) { transition-delay: 180ms; }
  .seym-shop-cats__tile:nth-child(4) { transition-delay: 270ms; }
  .seym-shop-cats__tile:nth-child(5) { transition-delay: 360ms; }
  .seym-shop-cats__tile:nth-child(6) { transition-delay: 450ms; }

  .seym-shop-cats__media {
    position: relative;
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    overflow: hidden;
    background: rgba(26,26,26,0.04);
  }

  .seym-shop-cats__media img,
  .seym-shop-cats__media svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1200ms cubic-bezier(0.22,1,0.36,1),
                opacity 600ms ease;
  }

  .seym-shop-cats__tile:hover .seym-shop-cats__media img {
    transform: scale(1.04);
  }

  .seym-shop-cats__placeholder {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg,
        rgba(142,34,68,0.08) 0%,
        rgba(197,71,48,0.06) 50%,
        rgba(26,26,26,0.04) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(26,26,26,0.25);
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.6rem;
    font-style: italic;
  }

  .seym-shop-cats__label {
    margin-top: 1.8rem;
    text-align: center;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.85rem;
    letter-spacing: 0.005em;
    color: #1A1A1A;
    transition: color 220ms ease;
  }

  .seym-shop-cats__tile:hover .seym-shop-cats__label {
    color: var(--seym-terracotta, #C54730);
  }

  .seym-shop-cats__caption {
    display: block;
    margin-top: 0.4rem;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.5);
  }

  .seym-shop-cats__footer {
    margin-top: 6rem;
    text-align: center;
  }

  .seym-shop-cats__view-all {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    padding: 1.2rem 0 0.6rem;
    border-bottom: 1px solid #1A1A1A;
    transition: color 220ms ease, border-color 220ms ease;
  }
  .seym-shop-cats__view-all:hover {
    color: var(--seym-wine, #8E2244);
    border-color: var(--seym-wine, #8E2244);
  }

  @media (max-width: 989px) {
    .seym-shop-cats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3.6rem 2rem;
      padding: 0 2.4rem;
    }
    .seym-shop-cats__intro { margin-bottom: 5rem; }
  }

  @media (max-width: 540px) {
    .seym-shop-cats {
      padding: {{ section.settings.padding_top | divided_by: 1.4 | floor }}px 0
              {{ section.settings.padding_bottom | divided_by: 1.4 | floor }}px;
    }
    .seym-shop-cats__label { font-size: 1.5rem; }
  }
</style>

<section class="seym-shop-cats" id="SeymShopCats-{{ section.id }}">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subtitle != blank -%}
    <div class="seym-shop-cats__intro">
      {%- if section.settings.eyebrow != blank -%}
        <span class="seym-shop-cats__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="seym-shop-cats__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="seym-shop-cats__sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="seym-shop-cats__grid">
    {%- for block in section.blocks -%}
      {%- assign cat = block.settings.collection -%}
      {%- assign tile_label = block.settings.label | default: cat.title -%}
      {%- assign tile_url = block.settings.link | default: cat.url -%}
      {%- if tile_url == blank -%}{%- assign tile_url = '#' -%}{%- endif -%}

      <a class="seym-shop-cats__tile" href="{{ tile_url }}" {{ block.shopify_attributes }}>
        <div class="seym-shop-cats__media">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image
               | image_url: width: 900
               | image_tag:
                 loading: 'lazy',
                 widths: '300, 450, 600, 800, 1100',
                 sizes: '(max-width: 540px) 88vw, (max-width: 989px) 44vw, 22vw',
                 alt: block.settings.image.alt | default: tile_label }}
          {%- elsif cat.image != blank -%}
            {{ cat.image
               | image_url: width: 900
               | image_tag:
                 loading: 'lazy',
                 widths: '300, 450, 600, 800, 1100',
                 sizes: '(max-width: 540px) 88vw, (max-width: 989px) 44vw, 22vw',
                 alt: cat.image.alt | default: tile_label }}
          {%- elsif cat.products.first.featured_image != blank -%}
            {{ cat.products.first.featured_image
               | image_url: width: 900
               | image_tag:
                 loading: 'lazy',
                 widths: '300, 450, 600, 800, 1100',
                 sizes: '(max-width: 540px) 88vw, (max-width: 989px) 44vw, 22vw',
                 alt: tile_label }}
          {%- else -%}
            <div class="seym-shop-cats__placeholder">{{ tile_label | slice: 0 }}</div>
          {%- endif -%}
        </div>
        <div class="seym-shop-cats__label">{{ tile_label }}</div>
        {%- if block.settings.caption != blank -%}
          <span class="seym-shop-cats__caption">{{ block.settings.caption }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>

  {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
    <div class="seym-shop-cats__footer">
      <a class="seym-shop-cats__view-all" href="{{ section.settings.view_all_link }}">
        {{ section.settings.view_all_label }}
      </a>
    </div>
  {%- endif -%}
</section>

<script>
(function () {
  var tiles = document.querySelectorAll('#SeymShopCats-{{ section.id }} .seym-shop-cats__tile');
  if (!tiles.length || !('IntersectionObserver' in window)) {
    tiles.forEach(function (t) { t.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.15 });
  tiles.forEach(function (t) { obs.observe(t); });
})();
</script>

{% schema %}
{
  "name": "Shop By Category",
  "tag": "section",
  "class": "shopify-section seym-shop-cats-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Twelve characters, born of earth and sky. Each series closes permanently."
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 5", "label": "Tall portrait (4:5)" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "5 / 4", "label": "Landscape (5:4)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View-all link label",
      "default": "View all collections"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View-all link URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 140
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label override (optional)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (small, all-caps)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override (optional)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Shop By Category",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
