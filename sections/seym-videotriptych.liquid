{%- comment -%}
  Seym Video Triptych — three tall cards, center is autoplay video.
  Cards start flush (gap 0) and separate on scroll.
{%- endcomment -%}

<style>
  .seym-vt { background: #fff; padding: 0; overflow: hidden; }
  .seym-vt__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    gap: 0;
    transition: gap 0.8s cubic-bezier(0.22,1,0.36,1);
    min-height: 92vh;
  }
  .seym-vt__grid.seym-vt--spread { gap: 0.5rem; padding: 0.5rem; }
  .seym-vt__card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: #F5F1EA;
    min-height: 0;
  }
  .seym-vt__card img,
  .seym-vt__card video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s cubic-bezier(0.22,1,0.36,1);
  }
  .seym-vt__card:hover img,
  .seym-vt__card:hover video { transform: scale(1.04); }

  .seym-vt__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .seym-vt__card--side .seym-vt__overlay {
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.48) 100%);
  }
  .seym-vt__card--center .seym-vt__overlay {
    background: linear-gradient(to bottom, rgba(0,0,0,0.18) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.55) 100%);
  }

  .seym-vt__content {
    position: absolute;
    z-index: 2;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3.2rem;
  }
  .seym-vt__card--center .seym-vt__content {
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 3rem;
  }
  .seym-vt__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.6);
    margin-bottom: 0.8rem;
  }
  .seym-vt__card--center .seym-vt__eyebrow {
    font-size: 0.72rem;
    margin-bottom: 1.4rem;
    color: rgba(245,241,234,0.7);
  }
  .seym-vt__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.6rem, 2vw, 2.2rem);
    line-height: 1.1;
    margin: 0;
    color: #F5F1EA;
    text-shadow: 0 1px 16px rgba(0,0,0,0.3);
  }
  .seym-vt__card--center .seym-vt__title {
    font-size: clamp(4rem, 7vw, 8rem);
    letter-spacing: -0.025em;
    line-height: 0.95;
    margin-bottom: 2.8rem;
  }
  .seym-vt__cta {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #F5F1EA;
    border: 1px solid rgba(245,241,234,0.4);
    padding: 1rem 2.8rem;
    transition: background 260ms ease, border-color 260ms ease;
    min-height: 44px;
  }
  .seym-vt__card--center:hover .seym-vt__cta {
    background: rgba(245,241,234,0.12);
    border-color: #F5F1EA;
  }
  .seym-vt__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.5);
    margin-top: 0.5rem;
  }

  @media (max-width: 749px) {
    .seym-vt__grid {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .seym-vt__card--center { order: -1; min-height: 80vh; }
    .seym-vt__card--side { min-height: 50vh; }
    .seym-vt__card--center .seym-vt__title { font-size: clamp(3rem, 12vw, 5rem); }
    .seym-vt__content { padding: 2.4rem; }
    .seym-vt__grid.seym-vt--spread { gap: 0.3rem; padding: 0.3rem; }
  }
</style>

<section class="seym-vt" id="SeymVT-{{ section.id }}">
  <div class="seym-vt__grid" id="SeymVTGrid-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- assign is_center = false -%}
      {%- if forloop.index == 2 -%}{%- assign is_center = true -%}{%- endif -%}

      <a class="seym-vt__card seym-vt__card--{% if is_center %}center{% else %}side{% endif %}"
         href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>

        {%- if is_center and section.settings.video_asset != blank -%}
          <video autoplay muted loop playsinline preload="auto"
            {%- if block.settings.image != blank %} poster="{{ block.settings.image | image_url: width: 1200 }}"{% endif %}>
            <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
          </video>
        {%- elsif block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1200 | image_tag:
             loading: forloop.first | ternary: 'eager', 'lazy',
             widths: '400,600,800,1000,1200',
             sizes: '(max-width: 749px) 100vw, 36vw' }}
        {%- endif -%}

        <div class="seym-vt__overlay"></div>

        <div class="seym-vt__content">
          {%- if block.settings.eyebrow != blank -%}
            <span class="seym-vt__eyebrow">{{ block.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h2 class="seym-vt__title">{{ block.settings.title }}</h2>
          {%- endif -%}
          {%- if is_center and block.settings.cta_label != blank -%}
            <span class="seym-vt__cta">{{ block.settings.cta_label }}</span>
          {%- endif -%}
          {%- unless is_center -%}
            {%- if block.settings.subtitle != blank -%}
              <span class="seym-vt__subtitle">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          {%- endunless -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<script>
  (function(){
    var grid = document.getElementById('SeymVTGrid-{{ section.id }}');
    if (!grid) return;
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.intersectionRatio < 0.85) grid.classList.add('seym-vt--spread');
      });
    }, { threshold: [0.85, 1] });
    io.observe(grid);
  })();
</script>

{% schema %}
{
  "name": "Video Triptych",
  "tag": "div",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "video_asset", "label": "Video asset filename (center card)", "default": "product-showcase.mp4" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (or video poster for center)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle (side cards)" },
        { "type": "text", "id": "cta_label", "label": "CTA label (center card)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Video Triptych",
    "blocks": [
      { "type": "card", "settings": { "eyebrow": "Collection", "title": "Flos", "subtitle": "Çiçeklerin sessiz mevsimi" } },
      { "type": "card", "settings": { "eyebrow": "Seym Glass Studio · Istanbul", "title": "SEYM", "cta_label": "Discover the collection" } },
      { "type": "card", "settings": { "eyebrow": "Featured", "title": "Maris", "subtitle": "Denizin hafızası" } }
    ]
  }]
}
{% endschema %}
