{%- comment -%}
  Seym 3D Viewer — interactive model-viewer section.
  Dark void background, auto-rotate, camera controls, AR on mobile.
{%- endcomment -%}

<link rel="stylesheet" href="{{ 'seym-3d-viewer.css' | asset_url }}" media="print" onload="this.media='all'">

<section class="seym-3d" id="Seym3D-{{ section.id }}">

  <div class="seym-3d__intro">
    {%- if section.settings.eyebrow != blank -%}
      <span class="seym-3d__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="seym-3d__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="seym-3d__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="seym-3d__stage">
    <model-viewer
      id="SeymModelViewer-{{ section.id }}"
      src="{{ section.settings.model_file | default: 'kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb' | asset_url }}"
      alt="{{ section.settings.model_alt | default: 'Seym Glass Studio — interactive 3D model' }}"
      auto-rotate
      auto-rotate-delay="800"
      rotation-per-second="12deg"
      camera-controls
      camera-orbit="0deg 75deg 105%"
      min-camera-orbit="auto auto 80%"
      max-camera-orbit="auto auto 130%"
      environment-image="neutral"
      shadow-intensity="{{ section.settings.shadow_intensity | default: 1.2 }}"
      exposure="{{ section.settings.exposure | default: 1.0 }}"
      {% if section.settings.enable_ar %}ar ar-modes="webxr scene-viewer quick-look"{% endif %}
      loading="eager"
      reveal="auto"
    >

      {%- if section.settings.enable_ar -%}
        <button slot="ar-button" class="seym-3d__ar-btn" aria-label="See in your room">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span>{{ section.settings.ar_label | default: 'View in your space' }}</span>
        </button>
      {%- endif -%}

      <div class="seym-3d__progress" slot="progress-bar">
        <div class="seym-3d__bar"></div>
      </div>

    </model-viewer>

    <div class="seym-3d__hint" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        <circle cx="12" cy="12" r="3" stroke-width="1"/>
      </svg>
      <span>{{ section.settings.hint_text | default: 'Drag to rotate · Pinch to zoom' }}</span>
    </div>
  </div>

  {%- if section.settings.caption != blank -%}
    <div class="seym-3d__caption">
      <p>{{ section.settings.caption }}</p>
    </div>
  {%- endif -%}

  {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
    <div class="seym-3d__cta">
      <a href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    </div>
  {%- endif -%}

</section>

<script>
  (function () {
    var s = document.createElement('script');
    s.type = 'module';
    s.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js';
    document.head.appendChild(s);

    /* Animate progress bar */
    var viewer = document.getElementById('SeymModelViewer-{{ section.id }}');
    if (viewer) {
      viewer.addEventListener('progress', function (e) {
        var bar = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__bar');
        if (bar) bar.style.width = (e.detail.totalProgress * 100) + '%';
      });
      viewer.addEventListener('load', function () {
        var prog = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__progress');
        if (prog) { prog.style.opacity = '0'; }
        var hint = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__hint');
        if (hint) {
          hint.style.opacity = '1';
          setTimeout(function() { hint.style.opacity = '0'; }, 4000);
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "3D Object Viewer",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "model_file",
      "label": "GLB filename (in assets/)",
      "default": "kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb",
      "info": "Upload the .glb file to theme assets, then enter the filename here."
    },
    {
      "type": "text",
      "id": "model_alt",
      "label": "Model alt text (accessibility)",
      "default": "Seym Glass Studio — interactive 3D model"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Examine Up Close"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Turn it. Study it. Own it."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every facet. Every angle. Every decision."
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption below viewer"
    },
    {
      "type": "range",
      "id": "shadow_intensity",
      "label": "Shadow intensity",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "range",
      "id": "exposure",
      "label": "Exposure / brightness",
      "min": 5,
      "max": 20,
      "step": 1,
      "default": 10,
      "info": "Stored as tenths — 10 = 1.0 actual exposure"
    },
    {
      "type": "checkbox",
      "id": "enable_ar",
      "label": "Enable AR (View in your space)",
      "default": true
    },
    {
      "type": "text",
      "id": "ar_label",
      "label": "AR button label",
      "default": "View in your space"
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Interaction hint",
      "default": "Drag to rotate · Pinch to zoom"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA link text",
      "default": "Acquire this piece"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link URL"
    }
  ],
  "presets": [
    {
      "name": "3D Object Viewer",
      "settings": {
        "model_file": "KHcshJYfvUsxoFGRrpAKO_model.glb",
        "eyebrow": "Examine Up Close",
        "heading": "Turn it. Study it. Own it.",
        "subheading": "Every facet. Every angle. Every decision.",
        "enable_ar": true,
        "ar_label": "View in your space",
        "hint_text": "Drag to rotate · Pinch to zoom"
      }
    }
  ]
}
{% endschema %}
