{%- comment -%}
  Seym 3D Viewer — split layout.
  Left: feature image + category info + CTA.
  Right: interactive 3D model with AR.
{%- endcomment -%}

<link rel="stylesheet" href="{{ 'seym-3d-viewer.css' | asset_url }}" media="print" onload="this.media='all'">

<section class="seym-3d" id="Seym3D-{{ section.id }}">
  <div class="seym-3d__split">

    <!-- LEFT: category info -->
    <aside class="seym-3d__info">
      <div class="seym-3d__image{% if section.settings.feature_image == blank %} seym-3d__image--placeholder{% endif %}">
        {%- if section.settings.feature_image != blank -%}
          {{ section.settings.feature_image
             | image_url: width: 1200
             | image_tag:
               loading: 'lazy',
               widths: '400, 600, 900, 1200, 1500',
               sizes: '(max-width: 989px) 88vw, 40vw',
               alt: section.settings.feature_image.alt | default: section.settings.heading }}
        {%- else -%}
          <span class="seym-3d__image-label">{{ section.settings.meta_left | default: 'Seym' }}</span>
        {%- endif -%}
      </div>

      <div class="seym-3d__info-body">
        {%- if section.settings.eyebrow != blank -%}
          <span class="seym-3d__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="seym-3d__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="seym-3d__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="seym-3d__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        <div class="seym-3d__meta">
          {%- if section.settings.meta_left != blank -%}
            <div class="seym-3d__meta-block">
              <span class="seym-3d__meta-key">{{ section.settings.meta_left_label | default: 'Collection' }}</span>
              <span class="seym-3d__meta-val">{{ section.settings.meta_left }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.meta_right != blank -%}
            <div class="seym-3d__meta-block">
              <span class="seym-3d__meta-key">{{ section.settings.meta_right_label | default: 'Edition' }}</span>
              <span class="seym-3d__meta-val">{{ section.settings.meta_right }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <div class="seym-3d__cta">
            <a href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </aside>

    <!-- RIGHT: 3D stage -->
    <div class="seym-3d__stage">
      <model-viewer
        id="SeymModelViewer-{{ section.id }}"
        src="{{ section.settings.model_file | default: 'kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb' | asset_url }}"
        alt="{{ section.settings.model_alt | default: 'Seym Glass Studio — interactive 3D model' }}"
        auto-rotate
        auto-rotate-delay="1600"
        rotation-per-second="6deg"
        camera-controls
        interaction-prompt="none"
        camera-orbit="0deg 75deg 105%"
        min-camera-orbit="auto auto 80%"
        max-camera-orbit="auto auto 130%"
        environment-image="neutral"
        shadow-intensity="{{ section.settings.shadow_intensity | default: 0.6 }}"
        shadow-softness="1"
        exposure="{{ section.settings.exposure | default: 1.0 }}"
        {% if section.settings.enable_ar %}ar ar-modes="webxr scene-viewer quick-look"{% endif %}
        loading="lazy"
        reveal="auto"
        disable-zoom
      >
        {%- if section.settings.enable_ar -%}
          <button slot="ar-button" class="seym-3d__ar-btn" aria-label="See in your room">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            <span>{{ section.settings.ar_label | default: 'View in your space' }}</span>
          </button>
        {%- endif -%}

        <div class="seym-3d__progress" slot="progress-bar">
          <div class="seym-3d__bar"></div>
        </div>
      </model-viewer>

      <div class="seym-3d__hint" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
          <circle cx="12" cy="12" r="3" stroke-width="1"/>
        </svg>
        <span>{{ section.settings.hint_text | default: 'Drag to rotate · Pinch to zoom' }}</span>
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('Seym3D-{{ section.id }}');
    if (!section) return;

    var loaded = false;
    function injectViewerScript() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.type = 'module';
      s.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js';
      document.head.appendChild(s);
    }

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            injectViewerScript();
            obs.disconnect();
          }
        });
      }, { rootMargin: '200px 0px' });
      obs.observe(section);
    } else {
      injectViewerScript();
    }

    var viewer = document.getElementById('SeymModelViewer-{{ section.id }}');
    if (viewer) {
      viewer.addEventListener('progress', function (e) {
        var bar = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__bar');
        if (bar) bar.style.width = (e.detail.totalProgress * 100) + '%';
      });
      viewer.addEventListener('load', function () {
        var prog = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__progress');
        if (prog) { prog.style.opacity = '0'; }
        var hint = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__hint');
        if (hint) {
          hint.style.opacity = '1';
          setTimeout(function() { hint.style.opacity = '0'; }, 4000);
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "3D Object Viewer",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Left column — category info"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature product photo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Maris · Series IV"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Turn it. Study it. Own it."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every facet. Every angle. Every decision."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Each piece in the Maris series is mouth-blown in our Çengelköy atelier and finished one at a time. Hold it to the light, and the story begins.</p>"
    },
    {
      "type": "text",
      "id": "meta_left_label",
      "label": "Meta label (left)",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "meta_left",
      "label": "Meta value (left)",
      "default": "Maris"
    },
    {
      "type": "text",
      "id": "meta_right_label",
      "label": "Meta label (right)",
      "default": "Edition"
    },
    {
      "type": "text",
      "id": "meta_right",
      "label": "Meta value (right)",
      "default": "1 of 12"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA link text",
      "default": "Acquire this piece"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link URL"
    },
    {
      "type": "header",
      "content": "Right column — 3D model"
    },
    {
      "type": "text",
      "id": "model_file",
      "label": "GLB filename (in assets/)",
      "default": "kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb"
    },
    {
      "type": "text",
      "id": "model_alt",
      "label": "Model alt text",
      "default": "Seym Glass Studio — interactive 3D model"
    },
    {
      "type": "range",
      "id": "shadow_intensity",
      "label": "Shadow intensity",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "range",
      "id": "exposure",
      "label": "Exposure / brightness",
      "min": 5,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "enable_ar",
      "label": "Enable AR (View in your space)",
      "default": true
    },
    {
      "type": "text",
      "id": "ar_label",
      "label": "AR button label",
      "default": "View in your space"
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Interaction hint",
      "default": "Drag to rotate · Pinch to zoom"
    }
  ],
  "presets": [
    {
      "name": "3D Object Viewer (split)",
      "settings": {
        "eyebrow": "Maris · Series IV",
        "heading": "Turn it. Study it. Own it.",
        "subheading": "Every facet. Every angle. Every decision.",
        "enable_ar": true
      }
    }
  ]
}
{% endschema %}
