{%- comment -%}
  Seym 3D Viewer — split layout.
  Left: single big lifestyle card (tag, label, sub, DISCOVER, image_link).
  Right: interactive 3D model with AR. Auto-rotate is hover-only.
{%- endcomment -%}

<link rel="stylesheet" href="{{ 'seym-3d-viewer.css' | asset_url }}" media="print" onload="this.media='all'">

<section class="seym-3d" id="Seym3D-{{ section.id }}">
  <div class="seym-3d__split">

    <!-- LEFT: full lifestyle card -->
    <aside class="seym-3d__info">
      {%- assign image_url = section.settings.image_link -%}
      <a class="seym-3d__image{% if section.settings.feature_image == blank %} seym-3d__image--placeholder{% endif %}"
         {% if image_url != blank %}href="{{ image_url }}"{% endif %}>
        {%- if section.settings.feature_image != blank -%}
          {{ section.settings.feature_image
             | image_url: width: 1600
             | image_tag:
               loading: 'lazy',
               widths: '600, 900, 1200, 1600, 2000',
               sizes: '(max-width: 989px) 92vw, 46vw',
               alt: section.settings.feature_image.alt | default: section.settings.image_label }}
        {%- else -%}
          {%- assign watermark_label = section.settings.image_label | default: 'S' -%}
          <span class="seym-3d__image-watermark" aria-hidden="true">{{ watermark_label | slice: 0 }}</span>
        {%- endif -%}

        <div class="seym-3d__image-content">
          {%- if section.settings.image_tag != blank -%}
            <span class="seym-3d__image-tag">{{ section.settings.image_tag }}</span>
          {%- endif -%}
          {%- if section.settings.image_label != blank -%}
            <h3 class="seym-3d__image-headline">{{ section.settings.image_label }}</h3>
          {%- endif -%}
          {%- if section.settings.image_sub != blank -%}
            <p class="seym-3d__image-sub">{{ section.settings.image_sub }}</p>
          {%- endif -%}
          {%- if section.settings.image_cta != blank -%}
            <span class="seym-3d__image-discover">{{ section.settings.image_cta }}</span>
          {%- endif -%}
        </div>
      </a>

    </aside>

    <!-- RIGHT: 3D stage -->
    <div class="seym-3d__stage">
      <model-viewer
        id="SeymModelViewer-{{ section.id }}"
        src="{{ section.settings.model_file | default: 'kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb' | asset_url }}"
        alt="{{ section.settings.model_alt | default: 'Seym Glass Studio — interactive 3D model' }}"
        camera-controls
        interaction-prompt="none"
        camera-orbit="0deg 75deg 105%"
        min-camera-orbit="auto auto 80%"
        max-camera-orbit="auto auto 130%"
        environment-image="neutral"
        shadow-intensity="0"
        exposure="{{ section.settings.exposure | default: 1.0 }}"
        {% if section.settings.enable_ar %}ar ar-modes="webxr scene-viewer quick-look"{% endif %}
        loading="lazy"
        reveal="auto"
        disable-zoom
        disable-tap
      >
        {%- if section.settings.enable_ar -%}
          <button slot="ar-button" class="seym-3d__ar-btn" aria-label="See in your room">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            <span>{{ section.settings.ar_label | default: 'View in your space' }}</span>
          </button>
        {%- endif -%}

        <div class="seym-3d__progress" slot="progress-bar">
          <div class="seym-3d__bar"></div>
        </div>
      </model-viewer>

      <div class="seym-3d__hint" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
          <circle cx="12" cy="12" r="3" stroke-width="1"/>
        </svg>
        <span>{{ section.settings.hint_text | default: 'Drag to rotate · Pinch to zoom' }}</span>
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('Seym3D-{{ section.id }}');
    if (!section) return;

    var loaded = false;
    function injectViewerScript() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.type = 'module';
      s.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js';
      document.head.appendChild(s);
    }

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            injectViewerScript();
            obs.disconnect();
          }
        });
      }, { rootMargin: '200px 0px' });
      obs.observe(section);
    } else {
      injectViewerScript();
    }

    var viewer = document.getElementById('SeymModelViewer-{{ section.id }}');
    if (viewer) {
      viewer.addEventListener('progress', function (e) {
        var bar = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__bar');
        if (bar) bar.style.width = (e.detail.totalProgress * 100) + '%';
      });
      viewer.addEventListener('load', function () {
        var prog = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__progress');
        if (prog) { prog.style.opacity = '0'; }
        var hint = document.querySelector('#Seym3D-{{ section.id }} .seym-3d__hint');
        if (hint) {
          hint.style.opacity = '1';
          setTimeout(function() { hint.style.opacity = '0'; }, 4000);
        }
      });

      /* Auto-rotate only on hover/touch — static the rest of the time
         to keep CPU/GPU idle. */
      var spinning = false;
      function startSpin() {
        if (spinning) return;
        spinning = true;
        viewer.setAttribute('auto-rotate', '');
        viewer.setAttribute('rotation-per-second', '8deg');
      }
      function stopSpin() {
        if (!spinning) return;
        spinning = false;
        viewer.removeAttribute('auto-rotate');
      }
      viewer.addEventListener('mouseenter', startSpin);
      viewer.addEventListener('mouseleave', stopSpin);
      viewer.addEventListener('touchstart', startSpin, { passive: true });
      viewer.addEventListener('touchend', function () {
        setTimeout(stopSpin, 2000);
      }, { passive: true });

      /* Pause renders entirely when the section leaves the viewport */
      if ('IntersectionObserver' in window) {
        var visObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) stopSpin();
          });
        }, { threshold: 0 });
        visObs.observe(viewer);
      }
    }
  })();
</script>

{% schema %}
{
  "name": "3D Object Viewer",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Left column — lifestyle card"
    },
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Lifestyle / product photo"
    },
    {
      "type": "text",
      "id": "image_tag",
      "label": "Photo small tag (all-caps)",
      "default": "Maris · Series IV"
    },
    {
      "type": "text",
      "id": "image_label",
      "label": "Photo large label (overlay)",
      "default": "Maris"
    },
    {
      "type": "textarea",
      "id": "image_sub",
      "label": "Photo sub-label (2 lines)",
      "default": "Hand-blown forms shaped one at a time, in Istanbul."
    },
    {
      "type": "text",
      "id": "image_cta",
      "label": "Photo CTA link label",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Photo link (defaults to CTA link)"
    },
    {
      "type": "header",
      "content": "Right column — 3D model"
    },
    {
      "type": "text",
      "id": "model_file",
      "label": "GLB filename (in assets/)",
      "default": "kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb"
    },
    {
      "type": "text",
      "id": "model_alt",
      "label": "Model alt text",
      "default": "Seym Glass Studio — interactive 3D model"
    },
    {
      "type": "range",
      "id": "shadow_intensity",
      "label": "Shadow intensity",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "range",
      "id": "exposure",
      "label": "Exposure / brightness",
      "min": 5,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "enable_ar",
      "label": "Enable AR (View in your space)",
      "default": true
    },
    {
      "type": "text",
      "id": "ar_label",
      "label": "AR button label",
      "default": "View in your space"
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Interaction hint",
      "default": "Drag to rotate · Pinch to zoom"
    }
  ],
  "presets": [
    {
      "name": "3D Object Viewer (split)",
      "settings": {
        "image_tag": "Maris · Series IV",
        "image_label": "Maris",
        "image_sub": "Hand-blown forms shaped one at a time, in Istanbul.",
        "image_cta": "Discover",
        "enable_ar": true
      }
    }
  ]
}
{% endschema %}
