{%- comment -%}
  Seym Product Video — autoplay loop, full-width cinematic.
  White padding above/below, dark frame optional.
{%- endcomment -%}

{%- assign video_src = section.settings.video_asset | default: 'product-showcase.mp4' -%}

<style>
  .seym-pvid {
    background: {{ section.settings.bg_color | default: '#fafaf7' }};
    padding: {{ section.settings.padding_top | default: 80 }}px 0 {{ section.settings.padding_bottom | default: 80 }}px;
  }

  .seym-pvid__inner {
    max-width: {{ section.settings.max_width | default: 120 }}rem;
    margin: 0 auto;
    padding: 0 5rem;
  }

  .seym-pvid__label {
    display: block;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.38);
    margin-bottom: 3.6rem;
  }

  .seym-pvid__wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #f0ede8;
    {% if section.settings.aspect_ratio == '1:1' %}
    aspect-ratio: 1 / 1;
    {% elsif section.settings.aspect_ratio == '4:3' %}
    aspect-ratio: 4 / 3;
    {% elsif section.settings.aspect_ratio == '9:16' %}
    aspect-ratio: 9 / 16;
    max-width: 52rem;
    margin: 0 auto;
    {% else %}
    aspect-ratio: 16 / 9;
    {% endif %}
  }

  .seym-pvid__wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .seym-pvid__caption {
    margin-top: 2.4rem;
    text-align: center;
  }
  .seym-pvid__caption p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.9rem;
    font-weight: 300;
    color: rgba(13,13,13,0.55);
    margin: 0;
    letter-spacing: 0;
  }

  @media (max-width: 749px) {
    .seym-pvid__inner { padding: 0 2.4rem; }
    .seym-pvid { padding: 6rem 0; }
  }
</style>

<section class="seym-pvid">
  <div class="seym-pvid__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="seym-pvid__label">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <div class="seym-pvid__wrap">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="{{ video_src | asset_url }}" type="video/mp4">
      </video>
    </div>

    {%- if section.settings.caption != blank -%}
      <div class="seym-pvid__caption">
        <p>{{ section.settings.caption }}</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Video",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "video_asset",
      "label": "Video filename (in assets/)",
      "default": "product-showcase.mp4",
      "info": "Upload the .mp4 file to theme assets, then enter the filename here."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "In Motion"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption below video",
      "default": "Hand-blown in Istanbul."
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "16:9", "label": "16:9 — widescreen" },
        { "value": "1:1", "label": "1:1 — square" },
        { "value": "4:3", "label": "4:3 — classic" },
        { "value": "9:16", "label": "9:16 — portrait / mobile" }
      ],
      "default": "16:9"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (rem)",
      "min": 60,
      "max": 180,
      "step": 10,
      "default": 120
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#fafaf7"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 96,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 96,
      "step": 8,
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Product Video",
      "settings": {
        "video_asset": "product-showcase.mp4",
        "eyebrow": "In Motion",
        "caption": "Hand-blown in Istanbul.",
        "aspect_ratio": "16:9"
      }
    }
  ]
}
{% endschema %}
