{%- comment -%}
  Seym Collections Grid
  Chic /collections landing — mirrors the homepage editorial language.
  - Minimal hero (wine eyebrow + giant serif title + count)
  - Asymmetric 3-col cascade of collection cards, lifestyle-card recipe
    (full-bleed image, wine gradient veil, overlay name + count, DISCOVER)
  - No long copy. Collections lead.
{%- endcomment -%}

<style>
  .seym-cg {
    background: var(--seym-ivory, #F5F1EA);
    color: var(--seym-ink, #1A1A1A);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .seym-cg__wrap {
    max-width: 132rem;
    margin: 0 auto;
    padding: 0 4rem;
  }

  /* --- Hero --- */
  .seym-cg__hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
    margin: 0 0 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(26,26,26,0.1);
  }
  .seym-cg__hero-lead { min-width: 0; }

  .seym-cg__eyebrow {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.4rem;
    padding-left: 2.6rem;
  }
  .seym-cg__eyebrow::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    width: 2rem; height: 1px;
    background: var(--seym-wine, #8E2244);
  }
  .seym-cg__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.6rem, 5.4vw, 7.2rem);
    line-height: 1;
    letter-spacing: -0.018em;
    color: #1A1A1A;
    margin: 0;
  }
  .seym-cg__heading em { font-style: italic; color: var(--seym-wine, #8E2244); }

  .seym-cg__hero-meta {
    flex-shrink: 0;
    text-align: right;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.5);
    line-height: 1.6;
  }
  .seym-cg__hero-count em {
    font-style: normal;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    letter-spacing: 0;
    color: #1A1A1A;
    margin-right: 0.4rem;
    vertical-align: -0.05em;
  }

  /* --- Grid: 3-col asymmetric cascade --- */
  .seym-cg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 3.6rem;
    row-gap: 6.4rem;
    align-items: start;
  }
  .seym-cg__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: rgba(26,26,26,0.05);
    isolation: isolate;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 800ms cubic-bezier(0.22,1,0.36,1),
                transform 800ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-cg__card.visible { opacity: 1; transform: none; }

  /* Asymmetric stagger + aspect variation, mirrors the product grid */
  .seym-cg__card:nth-child(3n + 2) { margin-top: 6.4rem; aspect-ratio: 1 / 1; }
  .seym-cg__card:nth-child(3n + 3) { margin-top: 3.2rem; aspect-ratio: 3 / 4; }
  /* Uniform, aligned grid — remove the staggered offsets + mixed ratios so every
     collection sits in the same row at the same 4/5 size (all breakpoints). */
  .seym-cg__card { margin-top: 0 !important; aspect-ratio: 4 / 5 !important; }

  .seym-cg__card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1600ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-cg__card:hover img { transform: scale(1.05); }

  /* Wine veil — soft default, deepens on hover (same recipe as trio cards) */
  .seym-cg__card::after {
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg,
        rgba(26,26,26,0) 0%,
        rgba(26,26,26,0.15) 45%,
        rgba(142, 34, 68, 0.78) 100%);
    z-index: 1;
    transition: background 500ms ease;
    pointer-events: none;
  }
  .seym-cg__card:hover::after {
    background:
      linear-gradient(180deg,
        rgba(142, 34, 68, 0.18) 0%,
        rgba(142, 34, 68, 0.45) 50%,
        rgba(110, 26, 53, 0.92) 100%);
  }

  /* Placeholder for collections with no featured image */
  .seym-cg__card--placeholder {
    background:
      linear-gradient(160deg,
        rgba(142,34,68,0.16) 0%,
        rgba(197,71,48,0.12) 60%,
        rgba(26,26,26,0.06) 100%);
  }
  .seym-cg__watermark {
    position: absolute;
    z-index: 1;
    top: 50%; right: 8%;
    transform: translateY(-50%);
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(8rem, 14vw, 16rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: rgba(245,241,234,0.92);
    text-shadow: 0 4px 32px rgba(0,0,0,0.15);
    pointer-events: none;
    user-select: none;
  }

  /* Overlay content */
  .seym-cg__overlay {
    position: absolute;
    z-index: 2;
    inset: auto 2.4rem 2.4rem 2.4rem;
    color: #F5F1EA;
    pointer-events: none;
    max-width: 90%;
  }
  .seym-cg__tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.82);
    margin-bottom: 0.9rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(245,241,234,0.4);
  }
  .seym-cg__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(2.2rem, 2.4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.008em;
    color: #F5F1EA;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0,0,0,0.35);
  }
  .seym-cg__discover {
    margin-top: 1.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #F5F1EA;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(245,241,234,0.6);
    transition: padding-right 280ms ease, border-color 220ms ease;
  }
  .seym-cg__discover::after {
    content: '→';
    display: inline-block;
    transition: transform 280ms ease;
  }
  .seym-cg__card:hover .seym-cg__discover { padding-right: 0.6rem; border-color: #F5F1EA; }
  .seym-cg__card:hover .seym-cg__discover::after { transform: translateX(4px); }

  /* Empty state */
  .seym-cg__empty {
    text-align: center;
    padding: 8rem 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.8rem;
    color: rgba(26,26,26,0.55);
  }

  /* Responsive */
  @media (max-width: 989px) {
    .seym-cg__wrap { padding: 0 2.4rem; }
    .seym-cg__hero { flex-direction: column; align-items: flex-start; gap: 1.6rem; }
    .seym-cg__hero-meta { text-align: left; }
    .seym-cg__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2rem;
      row-gap: 4.8rem;
    }
    .seym-cg__card:nth-child(3n + 2),
    .seym-cg__card:nth-child(3n + 3) { margin-top: 0; aspect-ratio: 4 / 5; }
    .seym-cg__card:nth-child(2n) { margin-top: 4rem; aspect-ratio: 1 / 1; }
    .seym-cg__overlay { inset: auto 1.8rem 1.8rem 1.8rem; }
  }
  @media (max-width: 540px) {
    .seym-cg {
      padding: {{ section.settings.padding_top | divided_by: 1.6 | floor }}px 0
              {{ section.settings.padding_bottom | divided_by: 1.6 | floor }}px;
    }
    .seym-cg__grid { grid-template-columns: 1fr; row-gap: 3.6rem; }
    .seym-cg__card,
    .seym-cg__card:nth-child(2n) { margin-top: 0; aspect-ratio: 4 / 5; }
  }
</style>

{%- liquid
  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
  assign eyebrow_text = section.settings.eyebrow
  assign heading_text = section.settings.heading
  if is_tr
    assign eyebrow_text = 'ATÖLYE'
    assign heading_text = 'Tüm Koleksiyon'
  endif
-%}

<section class="seym-cg" id="SeymCG-{{ section.id }}">
  <div class="seym-cg__wrap">

    {%- if eyebrow_text != blank or heading_text != blank -%}
      <header class="seym-cg__hero">
        <div class="seym-cg__hero-lead">
          {%- if eyebrow_text != blank -%}
            <span class="seym-cg__eyebrow">{{ eyebrow_text }}</span>
          {%- endif -%}
          {%- if heading_text != blank -%}
            <h1 class="seym-cg__heading">{{ heading_text }}</h1>
          {%- endif -%}
        </div>
        <div class="seym-cg__hero-meta">
          <div class="seym-cg__hero-count">
            <em>{{ collections.size }}</em>
            {% if is_tr %}koleksiyon{% elsif collections.size == 1 %}collection{% else %}collections{% endif %}
          </div>
        </div>
      </header>
    {%- endif -%}

    {%- liquid
      comment
        Order: numbered slot pickers first (slot_1..slot_17 in the editor),
        then any collection without a slot, per the sort setting. Handles are
        comma-delimited on both sides so lookups can't partial-match.
      endcomment
      assign cg_order = ','
      for cg_i in (1..17)
        assign cg_key = 'slot_' | append: cg_i
        assign cg_scol = section.settings[cg_key]
        if cg_scol != blank
          assign cg_token = ',' | append: cg_scol.handle | append: ','
          unless cg_order contains cg_token
            assign cg_order = cg_order | append: cg_scol.handle | append: ','
          endunless
        endif
      endfor
      assign cg_rest = collections
      if section.settings.sort_mode == 'za'
        assign cg_rest = collections | sort_natural: 'title' | reverse
      elsif section.settings.sort_mode == 'count_desc'
        assign cg_rest = collections | sort: 'products_count' | reverse
      elsif section.settings.sort_mode == 'count_asc'
        assign cg_rest = collections | sort: 'products_count'
      elsif section.settings.sort_mode == 'new_first'
        assign cg_rest = collections | sort: 'id' | reverse
      elsif section.settings.sort_mode == 'old_first'
        assign cg_rest = collections | sort: 'id'
      endif
      for cg_c in cg_rest
        assign cg_token = ',' | append: cg_c.handle | append: ','
        unless cg_order contains cg_token
          assign cg_order = cg_order | append: cg_c.handle | append: ','
        endunless
      endfor
      assign cg_handles = cg_order | split: ','
    -%}

    {%- if collections.size == 0 -%}
      <div class="seym-cg__empty">No collections yet.</div>
    {%- else -%}
      <div class="seym-cg__grid">
        {%- for cg_h in cg_handles -%}
          {%- if cg_h == blank -%}{%- continue -%}{%- endif -%}
          {%- assign collection = collections[cg_h] -%}
          {%- if collection == blank -%}{%- continue -%}{%- endif -%}
          {%- comment -%} Use the collection's own image set in admin
            (Collections → [name] → Image). No product fallback —
            if blank, the placeholder watermark shows instead. {%- endcomment -%}
          {%- assign card_img = collection.image -%}
          <a class="seym-cg__card{% if card_img == blank %} seym-cg__card--placeholder{% endif %}"
             href="{{ collection.url }}"
             aria-label="{{ collection.title | escape }}">
            {%- if card_img != blank -%}
              {{ card_img
                 | image_url: width: 1400
                 | image_tag:
                   loading: 'lazy',
                   widths: '400, 600, 800, 1100, 1400, 1800',
                   sizes: '(max-width: 540px) 92vw, (max-width: 989px) 44vw, 28vw',
                   alt: collection.title | escape }}
            {%- else -%}
              <span class="seym-cg__watermark" aria-hidden="true">{{ collection.title | slice: 0 }}</span>
            {%- endif -%}

            <div class="seym-cg__overlay">
              <span class="seym-cg__tag">
                {{ collection.products_count }}
                {% if is_tr %}parça{% elsif collection.products_count == 1 %}piece{% else %}pieces{% endif %}
              </span>
              <h2 class="seym-cg__name">{{ collection.title }}</h2>
              <span class="seym-cg__discover">{% if is_tr %}Keşfet{% else %}{{ section.settings.cta_label | default: 'Discover' }}{% endif %}</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var cards = document.querySelectorAll('#SeymCG-{{ section.id }} .seym-cg__card');
  if (!cards.length || !('IntersectionObserver' in window)) {
    cards.forEach(function (c) { c.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.style.transitionDelay = ((e.target.dataset.delay || 0) + 'ms');
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  cards.forEach(function (el, i) {
    el.dataset.delay = (i % 3) * 80;
    obs.observe(el);
  });
})();
</script>

