{%- comment -%}
  Seym Daum Hero — full-viewport video/image with centered overlay text + CTA.
{%- endcomment -%}

<style>
  .seym-dh {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #0a0a0a;
  }
  .seym-dh__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .seym-dh__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.15) 40%,
      rgba(0,0,0,0.15) 60%,
      rgba(0,0,0,0.5) 100%
    );
    z-index: 1;
  }
  .seym-dh__content {
    position: absolute;
    z-index: 2;
    bottom: 12vh;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: #F5F1EA;
  }
  .seym-dh__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.7);
    margin: 0 0 1.2rem;
  }
  .seym-dh__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.6rem, 6vw, 8rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 2.4rem;
    color: #F5F1EA;
    text-shadow: 0 2px 32px rgba(0,0,0,0.3);
  }
  .seym-dh__heading em { font-style: italic; }
  .seym-dh__cta {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #F5F1EA;
    text-decoration: none;
    border: 1px solid rgba(245,241,234,0.5);
    padding: 1.1rem 3.2rem;
    transition: background 260ms ease, border-color 260ms ease;
    min-height: 44px;
  }
  .seym-dh__cta:hover {
    background: rgba(245,241,234,0.12);
    border-color: #F5F1EA;
  }
  .seym-dh__scroll {
    position: absolute;
    bottom: 2.4rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 1px;
    height: 3.6rem;
    background: rgba(245,241,234,0.3);
    animation: seym-dh-pulse 2s ease infinite;
  }
  @keyframes seym-dh-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }
  @media (max-width: 749px) {
    .seym-dh__content { bottom: 8vh; padding: 0 2rem; }
    .seym-dh__heading { font-size: clamp(2.8rem, 10vw, 4.8rem); }
  }
</style>

<section class="seym-dh">
  {%- if section.settings.video_asset != blank -%}
    <video class="seym-dh__media" autoplay muted loop playsinline preload="auto"
      {%- if section.settings.poster != blank %} poster="{{ section.settings.poster | image_url: width: 1920 }}"{% endif %}>
      <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.poster != blank -%}
    {{ section.settings.poster | image_url: width: 2400 | image_tag:
       class: 'seym-dh__media', loading: 'eager',
       widths: '800,1200,1600,2000,2400',
       sizes: '100vw' }}
  {%- endif -%}

  <div class="seym-dh__overlay"></div>

  <div class="seym-dh__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="seym-dh__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="seym-dh__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="seym-dh__cta">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
  <span class="seym-dh__scroll"></span>
</section>

{% schema %}
{
  "name": "Daum Hero",
  "tag": "div",
  "class": "seym-daum-hero-section",
  "settings": [
    { "type": "text", "id": "video_asset", "label": "Video asset filename (e.g. product-showcase.mp4)" },
    { "type": "image_picker", "id": "poster", "label": "Poster / fallback image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Seym Glass Studio · Istanbul" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEYM" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Discover the collection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Daum Hero" }]
}
{% endschema %}
