{%- comment -%}
  Daum Hero — 100vh full-screen video/image. Dark overlay.
  Small eyebrow, large brand title, outlined CTA centered at bottom.
  Header sits transparently on top.
{%- endcomment -%}

<style>
  .sdh {
    position: relative;
    width: 100%;
    height: 100vh;
    max-height: 56rem;
    overflow: hidden;
    background: #0a0a0a;
  }
  .sdh__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sdh__grad {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom,
        rgba(0,0,0,0.25) 0%,
        rgba(0,0,0,0.08) 30%,
        rgba(0,0,0,0.08) 55%,
        rgba(0,0,0,0.50) 100%);
    z-index: 1;
  }
  .sdh__txt {
    position: absolute;
    z-index: 2;
    bottom: 8vh;
    left: 0; right: 0;
    text-align: center;
    color: #fff;
  }
  .sdh__ey {
    font: 300 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin: 0 0 1.4rem;
  }
  .sdh__h {
    font: 300 clamp(3.2rem,6vw,6rem)/0.95 'Cormorant Garamond', serif;
    letter-spacing: 0.06em;
    margin: 0 0 2.6rem;
    color: #fff;
  }
  .sdh__cta {
    display: inline-block;
    font: 400 0.68rem/1 'Inter', sans-serif;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.45);
    padding: 1.05rem 2.8rem;
    transition: background .25s, border-color .25s;
    min-height: 44px;
  }
  .sdh__cta:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
  @media(max-width:749px){
    .sdh { max-height: none; }
    .sdh__txt { bottom: 6vh; padding: 0 2rem; }
  }
</style>

<section class="sdh">
  {%- if section.settings.video_asset != blank -%}
    <video class="sdh__media" autoplay muted loop playsinline preload="auto"
      {%- if section.settings.poster != blank %} poster="{{ section.settings.poster | image_url: width: 1920 }}"{% endif %}>
      <source src="{{ section.settings.video_asset | asset_url }}" type="video/mp4">
    </video>
  {%- elsif section.settings.poster != blank -%}
    {{ section.settings.poster | image_url: width: 2400 | image_tag:
       class: 'sdh__media', loading: 'eager',
       widths: '800,1200,1600,2000,2400', sizes: '100vw' }}
  {%- endif -%}
  <div class="sdh__grad"></div>
  <div class="sdh__txt">
    {%- if section.settings.eyebrow != blank -%}<p class="sdh__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h1 class="sdh__h">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="sdh__cta">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Daum Hero",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "video_asset", "label": "Video filename", "default": "product-showcase.mp4" },
    { "type": "image_picker", "id": "poster", "label": "Poster / fallback" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Art de la Table" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEYM" },
    { "type": "text", "id": "cta_label", "label": "CTA", "default": "Discover the collection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Daum Hero" }]
}
{% endschema %}
