{%- comment -%}
  Seym Editorial Collection
  Completedworks-style minimal listing.
  - Optional editorial intro pulled from collection metafields
  - 2-column desktop grid (1-column mobile)
  - Editorial passages intercalated between product rows (from metafields)
  - Minimal card: image, name, price — no borders, no badges in-flow
  - Light sort dropdown, optional left rail meta info

  Metafields (Shopify admin → Collections → Metafields, namespace "custom"):
    story_eyebrow        (single_line_text)   e.g. "Flos · Series I"
    story_heading        (single_line_text)   e.g. "Çiçeklerin sessiz mevsimi"
    story_intro          (multi_line_text)    Long intro passage
    story_passage_1      (multi_line_text)    Mid-grid passage
    story_passage_1_after(number_integer)     Insert after N-th product (default 4)
    story_passage_2      (multi_line_text)    Second mid-grid passage
    story_passage_2_after(number_integer)     Insert after N-th product (default 12)
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  .seym-coll {
    background: #FFFFFF;
    color: #1A1A1A;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .seym-coll__wrap {
    max-width: 144rem;
    margin: 0 auto;
    padding: 0 4rem;
  }

  /* Asimetrik editorial grid */
.seym-coll__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: auto;
  gap: 2rem 1.5rem;
  align-items: start;
}

/* Her 5. grubun 1. kartı büyük (2 kolon, 2 sıra) */
.seym-coll__item:nth-child(5n+1) {
  grid-column: span 2;
  grid-row: span 2;
}

/* Staggered offset — 3. kart aşağı kayar */
.seym-coll__item:nth-child(5n+3) {
  margin-top: 3rem;
}

/* 5. kart hafif yukarı çıkar */
.seym-coll__item:nth-child(5n+5) {
  margin-top: -1.5rem;
}

/* Mobilde düz tek kolon */
@media (max-width: 989px) {
  .seym-coll__grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .seym-coll__item:nth-child(5n+1) {
    grid-column: span 2;
    grid-row: span 1;
  }
  .seym-coll__item:nth-child(5n+3),
  .seym-coll__item:nth-child(5n+5) {
    margin-top: 0;
  }
}

@media (max-width: 540px) {
  .seym-coll__grid {
    grid-template-columns: 1fr;
  }
  .seym-coll__item:nth-child(5n+1) {
    grid-column: span 1;
  }
}


  /* --- Editorial intro (top) --- */
  .seym-coll__intro {
    max-width: 92rem;
    margin: 0 auto 8rem;
    text-align: left;
  }
  .seym-coll__intro--center { text-align: center; }

  .seym-coll__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.55);
    margin-bottom: 2.4rem;
  }

  .seym-coll__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.4rem, 4.6vw, 6.4rem);
    line-height: 1.04;
    letter-spacing: -0.012em;
    color: #1A1A1A;
    margin: 0 0 2.6rem;
  }

  .seym-coll__intro-text {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.7rem, 1.7vw, 2.05rem);
    line-height: 1.55;
    color: rgba(26,26,26,0.78);
    max-width: 68ch;
    margin: 0;
  }
  .seym-coll__intro--center .seym-coll__intro-text { margin: 0 auto; }

  /* --- Toolbar --- */
  .seym-coll__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 2.4rem;
    border-bottom: 1px solid rgba(26,26,26,0.1);
    margin-bottom: 5rem;
  }
  .seym-coll__count {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.55);
  }
  .seym-coll__sort {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: transparent;
    border: 0;
    border-bottom: 1px solid transparent;
    padding: 0.4rem 1.8rem 0.4rem 0;
    color: #1A1A1A;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, #1A1A1A 50%),
                      linear-gradient(135deg, #1A1A1A 50%, transparent 50%);
    background-position: calc(100% - 8px) 50%, calc(100% - 4px) 50%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
  }
  .seym-coll__sort:focus { outline: none; border-bottom-color: #1A1A1A; }

  /* --- Grid --- */
  .seym-coll__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 6rem;
    row-gap: 9rem;
  }

  .seym-coll__item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 700ms cubic-bezier(0.22,1,0.36,1),
                transform 700ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-coll__item.visible { opacity: 1; transform: none; }

  .seym-coll__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #F8F5F0;
  }
  .seym-coll__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 600ms ease, transform 1400ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-coll__media .seym-coll__img--secondary {
    opacity: 0;
  }
  .seym-coll__media:hover .seym-coll__img--primary {
    opacity: 0;
  }
  .seym-coll__media:hover .seym-coll__img--secondary {
    opacity: 1;
    transform: scale(1.02);
  }

  .seym-coll__sold {
    position: absolute;
    top: 1.6rem;
    left: 1.6rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.7);
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(4px);
    padding: 0.5rem 0.9rem;
  }

  .seym-coll__info {
    margin-top: 1.8rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.6rem;
  }
  .seym-coll__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.8rem;
    line-height: 1.2;
    margin: 0;
    color: #1A1A1A;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .seym-coll__name:hover { color: var(--seym-terracotta, #C54730); }
  .seym-coll__price {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: rgba(26,26,26,0.78);
    white-space: nowrap;
  }
  .seym-coll__price-compare {
    text-decoration: line-through;
    color: rgba(26,26,26,0.4);
    margin-right: 0.6rem;
  }
  .seym-coll__price-sale {
    color: var(--seym-orange, #FD4401);
  }

  /* --- Editorial passage between rows --- */
  .seym-coll__passage {
    grid-column: 1 / -1;
    max-width: 64ch;
    margin: 2rem auto 1rem;
    padding: 4rem 0;
    text-align: center;
    border-top: 1px solid rgba(26,26,26,0.1);
    border-bottom: 1px solid rgba(26,26,26,0.1);
  }
  .seym-coll__passage p {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.7rem, 1.8vw, 2.15rem);
    line-height: 1.55;
    color: rgba(26,26,26,0.85);
    margin: 0;
  }
  .seym-coll__passage p + p { margin-top: 1.2rem; }

  /* --- Empty state --- */
  .seym-coll__empty {
    text-align: center;
    padding: 8rem 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.8rem;
    color: rgba(26,26,26,0.55);
  }

  /* --- Pagination --- */
  .seym-coll__pagination {
    margin-top: 8rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .seym-coll__pagination a,
  .seym-coll__pagination span {
    color: #1A1A1A;
    text-decoration: none;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid transparent;
  }
  .seym-coll__pagination a:hover { border-bottom-color: #1A1A1A; }
  .seym-coll__pagination .seym-coll__pagination-current {
    color: var(--seym-wine, #8E2244);
    border-bottom-color: var(--seym-wine, #8E2244);
  }

  @media (max-width: 989px) {
    .seym-coll__wrap { padding: 0 2.4rem; }
    .seym-coll__intro { margin-bottom: 5rem; }
    .seym-coll__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2rem;
      row-gap: 5rem;
    }
    .seym-coll__name { font-size: 1.55rem; }
    .seym-coll__info { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
    .seym-coll__passage { padding: 3rem 0; margin: 1rem auto; }
  }

  @media (max-width: 540px) {
    .seym-coll {
      padding: {{ section.settings.padding_top | divided_by: 1.6 | floor }}px 0
              {{ section.settings.padding_bottom | divided_by: 1.6 | floor }}px;
    }
    .seym-coll__grid {
      grid-template-columns: 1fr;
      row-gap: 5rem;
    }
    .seym-coll__toolbar { margin-bottom: 3.6rem; }
  }
</style>

{%- liquid
  assign mf_eyebrow   = collection.metafields.custom.story_eyebrow
  assign mf_heading   = collection.metafields.custom.story_heading
  assign mf_intro     = collection.metafields.custom.story_intro
  assign mf_passage_1 = collection.metafields.custom.story_passage_1
  assign mf_passage_1_after_raw = collection.metafields.custom.story_passage_1_after
  assign mf_passage_2 = collection.metafields.custom.story_passage_2
  assign mf_passage_2_after_raw = collection.metafields.custom.story_passage_2_after

  assign eyebrow_text = mf_eyebrow | default: section.settings.fallback_eyebrow
  assign heading_text = mf_heading | default: collection.title
  assign intro_text   = mf_intro   | default: section.settings.fallback_intro

  assign passage_1_text = mf_passage_1 | default: section.settings.fallback_passage_1
  assign passage_2_text = mf_passage_2 | default: section.settings.fallback_passage_2

  if mf_passage_1_after_raw != blank
    assign passage_1_after = mf_passage_1_after_raw | plus: 0
  else
    assign passage_1_after = section.settings.fallback_passage_1_after
  endif
  if mf_passage_2_after_raw != blank
    assign passage_2_after = mf_passage_2_after_raw | plus: 0
  else
    assign passage_2_after = section.settings.fallback_passage_2_after
  endif
-%}

<section class="seym-coll" id="SeymColl-{{ section.id }}">
  <div class="seym-coll__wrap">

    {%- if eyebrow_text != blank or heading_text != blank or intro_text != blank -%}
      <header class="seym-coll__intro{% if section.settings.intro_alignment == 'center' %} seym-coll__intro--center{% endif %}">
        {%- if eyebrow_text != blank -%}
          <span class="seym-coll__eyebrow">{{ eyebrow_text }}</span>
        {%- endif -%}
        {%- if heading_text != blank -%}
          <h1 class="seym-coll__heading">{{ heading_text }}</h1>
        {%- endif -%}
        {%- if intro_text != blank -%}
          <div class="seym-coll__intro-text rte">{{ intro_text }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}

      <div class="seym-coll__toolbar">
        <span class="seym-coll__count">
          {%- if collection.products_count == collection.all_products_count -%}
            {{ collection.products_count }} {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}
          {%- else -%}
            {{ collection.products_count }} of {{ collection.all_products_count }}
          {%- endif -%}
        </span>

        {%- if section.settings.enable_sorting -%}
          <form method="get" class="seym-coll__sort-form">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            <select name="sort_by" class="seym-coll__sort" onchange="this.form.submit()">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected{% endif %}>
                  {{ option.name | escape }}
                </option>
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      </div>

      {%- if collection.products.size == 0 -%}
        <div class="seym-coll__empty">No pieces in this collection — yet.</div>
      {%- else -%}
        <div class="seym-coll__grid">
          {%- for product in collection.products -%}
            {%- assign idx = forloop.index -%}

            <article class="seym-coll__item">
              <a class="seym-coll__media" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                {%- assign primary = product.featured_media -%}
                {%- assign secondary = product.media[1] -%}
                {%- if primary != blank -%}
                  {{ primary
                     | image_url: width: 1200
                     | image_tag:
                       class: 'seym-coll__img--primary',
                       loading: 'lazy',
                       widths: '300, 450, 600, 800, 1100, 1400',
                       sizes: '(max-width: 540px) 92vw, (max-width: 989px) 44vw, 38vw',
                       alt: product.title | escape }}
                {%- endif -%}
                {%- if secondary != blank -%}
                  {{ secondary
                     | image_url: width: 1200
                     | image_tag:
                       class: 'seym-coll__img--secondary',
                       loading: 'lazy',
                       widths: '300, 450, 600, 800, 1100, 1400',
                       sizes: '(max-width: 540px) 92vw, (max-width: 989px) 44vw, 38vw',
                       alt: product.title | escape }}
                {%- endif -%}
                {%- unless product.available -%}
                  <span class="seym-coll__sold">Sold</span>
                {%- endunless -%}
              </a>
              <div class="seym-coll__info">
                <h3 style="margin:0">
                  <a class="seym-coll__name" href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <div class="seym-coll__price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="seym-coll__price-compare">{{ product.compare_at_price | money }}</span>
                    <span class="seym-coll__price-sale">{{ product.price | money }}</span>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </div>
              </div>
            </article>

            {%- if passage_1_text != blank and idx == passage_1_after -%}
              <aside class="seym-coll__passage">{{ passage_1_text }}</aside>
            {%- endif -%}
            {%- if passage_2_text != blank and idx == passage_2_after -%}
              <aside class="seym-coll__passage">{{ passage_2_text }}</aside>
            {%- endif -%}

          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="seym-coll__pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">‹ Prev</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="seym-coll__pagination-current">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">Next ›</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endif -%}

    {%- endpaginate -%}
  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('#SeymColl-{{ section.id }} .seym-coll__item');
  if (!items.length || !('IntersectionObserver' in window)) {
    items.forEach(function (i) { i.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.style.transitionDelay = ((e.target.dataset.delay || 0) + 'ms');
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function (el, i) {
    el.dataset.delay = (i % 2) * 80;
    obs.observe(el);
  });
})();
</script>

{% schema %}
{
  "name": "Editorial Collection",
  "tag": "section",
  "class": "shopify-section seym-collection-section",
  "settings": [
    {
      "type": "header",
      "content": "Intro fallbacks"
    },
    {
      "type": "paragraph",
      "content": "Per-collection text comes from the collection's metafields (namespace 'custom'): story_eyebrow, story_heading, story_intro. These fallbacks are used only when a collection has none."
    },
    {
      "type": "text",
      "id": "fallback_eyebrow",
      "label": "Fallback eyebrow"
    },
    {
      "type": "richtext",
      "id": "fallback_intro",
      "label": "Fallback intro text"
    },
    {
      "type": "select",
      "id": "intro_alignment",
      "label": "Intro alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Passage fallbacks (between rows)"
    },
    {
      "type": "richtext",
      "id": "fallback_passage_1",
      "label": "Passage 1 fallback"
    },
    {
      "type": "range",
      "id": "fallback_passage_1_after",
      "label": "Insert passage 1 after product #",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 4
    },
    {
      "type": "richtext",
      "id": "fallback_passage_2",
      "label": "Passage 2 fallback"
    },
    {
      "type": "range",
      "id": "fallback_passage_2_after",
      "label": "Insert passage 2 after product #",
      "min": 1,
      "max": 36,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 2,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sort dropdown",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "Editorial Collection"
    }
  ]
}
{% endschema %}
