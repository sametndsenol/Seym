    },
    {
      "type": "text",
      "id": "fallback_eyebrow",
      "label": "Fallback eyebrow"
    },
    {
      "type": "richtext",
      "id": "fallback_intro",
      "label": "Fallback intro text"
    },
    {
      "type": "select",
