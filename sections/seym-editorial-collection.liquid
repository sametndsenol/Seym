      "min": 1,
      "max": 24,
      "step": 1,
      "default": 4
    },
    {
      "type": "richtext",
      "id": "fallback_passage_2",
      "label": "Passage 2 fallback"
    },
    {
      "type": "range",
      "id": "fallback_passage_2_after",
      "label": "Insert passage 2 after product #",
      "min": 1,
      "max": 36,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 2,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sort dropdown",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "Editorial Collection"
    }
  ]
}
{% endschema %}
