{%- comment -%}
  Seym Editorial Collection
  Completedworks-style minimal listing.
  - Optional editorial intro pulled from collection metafields
  - 2-column desktop grid (1-column mobile)
  - Editorial passages intercalated between product rows (from metafields)
  - Minimal card: image, name, price — no borders, no badges in-flow
  - Light sort dropdown, optional left rail meta info

  Metafields (Shopify admin → Collections → Metafields, namespace "custom"):
    story_eyebrow        (single_line_text)   e.g. "Flos · Series I"
    story_heading        (single_line_text)   e.g. "Çiçeklerin sessiz mevsimi"
    story_intro          (multi_line_text)    Long intro passage
    story_passage_1      (multi_line_text)    Mid-grid passage
    story_passage_1_after(number_integer)     Insert after N-th product (default 4)
    story_passage_2      (multi_line_text)    Second mid-grid passage
    story_passage_2_after(number_integer)     Insert after N-th product (default 12)
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  .seym-coll {
    background: #FFFFFF;
    color: #1A1A1A;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .seym-coll__wrap {
    max-width: 132rem;
    margin: 0 auto;
    padding: 0 4rem;
  }
  /* --- Hero strip (chic, minimal) ---
     Eyebrow on top, giant serif collection name underneath,
     a thin wine rule, and the meta toolbar tucked under it.
     No long copy — the products do the talking. */
  .seym-coll__hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
    margin: 0 0 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(26,26,26,0.1);
  }

  .seym-coll__hero-lead { min-width: 0; }

  .seym-coll__eyebrow {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.4rem;
    padding-left: 2.6rem;
  }
  .seym-coll__eyebrow::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    width: 2rem; height: 1px;
    background: var(--seym-wine, #8E2244);
  }

  .seym-coll__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.6rem, 5.4vw, 7.2rem);
    line-height: 1;
    letter-spacing: -0.018em;
    color: #1A1A1A;
    margin: 0;
  }

  .seym-coll__hero-meta {
    flex-shrink: 0;
    text-align: right;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.5);
    line-height: 1.6;
  }
  .seym-coll__hero-count em {
    font-style: normal;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    letter-spacing: 0;
    color: #1A1A1A;
    margin-right: 0.4rem;
    vertical-align: -0.05em;
  }

  /* --- Toolbar (slim, sits right under the hero rule) --- */
  .seym-coll__toolbar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 3.6rem;
  }
  .seym-coll__sort {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: transparent;
    border: 0;
    border-bottom: 1px solid transparent;
    padding: 0.4rem 1.8rem 0.4rem 0;
    color: #1A1A1A;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    background-image: linear-gradient(45deg, transparent 50%, #1A1A1A 50%),
                      linear-gradient(135deg, #1A1A1A 50%, transparent 50%);
    background-position: calc(100% - 8px) 50%, calc(100% - 4px) 50%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
  }
  .seym-coll__sort:focus { outline: none; border-bottom-color: #1A1A1A; }

  /* Themed sort dropdown — matches the site (ivory/wine/serif) instead of the
     browser's native select list. */
  .scsort__label { font: 400 .7rem/1 'Inter', sans-serif; letter-spacing: .24em; text-transform: uppercase; color: rgba(26,26,26,.5); }
  .scsort { position: relative; }
  .scsort__btn {
    display: inline-flex; align-items: center; gap: .7rem; background: transparent; border: 0;
    border-bottom: 1px solid rgba(26,26,26,.28); padding: .5rem 0;
    font: 400 .82rem/1 'Inter', sans-serif; letter-spacing: .14em; text-transform: uppercase;
    color: #1A1A1A; cursor: pointer; transition: border-color .25s ease, color .25s ease;
  }
  .scsort__btn:hover { border-bottom-color: #1A1A1A; color: var(--seym-wine, #8E2244); }
  .scsort__chev { width: 1.1rem; height: 1.1rem; stroke: currentColor; fill: none; stroke-width: 1.5; transition: transform .3s ease; }
  .scsort.is-open .scsort__chev { transform: rotate(180deg); }
  .scsort__panel {
    position: absolute; top: calc(100% + .9rem); right: 0; min-width: 22rem;
    background: #fff; border: 1px solid rgba(26,26,26,.07); border-radius: 12px;
    box-shadow: 0 30px 60px -30px rgba(40,28,24,.38), 0 10px 24px -18px rgba(0,0,0,.2);
    padding: .6rem; list-style: none; margin: 0; z-index: 30;
    opacity: 0; transform: translateY(-6px); pointer-events: none;
    transition: opacity .28s cubic-bezier(.22,1,.36,1), transform .28s cubic-bezier(.22,1,.36,1);
  }
  .scsort.is-open .scsort__panel { opacity: 1; transform: none; pointer-events: auto; }
  .scsort__opt {
    font: 400 1.25rem/1 'Cormorant Garamond', serif; color: rgba(26,26,26,.72);
    padding: .95rem 1.2rem; border-radius: 8px; cursor: pointer; white-space: nowrap;
    transition: background .2s ease, color .2s ease;
  }
  .scsort__opt:hover { background: rgba(142,34,68,.06); color: #1A1A1A; }
  .scsort__opt.is-active { color: var(--seym-wine, #8E2244); }
  .scsort__native { position: absolute; width: 1px; height: 1px; opacity: 0; overflow: hidden; pointer-events: none; }
  @media (max-width: 749px) { .scsort__panel { min-width: 18rem; } }

  /* --- Grid: 3-column asymmetric cascade ---
     Each row stacks three smaller cards.
     The middle and right columns are pushed down so the
     row reads as a soft waterfall instead of a flat grid.
     Aspect ratios vary by column to break the visual rhythm
     (portrait / square / tall) — editorial, not catalog. */
  .seym-coll__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 3.6rem;
    row-gap: 6.4rem;
    align-items: start;
  }

  .seym-coll__item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 700ms cubic-bezier(0.22,1,0.36,1),
                transform 700ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-coll__item.visible { opacity: 1; transform: none; }

  /* Symmetric stagger — columns 1 & 3 match, middle offset */
  .seym-coll__item:nth-child(3n + 2) { margin-top: 4.8rem; }
  .seym-coll__item:nth-child(3n + 3) { margin-top: 0; }

  .seym-coll__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: transparent;
    isolation: isolate;
    color: inherit;
    text-decoration: none;
  }
  /* Aspect: columns 1 & 3 match (4/5), middle square */
  .seym-coll__item:nth-child(3n + 2) .seym-coll__media { aspect-ratio: 1 / 1; }
  .seym-coll__item:nth-child(3n + 3) .seym-coll__media { aspect-ratio: 4 / 5; }
  /* Uniform, aligned grid — remove the staggered offsets + mixed ratios so every
     product sits in the same row at the same 4/5 size (all breakpoints). */
  .seym-coll__item { margin-top: 0 !important; }
  .seym-coll__media { aspect-ratio: 4 / 5 !important; }

  /* Primary = cutout product, floats on ivory.
     Secondary = lifestyle, fills the card. */
  .seym-coll__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: opacity 700ms cubic-bezier(0.22,1,0.36,1),
                transform 1600ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-coll__img--primary   { object-fit: contain; }
  .seym-coll__img--secondary { object-fit: cover; opacity: 0; }
  .seym-coll__media:hover .seym-coll__img--primary  { opacity: 0; transform: scale(1.02); }
  .seym-coll__media:hover .seym-coll__img--secondary { opacity: 1; transform: scale(1.04); }

  /* Wine veil + overlay only appear when lifestyle is showing,
     so the default catalog state stays clean. */
  .seym-coll__media--has-lifestyle::after {
    content: '';
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg,
        rgba(26,26,26,0) 0%,
        rgba(26,26,26,0.18) 50%,
        rgba(142, 34, 68, 0.88) 100%);
    z-index: 1;
    opacity: 0;
    transition: opacity 500ms ease;
    pointer-events: none;
  }
  .seym-coll__media--has-lifestyle:hover::after { opacity: 1; }

  .seym-coll__overlay {
    position: absolute;
    z-index: 2;
    inset: auto 1.8rem 1.8rem 1.8rem;
    color: #F5F1EA;
    pointer-events: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 380ms ease 80ms, transform 500ms cubic-bezier(0.22,1,0.36,1) 80ms;
  }
  .seym-coll__media--has-lifestyle:hover .seym-coll__overlay {
    opacity: 1;
    transform: none;
  }
  .seym-coll__overlay-tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245,241,234,0.82);
    margin-bottom: 0.6rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(245,241,234,0.45);
  }
  .seym-coll__overlay-name {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 2vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.008em;
    color: #F5F1EA;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0,0,0,0.35);
  }
  .seym-coll__overlay-price {
    display: block;
    margin-top: 0.6rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    color: rgba(245,241,234,0.92);
  }

  .seym-coll__sold {
    position: absolute;
    top: 1.6rem;
    left: 1.6rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.7);
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(4px);
    padding: 0.5rem 0.9rem;
  }

  .seym-coll__info {
    margin-top: 1.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.7rem;
  }
  .seym-coll__vendor {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.5);
  }
  .seym-coll__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 2.1rem;
    line-height: 1.2;
    margin: 0;
    color: #1A1A1A;
    text-decoration: none;
    transition: color 220ms ease;
  }
  .seym-coll__name:hover { color: var(--seym-terracotta, #C54730); }
  .seym-coll__price {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    color: rgba(26,26,26,0.78);
    white-space: nowrap;
  }
  .seym-coll__price-compare {
    text-decoration: line-through;
    color: rgba(26,26,26,0.4);
    margin-right: 0.6rem;
  }
  .seym-coll__price-sale {
    color: var(--seym-orange, #FD4401);
  }

  /* --- Editorial passage between rows --- */
  .seym-coll__passage {
    grid-column: 1 / -1;
    max-width: 64ch;
    margin: 2rem auto 1rem;
    padding: 4rem 0;
    text-align: center;
    border-top: 1px solid rgba(26,26,26,0.1);
    border-bottom: 1px solid rgba(26,26,26,0.1);
  }
  .seym-coll__passage p {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.7rem, 1.8vw, 2.15rem);
    line-height: 1.55;
    color: rgba(26,26,26,0.85);
    margin: 0;
  }
  .seym-coll__passage p + p { margin-top: 1.2rem; }

  /* --- Empty state --- */
  .seym-coll__empty {
    text-align: center;
    padding: 8rem 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.8rem;
    color: rgba(26,26,26,0.55);
  }

  /* --- Pagination --- */
  .seym-coll__pagination {
    margin-top: 8rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .seym-coll__pagination a,
  .seym-coll__pagination span {
    color: #1A1A1A;
    text-decoration: none;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid transparent;
  }
  .seym-coll__pagination a:hover { border-bottom-color: #1A1A1A; }
  .seym-coll__pagination .seym-coll__pagination-current {
    color: var(--seym-wine, #8E2244);
    border-bottom-color: var(--seym-wine, #8E2244);
  }

  @media (max-width: 989px) {
    .seym-coll__wrap { padding: 0 2.4rem; }
    .seym-coll__intro { margin-bottom: 5rem; }
    .seym-coll__grid {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 2rem;
      row-gap: 4.8rem;
    }
    /* Reset the 3-col cascade rules on tablet/mobile, then apply
       a softer 2-col stagger so the asymmetric feel survives. */
    .seym-coll__item:nth-child(3n + 2),
    .seym-coll__item:nth-child(3n + 3) { margin-top: 0; }
    .seym-coll__item:nth-child(3n + 2) .seym-coll__media,
    .seym-coll__item:nth-child(3n + 3) .seym-coll__media { aspect-ratio: 4 / 5; }
    .seym-coll__item:nth-child(2n) { margin-top: 4rem; }
    .seym-coll__item:nth-child(2n) .seym-coll__media { aspect-ratio: 1 / 1; }
    .seym-coll__name { font-size: 1.85rem; }
    .seym-coll__info { align-items: center; gap: 0.5rem; }
    .seym-coll__passage { padding: 3rem 0; margin: 1rem auto; }
  }

  @media (max-width: 540px) {
    .seym-coll {
      padding: {{ section.settings.padding_top | divided_by: 1.6 | floor }}px 0
              {{ section.settings.padding_bottom | divided_by: 1.6 | floor }}px;
    }
    .seym-coll__grid {
      grid-template-columns: 1fr;
      row-gap: 4rem;
    }
    .seym-coll__item:nth-child(2n) { margin-top: 0; }
    .seym-coll__item:nth-child(2n) .seym-coll__media { aspect-ratio: 4 / 5; }
    .seym-coll__toolbar { margin-bottom: 3.6rem; }
  }
</style>

{%- liquid
  assign mf_eyebrow   = collection.metafields.custom.story_eyebrow
  assign mf_heading   = collection.metafields.custom.story_heading
  assign mf_intro     = collection.metafields.custom.story_intro
  assign mf_passage_1 = collection.metafields.custom.story_passage_1
  assign mf_passage_1_after_raw = collection.metafields.custom.story_passage_1_after
  assign mf_passage_2 = collection.metafields.custom.story_passage_2
  assign mf_passage_2_after_raw = collection.metafields.custom.story_passage_2_after

  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
  assign eyebrow_text = mf_eyebrow | default: section.settings.fallback_eyebrow
  assign heading_text = mf_heading | default: collection.title
  assign intro_text   = mf_intro   | default: section.settings.fallback_intro

  assign passage_1_text = mf_passage_1 | default: section.settings.fallback_passage_1
  assign passage_2_text = mf_passage_2 | default: section.settings.fallback_passage_2

  if mf_passage_1_after_raw != blank
    assign passage_1_after = mf_passage_1_after_raw | plus: 0
  else
    assign passage_1_after = section.settings.fallback_passage_1_after
  endif
  if mf_passage_2_after_raw != blank
    assign passage_2_after = mf_passage_2_after_raw | plus: 0
  else
    assign passage_2_after = section.settings.fallback_passage_2_after
  endif
-%}

<section class="seym-coll" id="SeymColl-{{ section.id }}">
  <div class="seym-coll__wrap">

    {%- paginate collection.products by section.settings.products_per_page -%}

      {%- if eyebrow_text != blank or heading_text != blank -%}
        <header class="seym-coll__hero">
          <div class="seym-coll__hero-lead">
            {%- if eyebrow_text != blank -%}
              <span class="seym-coll__eyebrow">{% if is_tr %}ATÖLYE{% else %}{{ eyebrow_text }}{% endif %}</span>
            {%- endif -%}
            {%- if heading_text != blank -%}
              <h1 class="seym-coll__heading">{{ heading_text }}</h1>
            {%- endif -%}
          </div>
          <div class="seym-coll__hero-meta">
            <div class="seym-coll__hero-count">
              <em>{{ collection.products_count }}</em>
              {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}
            </div>
          </div>
        </header>
      {%- endif -%}

      {%- if section.settings.enable_sorting -%}
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        {%- assign current_name = collection.sort_options.first.name -%}
        {%- for option in collection.sort_options -%}{%- if option.value == sort_by -%}{%- assign current_name = option.name -%}{%- endif -%}{%- endfor -%}
        <div class="seym-coll__toolbar">
          <form method="get" class="seym-coll__sort-form" id="SeymSortForm-{{ section.id }}">
            <span class="scsort__label">{{ 'products.facets.sort_button' | t }}</span>
            <div class="scsort" id="SeymSort-{{ section.id }}">
              <button type="button" class="scsort__btn" aria-haspopup="listbox" aria-expanded="false">
                <span class="scsort__current">{{ current_name | escape }}</span>
                <svg class="scsort__chev" viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <ul class="scsort__panel" role="listbox">
                {%- for option in collection.sort_options -%}
                  <li class="scsort__opt{% if option.value == sort_by %} is-active{% endif %}" role="option" data-value="{{ option.value | escape }}"{% if option.value == sort_by %} aria-selected="true"{% endif %}>{{ option.name | escape }}</li>
                {%- endfor -%}
              </ul>
            </div>
            <select name="sort_by" class="seym-coll__sort scsort__native" onchange="this.form.submit()" aria-label="Sort by">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name | escape }}</option>
              {%- endfor -%}
            </select>
          </form>
        </div>
        <noscript><style>#SeymSort-{{ section.id }}{display:none}#SeymSortForm-{{ section.id }} .scsort__native{position:static;width:auto;height:auto;opacity:1;overflow:visible;pointer-events:auto}</style></noscript>
        <script>
        (function(){
          var root=document.getElementById('SeymSort-{{ section.id }}'); if(!root) return;
          var form=document.getElementById('SeymSortForm-{{ section.id }}');
          var native=form && form.querySelector('.scsort__native');
          var btn=root.querySelector('.scsort__btn');
          btn.addEventListener('click', function(e){ e.stopPropagation(); var open=root.classList.toggle('is-open'); btn.setAttribute('aria-expanded', open?'true':'false'); });
          root.querySelectorAll('.scsort__opt').forEach(function(opt){
            opt.addEventListener('click', function(){
              var val=opt.getAttribute('data-value');
              if(native){ native.value=val; }
              if(form){ if(typeof form.requestSubmit==='function'){ form.requestSubmit(); } else { form.submit(); } }
            });
          });
          document.addEventListener('click', function(e){ if(!root.contains(e.target)){ root.classList.remove('is-open'); btn.setAttribute('aria-expanded','false'); } });
          document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ root.classList.remove('is-open'); btn.setAttribute('aria-expanded','false'); } });
        })();
        </script>
      {%- endif -%}

      {%- if collection.products.size == 0 -%}
        <div class="seym-coll__empty">No pieces in this collection — yet.</div>
      {%- else -%}
        {%- comment -%} Sold-out pieces always sink to the bottom, keeping the chosen sort within each group. {%- endcomment -%}
        {%- assign coll_in_stock = collection.products | where: 'available', true -%}
        {%- assign coll_out_stock = collection.products | where: 'available', false -%}
        {%- assign coll_ordered = coll_in_stock | concat: coll_out_stock -%}
        <div class="seym-coll__grid">
          {%- for product in coll_ordered -%}
            {%- assign idx = forloop.index -%}

            <article class="seym-coll__item">
              {%- assign primary = product.featured_media -%}
              {%- assign secondary = product.media[1] -%}
              <a class="seym-coll__media{% if secondary != blank %} seym-coll__media--has-lifestyle{% endif %}"
                 href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                {%- if primary != blank -%}
                  {{ primary
                     | image_url: width: 1200
                     | image_tag:
                       class: 'seym-coll__img--primary',
                       loading: 'lazy',
                       widths: '300, 450, 600, 800, 1100, 1400',
                       sizes: '(max-width: 540px) 92vw, (max-width: 989px) 44vw, 28vw',
                       alt: product.title | escape }}
                {%- endif -%}
                {%- if secondary != blank -%}
                  {{ secondary
                     | image_url: width: 1400
                     | image_tag:
                       class: 'seym-coll__img--secondary',
                       loading: 'lazy',
                       widths: '400, 600, 800, 1100, 1400, 1800',
                       sizes: '(max-width: 540px) 92vw, (max-width: 989px) 44vw, 28vw',
                       alt: product.title | escape }}
                  <div class="seym-coll__overlay">
                    <span class="seym-coll__overlay-tag">{{ 'sections.seym.in_your_space' | t }}</span>
                    <span class="seym-coll__overlay-name">{{ product.title }}</span>
                    <span class="seym-coll__overlay-price">
                      {% render 'seym-money', amount: product.price %}
                    </span>
                  </div>
                {%- endif -%}
                {%- unless product.available -%}
                  <span class="seym-coll__sold">{{ 'sections.seym.sold' | t }}</span>
                {%- endunless -%}
              </a>
              <div class="seym-coll__info">
                {%- if product.vendor != blank and product.vendor != shop.name -%}
                  <span class="seym-coll__vendor">{{ product.vendor }}</span>
                {%- endif -%}
                <h3 style="margin:0">
                  <a class="seym-coll__name" href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <div class="seym-coll__price">
                  {%- if product.compare_at_price > product.price -%}
                    {% render 'seym-money', amount: product.compare_at_price, class: 'seym-coll__price-compare' %}
                    {% render 'seym-money', amount: product.price, class: 'seym-coll__price-sale' %}
                  {%- else -%}
                    {% render 'seym-money', amount: product.price %}
                  {%- endif -%}
                </div>
              </div>
            </article>

            {%- if passage_1_text != blank and idx == passage_1_after -%}
              <aside class="seym-coll__passage">{{ passage_1_text }}</aside>
            {%- endif -%}
            {%- if passage_2_text != blank and idx == passage_2_after -%}
              <aside class="seym-coll__passage">{{ passage_2_text }}</aside>
            {%- endif -%}

          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="seym-coll__pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">‹ Prev</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="seym-coll__pagination-current">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">Next ›</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endif -%}

    {%- endpaginate -%}
  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('#SeymColl-{{ section.id }} .seym-coll__item');
  if (!items.length || !('IntersectionObserver' in window)) {
    items.forEach(function (i) { i.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.style.transitionDelay = ((e.target.dataset.delay || 0) + 'ms');
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function (el, i) {
    el.dataset.delay = (i % 2) * 80;
    obs.observe(el);
  });
})();
</script>

{% schema %}
