      "label": "Intro alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Passage fallbacks (between rows)"
    },
    {
      "type": "richtext",
      "id": "fallback_passage_1",
      "label": "Passage 1 fallback"
    },
    {
      "type": "range",
