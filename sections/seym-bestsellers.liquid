{%- comment -%}
  Seym Bestsellers — renders products with the SAME card component the
  collection pages use (snippet 'card-product'), so the homepage grid looks
  identical to /collections/all. Calm ivory frame, spec heading + rhythm.
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .sbs {
    background: var(--seym-ivory, #F5F1EA);
    padding: clamp(7rem, 11vh, 11rem) 0;
  }
  #shopify-section-{{ section.id }} .sbs__wrap {
    max-width: 150rem;
    margin: 0 auto;
    padding: 0 4.8rem;
  }
  #shopify-section-{{ section.id }} .sbs__hd {
    text-align: center;
    margin-bottom: clamp(3.6rem, 6vh, 5.6rem);
  }
  #shopify-section-{{ section.id }} .sbs__ey {
    font: 300 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    margin: 0 0 1.2rem;
  }
  #shopify-section-{{ section.id }} .sbs__h {
    font: 300 clamp(2.8rem, 5vw, 5.2rem)/1.02 'Cormorant Garamond', serif;
    letter-spacing: -0.01em;
    color: var(--seym-ink, #0D0D0D);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .sbs__grid { margin: 0; }
  #shopify-section-{{ section.id }} .sbs__cta {
    text-align: center;
    margin-top: clamp(3rem, 5vh, 4.8rem);
  }
  #shopify-section-{{ section.id }} .sbs__cta a {
    position: relative;
    font: 300 0.72rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--seym-ink, #0D0D0D);
    text-decoration: none;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(13,13,13,0.25);
    transition: border-color .4s cubic-bezier(0.22,1,0.36,1), color .4s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sbs__cta a:hover { color: var(--seym-wine, #8E2244); border-color: var(--seym-wine, #8E2244); }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sbs { padding: clamp(4.5rem, 9vh, 6rem) 0; }
    #shopify-section-{{ section.id }} .sbs__wrap { padding: 0 2rem; }
  }
</style>

<section class="sbs" data-reveal>
  <div class="sbs__wrap">
    <header class="sbs__hd">
      {%- if section.settings.eyebrow != blank -%}<p class="sbs__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sbs__h">{{ section.settings.heading }}</h2>{%- endif -%}
    </header>

    {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      <ul class="sbs__grid grid product-grid grid--{{ section.settings.columns }}-col-desktop grid--2-col-tablet-down"
          role="list">
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <li class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}data-cascade style="--animation-order: {{ forloop.index }};"{% endif %}>
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: 'default',
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              show_quick_add: false,
              section_id: section.id
            %}
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.cta_label != blank -%}
        {%- assign coll_url = section.settings.collection.url | default: routes.all_products_collection_url -%}
        <div class="sbs__cta">
          <a href="{{ coll_url }}">{{ section.settings.cta_label }}</a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Notre Sélection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    {
      "type": "select", "id": "image_ratio", "label": "Image ratio", "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ]
    },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Show second image on hover", "default": true },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "View all" }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
