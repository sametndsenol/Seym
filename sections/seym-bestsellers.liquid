{%- comment -%}
  Seym Bestsellers — horizontal scroller. Always 4 cards in view (desktop),
  8 products total, swipe / arrow to reveal the rest. Uses the same
  'card-product' component as the collection pages so the look matches.
{%- endcomment -%}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .sbs { background: var(--seym-ivory, #fcfbf9); padding: clamp(6rem,10vh,9rem) 0; }
  #shopify-section-{{ section.id }} .sbs__wrap { max-width: 156rem; margin: 0 auto; padding: 0 4.8rem; }
  #shopify-section-{{ section.id }} .sbs__hd {
    display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem;
    margin-bottom: clamp(2.6rem,4vh,3.6rem);
  }
  #shopify-section-{{ section.id }} .sbs__ey {
    font: 300 0.7rem/1 'Inter',sans-serif; letter-spacing: .32em; text-transform: uppercase;
    color: rgba(13,13,13,.55); margin: 0 0 1rem;
  }
  #shopify-section-{{ section.id }} .sbs__h {
    font: 300 clamp(2.6rem,4.4vw,4.6rem)/1.02 'Cormorant Garamond',serif; letter-spacing: -0.01em;
    color: var(--seym-ink,#1a1a1a); margin: 0;
  }
  /* arrows */
  #shopify-section-{{ section.id }} .sbs__nav { display: flex; gap: .8rem; flex-shrink: 0; }
  #shopify-section-{{ section.id }} .sbs__arrow {
    width: 4.4rem; height: 4.4rem; border-radius: 999px; border: 1px solid rgba(13,13,13,.18);
    background: transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    color: var(--seym-ink,#1a1a1a); transition: background .35s ease, color .35s ease, border-color .35s ease, opacity .35s ease;
  }
  #shopify-section-{{ section.id }} .sbs__arrow:hover { background: #8E2244; border-color: #8E2244; color: #fff; }
  #shopify-section-{{ section.id }} .sbs__arrow svg { width: 1.7rem; height: 1.7rem; stroke: currentColor; fill: none; stroke-width: 1.4; }
  #shopify-section-{{ section.id }} .sbs__arrow[disabled] { opacity: .3; cursor: default; }
  #shopify-section-{{ section.id }} .sbs__arrow[disabled]:hover { background: transparent; color: var(--seym-ink,#1a1a1a); border-color: rgba(13,13,13,.18); }

  #shopify-section-{{ section.id }} .sbs__track {
    --gap: 2.4rem;
    display: flex; gap: var(--gap); overflow-x: auto; scroll-snap-type: x mandatory;
    scroll-behavior: smooth; -webkit-overflow-scrolling: touch; padding-bottom: .5rem;
    scrollbar-width: none;
  }
  #shopify-section-{{ section.id }} .sbs__track::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .sbs__item {
    flex: 0 0 calc((100% - 3 * var(--gap)) / 4); scroll-snap-align: start;
  }
  #shopify-section-{{ section.id }} .sbs__item .card-wrapper { height: 100%; }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .sbs__track { --gap: 1.6rem; }
    #shopify-section-{{ section.id }} .sbs__item { flex-basis: calc((100% - 2 * var(--gap)) / 2.4); }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sbs { padding: clamp(4rem,8vh,5.5rem) 0; }
    #shopify-section-{{ section.id }} .sbs__wrap { padding: 0 2rem; }
    #shopify-section-{{ section.id }} .sbs__item { flex-basis: calc((100% - 1 * var(--gap)) / 1.5); }
    #shopify-section-{{ section.id }} .sbs__nav { display: none; }
  }
</style>

<section class="sbs" data-reveal>
  <div class="sbs__wrap">
    <header class="sbs__hd">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="sbs__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="sbs__h">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      <div class="sbs__nav">
        <button class="sbs__arrow" data-dir="-1" aria-label="Previous"><svg viewBox="0 0 24 24"><polyline points="15 5 8 12 15 19"/></svg></button>
        <button class="sbs__arrow" data-dir="1" aria-label="Next"><svg viewBox="0 0 24 24"><polyline points="9 5 16 12 9 19"/></svg></button>
      </div>
    </header>

    {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      <div class="sbs__track" id="sbsTrack-{{ section.id }}">
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <div class="sbs__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: 'default',
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: false, show_rating: false, lazy_load: true,
              show_quick_add: false, section_id: section.id
            %}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function(){
  var track=document.getElementById('sbsTrack-{{ section.id }}');
  if(!track) return;
  var sec=document.getElementById('shopify-section-{{ section.id }}');
  var btns=sec.querySelectorAll('.sbs__arrow');
  function step(){var it=track.querySelector('.sbs__item');if(!it)return track.clientWidth*0.8;var g=parseFloat(getComputedStyle(track).gap)||0;return it.getBoundingClientRect().width+g;}
  function upd(){var max=track.scrollWidth-track.clientWidth-2;btns[0].disabled=track.scrollLeft<=2;btns[1].disabled=track.scrollLeft>=max;}
  btns.forEach(function(b){b.addEventListener('click',function(){track.scrollBy({left:step()*parseInt(b.dataset.dir,10),behavior:'smooth'});});});
  track.addEventListener('scroll',function(){requestAnimationFrame(upd);},{passive:true});
  window.addEventListener('resize',upd); upd();
})();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Notre Sélection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Bestsellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 4, "max": 16, "step": 1, "default": 8 },
    {
      "type": "select", "id": "image_ratio", "label": "Image ratio", "default": "adapt",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ]
    },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Show second image on hover", "default": true }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
