{%- comment -%}
  Seym Bestsellers — calm ivory product grid. Cormorant titles, Inter prices,
  consistent aspect ratio, second-image swap on hover, restrained "View" affordance.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .sbs {
    background: var(--seym-ivory, #F5F1EA);
    padding: clamp(7rem, 11vh, 11rem) 0;
  }
  #shopify-section-{{ section.id }} .sbs__wrap {
    max-width: 150rem;
    margin: 0 auto;
    padding: 0 4.8rem;
  }
  #shopify-section-{{ section.id }} .sbs__hd {
    text-align: center;
    margin-bottom: clamp(3.6rem, 6vh, 5.6rem);
  }
  #shopify-section-{{ section.id }} .sbs__ey {
    font: 300 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    margin: 0 0 1.2rem;
  }
  #shopify-section-{{ section.id }} .sbs__h {
    font: 300 clamp(2.8rem, 5vw, 5.2rem)/1.02 'Cormorant Garamond', serif;
    letter-spacing: -0.01em;
    color: var(--seym-ink, #0D0D0D);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .sbs__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3.2rem 2.4rem;
  }
  #shopify-section-{{ section.id }} .sbs__item {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .sbs__img {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--seym-ivory-2, #FAFAF7);
    overflow: hidden;
    margin-bottom: 1.6rem;
  }
  #shopify-section-{{ section.id }} .sbs__img::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(13,13,13,0.08);
    pointer-events: none;
    z-index: 3;
  }
  #shopify-section-{{ section.id }} .sbs__img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 11%;
    transition: transform 1.1s cubic-bezier(0.22,1,0.36,1), opacity .6s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sbs__img .sbs__img--alt {
    opacity: 0;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .sbs__item:hover .sbs__img--alt { opacity: 1; }
  /* single-image cards: scale the primary on hover */
  #shopify-section-{{ section.id }} .sbs__item:hover .sbs__img--solo { transform: scale(1.04); }
  /* two-image cards: keep base steady, gently scale incoming */
  #shopify-section-{{ section.id }} .sbs__item:hover .sbs__img--alt { transform: scale(1.04); }

  #shopify-section-{{ section.id }} .sbs__view {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 4;
    text-align: center;
    padding: 1.1rem 0;
    font: 300 0.62rem/1 'Inter', sans-serif;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--seym-ink, #0D0D0D);
    background: rgba(250,250,247,0.86);
    backdrop-filter: blur(2px);
    opacity: 0;
    transform: translateY(100%);
    transition: opacity .45s cubic-bezier(0.22,1,0.36,1), transform .45s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sbs__item:hover .sbs__view { opacity: 1; transform: translateY(0); }

  #shopify-section-{{ section.id }} .sbs__tag {
    display: block;
    font: 300 0.6rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 0.6rem;
  }
  #shopify-section-{{ section.id }} .sbs__name {
    font: 400 1.5rem/1.2 'Cormorant Garamond', serif;
    color: var(--seym-ink, #0D0D0D);
    margin: 0 0 0.45rem;
  }
  #shopify-section-{{ section.id }} .sbs__price {
    font: 300 0.95rem/1 'Inter', sans-serif;
    color: rgba(13,13,13,0.55);
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .sbs__track { grid-template-columns: repeat(2, 1fr); gap: 2.8rem 2rem; }
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sbs { padding: clamp(4.5rem, 9vh, 6rem) 0; }
    #shopify-section-{{ section.id }} .sbs__wrap { padding: 0 2rem; }
    #shopify-section-{{ section.id }} .sbs__track { gap: 2.4rem 1.6rem; }
    #shopify-section-{{ section.id }} .sbs__name { font-size: 1.35rem; }
    /* touch devices: keep the View bar visible-on-tap simple — show statically */
    #shopify-section-{{ section.id }} .sbs__view { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .sbs__img img,
    #shopify-section-{{ section.id }} .sbs__view { transition: none; }
    #shopify-section-{{ section.id }} .sbs__item:hover .sbs__img--solo,
    #shopify-section-{{ section.id }} .sbs__item:hover .sbs__img--alt { transform: none; }
  }
</style>

<section class="sbs" data-reveal>
  <div class="sbs__wrap">
    <header class="sbs__hd">
      {%- if section.settings.eyebrow != blank -%}<p class="sbs__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sbs__h">{{ section.settings.heading }}</h2>{%- endif -%}
    </header>

    {%- if section.settings.collection != blank -%}
      <div class="sbs__row">
        <div class="sbs__track" data-reveal-child>
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            {%- assign second_image = product.images[1] -%}
            <a class="sbs__item" href="{{ product.url }}">
              <div class="sbs__img">
                {%- if product.featured_image != blank -%}
                  {%- if second_image != blank -%}
                    {{ product.featured_image | image_url: width: 800 | image_tag:
                       loading: 'lazy', widths: '300,500,700',
                       sizes: '(max-width:749px) 50vw, 24vw',
                       alt: product.title, class: 'sbs__img--base' }}
                    {{ second_image | image_url: width: 800 | image_tag:
                       loading: 'lazy', widths: '300,500,700',
                       sizes: '(max-width:749px) 50vw, 24vw',
                       alt: product.title, class: 'sbs__img--alt' }}
                  {%- else -%}
                    {{ product.featured_image | image_url: width: 800 | image_tag:
                       loading: 'lazy', widths: '300,500,700',
                       sizes: '(max-width:749px) 50vw, 24vw',
                       alt: product.title, class: 'sbs__img--solo' }}
                  {%- endif -%}
                {%- endif -%}
                {%- if section.settings.view_label != blank -%}
                  <span class="sbs__view">{{ section.settings.view_label }}</span>
                {%- endif -%}
              </div>
              {%- if product.collections.first != blank -%}
                <span class="sbs__tag">{{ product.collections.first.title }}</span>
              {%- endif -%}
              <h3 class="sbs__name">{{ product.title }}</h3>
              <span class="sbs__price">{{ product.price | money }}</span>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Notre Sélection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "view_label", "label": "Hover affordance label", "default": "View" }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
