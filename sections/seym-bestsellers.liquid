{%- comment -%}
  Seym Best Sellers — Daum-style clean product grid on white.
  Products float on white background, collection tag + name + price.
{%- endcomment -%}

<style>
  .seym-bs {
    background: #fff;
    padding: 80px 0 96px;
  }
  .seym-bs__wrap { max-width: 132rem; margin: 0 auto; padding: 0 4rem; }
  .seym-bs__header {
    text-align: center;
    margin-bottom: 4.8rem;
  }
  .seym-bs__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.45);
    margin: 0 0 1rem;
  }
  .seym-bs__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: #1A1A1A;
    margin: 0;
    font-style: italic;
  }
  .seym-bs__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .seym-bs__item {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .seym-bs__img {
    position: relative;
    aspect-ratio: 4 / 5;
    background: #f7f7f5;
    overflow: hidden;
    margin-bottom: 1.6rem;
  }
  .seym-bs__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8%;
    transition: transform 800ms cubic-bezier(0.22,1,0.36,1);
  }
  .seym-bs__item:hover .seym-bs__img img { transform: scale(1.05); }
  .seym-bs__tag {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 0.4rem;
  }
  .seym-bs__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.2;
    color: #1A1A1A;
    margin: 0 0 0.4rem;
    transition: color 220ms ease;
  }
  .seym-bs__item:hover .seym-bs__name { color: var(--seym-wine, #8E2244); }
  .seym-bs__price {
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
    color: rgba(26,26,26,0.6);
  }
  .seym-bs__nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 4rem;
  }
  .seym-bs__nav-btn {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(26,26,26,0.15);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 220ms ease;
    color: #1A1A1A;
  }
  .seym-bs__nav-btn:hover { border-color: #1A1A1A; }
  .seym-bs__nav-btn svg { width: 1.2rem; height: 1.2rem; }

  @media (max-width: 989px) {
    .seym-bs__grid { grid-template-columns: repeat(2, 1fr); gap: 1.6rem; }
    .seym-bs { padding: 56px 0 64px; }
  }
  @media (max-width: 749px) {
    .seym-bs__wrap { padding: 0 2rem; }
    .seym-bs__grid { gap: 1.2rem; }
  }
</style>

<section class="seym-bs">
  <div class="seym-bs__wrap">
    <header class="seym-bs__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="seym-bs__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="seym-bs__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </header>

    {%- if section.settings.collection != blank -%}
      <div class="seym-bs__grid">
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <a class="seym-bs__item" href="{{ product.url }}">
            <div class="seym-bs__img">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag:
                   loading: 'lazy', widths: '300,500,700,900',
                   sizes: '(max-width: 749px) 50vw, 25vw',
                   alt: product.title }}
              {%- endif -%}
            </div>
            {%- if product.collections.first != blank -%}
              <span class="seym-bs__tag">{{ product.collections.first.title }}</span>
            {%- endif -%}
            <h3 class="seym-bs__name">{{ product.title }}</h3>
            <span class="seym-bs__price">{{ product.price | money }}</span>
          </a>
        {%- endfor -%}
      </div>

      <div class="seym-bs__nav">
        <button class="seym-bs__nav-btn" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none"><path d="M15 19L8 12L15 5" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
        <button class="seym-bs__nav-btn" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none"><path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Selection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
