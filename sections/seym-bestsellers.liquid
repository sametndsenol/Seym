{%- comment -%}
  Daum Bestsellers — clean white grid, products float on light bg.
  Eyebrow + italic heading centered. 4 products. Nav arrows at sides.
{%- endcomment -%}

<style>
  .sbs {
    background: #fff;
    padding: 72px 0 80px;
  }
  .sbs__wrap { max-width: 128rem; margin: 0 auto; padding: 0 4rem; }
  .sbs__hd { text-align: center; margin-bottom: 4.4rem; }
  .sbs__ey {
    font: 300 0.68rem/1 'Inter', sans-serif;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.4);
    margin: 0 0 0.8rem;
  }
  .sbs__h {
    font: 300 clamp(2.4rem,3.6vw,3.8rem)/1.05 'Cormorant Garamond', serif;
    font-style: italic;
    letter-spacing: -0.01em;
    color: #1A1A1A;
    margin: 0;
  }

  .sbs__row {
    position: relative;
  }
  .sbs__track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.4rem;
  }
  .sbs__item {
    text-decoration: none;
    color: inherit;
  }
  .sbs__img {
    aspect-ratio: 4 / 5;
    background: #f5f5f3;
    overflow: hidden;
    margin-bottom: 1.4rem;
    position: relative;
  }
  .sbs__img img {
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 10%;
    transition: transform .8s cubic-bezier(0.22,1,0.36,1);
  }
  .sbs__item:hover .sbs__img img { transform: scale(1.06); }
  .sbs__tag {
    display: block;
    font: 400 0.6rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 0.35rem;
  }
  .sbs__name {
    font: 400 1.3rem/1.25 'Cormorant Garamond', serif;
    color: #1A1A1A;
    margin: 0 0 0.3rem;
  }
  .sbs__price {
    font: 300 0.85rem/1 'Inter', sans-serif;
    color: rgba(26,26,26,0.5);
  }

  .sbs__nav {
    position: absolute;
    top: 35%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
    padding: 0;
  }
  .sbs__arr {
    pointer-events: auto;
    width: 44px; height: 44px;
    border: 1px solid rgba(26,26,26,0.15);
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: border-color .2s;
    color: #1A1A1A;
  }
  .sbs__arr:hover { border-color: #1A1A1A; }
  .sbs__arr svg { width: 1rem; height: 1rem; }
  .sbs__arr--l { margin-left: -20px; }
  .sbs__arr--r { margin-right: -20px; }

  @media(max-width:989px){
    .sbs__track { grid-template-columns: repeat(2, 1fr); gap: 1.6rem; }
    .sbs { padding: 56px 0 64px; }
    .sbs__nav { display: none; }
  }
  @media(max-width:749px){
    .sbs__wrap { padding: 0 2rem; }
    .sbs__track { gap: 1.2rem; }
  }
</style>

<section class="sbs" data-reveal>
  <div class="sbs__wrap">
    <header class="sbs__hd">
      {%- if section.settings.eyebrow != blank -%}<p class="sbs__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sbs__h">{{ section.settings.heading }}</h2>{%- endif -%}
    </header>

    {%- if section.settings.collection != blank -%}
      <div class="sbs__row">
        <div class="sbs__track" data-reveal-child>
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            <a class="sbs__item" href="{{ product.url }}">
              <div class="sbs__img">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 800 | image_tag:
                     loading: 'lazy', widths: '300,500,700',
                     sizes: '(max-width:749px) 50vw, 25vw',
                     alt: product.title }}
                {%- endif -%}
              </div>
              {%- if product.collections.first != blank -%}
                <span class="sbs__tag">{{ product.collections.first.title }}</span>
              {%- endif -%}
              <h3 class="sbs__name">{{ product.title }}</h3>
              <span class="sbs__price">{{ product.price | money }}</span>
            </a>
          {%- endfor -%}
        </div>
        <div class="sbs__nav">
          <button class="sbs__arr sbs__arr--l" aria-label="Previous"><svg viewBox="0 0 24 24" fill="none"><path d="M15 19L8 12L15 5" stroke="currentColor" stroke-width="1.5"/></svg></button>
          <button class="sbs__arr sbs__arr--r" aria-label="Next"><svg viewBox="0 0 24 24" fill="none"><path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.5"/></svg></button>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Notre Sélection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "OUR BESTSELLERS" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
