{%- comment -%}
  Gift Banner — two modes:
   • Text-overlay mode: fixed-height cropped image + ivory scrim + editorial copy.
   • Plain mode (show_text=false): finished self-contained banner image shown
     WHOLE (uncropped), no scrim/overlay, the entire image is the link.
{%- endcomment -%}

{%- liquid
  assign is_tr = false
  if localization.language.iso_code == 'tr'
    assign is_tr = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} .sgb {
    position: relative;
    width: 100%;
    height: clamp(28rem, 50vh, 44rem);
    overflow: hidden;
    background: var(--seym-ivory, #F5F1EA);
  }
  #shopify-section-{{ section.id }} .sgb__media {
    position: absolute;
    inset: 0;
  }
  #shopify-section-{{ section.id }} .sgb__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.1s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sgb:hover .sgb__media img { transform: scale(1.04); }

  /* ---- Plain mode — big finished banner: whole & uncropped, SOFT rounded
       edges, mor glow, the whole image is the link. Sits on the same warm
       paper band as the Press section directly above. ---- */
  #shopify-section-{{ section.id }} .sgb--plain {
    height: auto;
    overflow: visible;
    background: var(--seym-warm, #f3efe8);
    padding: clamp(3.5rem, 7vh, 7rem) 4.8rem clamp(5rem, 9vh, 8rem);
    display: flex;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .sgb--plain .sgb__media {
    position: static;
    inset: auto;
    display: block;
    width: 100%;
    max-width: 88rem;
    line-height: 0;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 40px 80px -42px rgba(142,34,68,.42), 0 16px 40px -32px rgba(0,0,0,.24);
    transition: transform .9s cubic-bezier(0.22,1,0.36,1), box-shadow .9s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sgb--plain .sgb__media img {
    width: 100%;
    height: auto;
    object-fit: initial;
    border-radius: 18px;
  }
  #shopify-section-{{ section.id }} .sgb--plain a.sgb__media { cursor: pointer; }
  #shopify-section-{{ section.id }} .sgb--plain:hover .sgb__media {
    transform: translateY(-6px);
    box-shadow: 0 52px 96px -42px rgba(142,34,68,.52), 0 20px 46px -32px rgba(0,0,0,.28);
  }

  /* ---- Text-overlay mode ---- */
  #shopify-section-{{ section.id }} .sgb__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right,
        rgba(245,241,234,0.94) 0%,
        rgba(245,241,234,0.72) 32%,
        rgba(245,241,234,0.22) 58%,
        transparent 78%);
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .sgb__txt {
    position: absolute;
    z-index: 2;
    top: 0; bottom: 0; left: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(4rem, 8vh, 7rem) clamp(2rem, 6vw, 7rem);
    max-width: 46rem;
  }
  #shopify-section-{{ section.id }} .sgb__ey {
    font: 300 0.78rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(13,13,13,0.55);
    margin: 0 0 1.4rem;
  }
  #shopify-section-{{ section.id }} .sgb__h {
    font: 300 clamp(3.6rem, 8vw, 7rem)/0.96 'Cormorant Garamond', serif;
    font-style: italic;
    letter-spacing: -0.01em;
    color: var(--seym-ink, #0D0D0D);
    margin: 0 0 2rem;
  }
  #shopify-section-{{ section.id }} .sgb__cta {
    position: relative;
    font: 300 0.78rem/1 'Inter', sans-serif;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--seym-ink, #0D0D0D);
    text-decoration: none;
    padding-bottom: 0.55rem;
    align-self: flex-start;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color .35s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sgb__cta::after {
    content: "";
    position: absolute;
    left: 0; bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--seym-wine, #8E2244);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .5s cubic-bezier(0.22,1,0.36,1);
  }
  #shopify-section-{{ section.id }} .sgb__cta::before {
    content: "";
    position: absolute;
    left: 0; bottom: 0;
    width: 100%;
    height: 1px;
    background: rgba(13,13,13,0.12);
  }
  #shopify-section-{{ section.id }} .sgb__cta:hover { color: var(--seym-wine, #8E2244); }
  #shopify-section-{{ section.id }} .sgb__cta:hover::after { transform: scaleX(1); }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .sgb { height: clamp(24rem, 60vh, 36rem); }
    #shopify-section-{{ section.id }} .sgb--plain { padding: clamp(4.5rem, 9vh, 6rem) 2rem; }
    #shopify-section-{{ section.id }} .sgb__txt {
      top: 0; bottom: auto; left: 0; right: 0;
      justify-content: flex-start;
      padding: 3rem 2rem 0;
      max-width: none;
    }
    #shopify-section-{{ section.id }} .sgb__scrim {
      background:
        linear-gradient(to bottom,
          rgba(245,241,234,0.92) 0%,
          rgba(245,241,234,0.62) 50%,
          transparent 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .sgb__media img,
    #shopify-section-{{ section.id }} .sgb__cta,
    #shopify-section-{{ section.id }} .sgb__cta::after { transition: none; }
    #shopify-section-{{ section.id }} .sgb:hover .sgb__media img,
    #shopify-section-{{ section.id }} .sgb--plain:hover .sgb__media img { transform: none; }
  }
</style>

{%- liquid
  assign plain = false
  if section.settings.show_text == false
    assign plain = true
  endif
-%}
{%- capture media -%}
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
       loading: 'lazy', widths: '600,1000,1400,2000', sizes: '100vw',
       alt: section.settings.heading | default: 'Gift' }}
  {%- endif -%}
{%- endcapture -%}

<section class="sgb{% if plain %} sgb--plain{% endif %}" data-reveal>
  {%- if plain -%}
    {%- if section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="sgb__media" aria-label="{{ section.settings.cta_label | default: section.settings.heading | default: 'Gift' }}">{{ media }}</a>
    {%- else -%}
      <div class="sgb__media">{{ media }}</div>
    {%- endif -%}
  {%- else -%}
    <div class="sgb__media">{{ media }}</div>
    <div class="sgb__scrim"></div>
    <div class="sgb__txt">
      {%- if section.settings.eyebrow != blank -%}<p class="sgb__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sgb__h">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="sgb__cta">{% if is_tr %}Seçkiyi keşfet{% else %}{{ section.settings.cta_label }}{% endif %} →</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "show_text", "label": "Show text overlay", "info": "Turn off when the image already has its own text/CTA baked in — the whole banner becomes a clickable, full (uncropped) image.", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find the ideal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "GIFT" },
    { "type": "text", "id": "cta_label", "label": "CTA", "default": "Discover the selection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Gift Banner" }]
}
{% endschema %}
