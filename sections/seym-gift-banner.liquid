{%- comment -%}
  Gift Banner — fixed-height image with strong readable text overlay.
{%- endcomment -%}

<style>
  .sgb {
    position: relative;
    width: 100%;
    height: clamp(28rem, 50vh, 44rem);
    overflow: hidden;
  }
  .sgb__media {
    position: absolute;
    inset: 0;
  }
  .sgb__media img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Plain mode — the image is a finished, self-contained banner
     (text/CTA baked in). Show it whole, no crop, no scrim, no overlay;
     the whole banner is the link. */
  .sgb--plain { height: auto; overflow: visible; }
  .sgb--plain .sgb__media { position: static; inset: auto; display: block; }
  .sgb--plain .sgb__media img { height: auto; object-fit: initial; }
  .sgb--plain a.sgb__media { cursor: pointer; }
  .sgb__scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right,
        rgba(245,241,234,0.92) 0%,
        rgba(245,241,234,0.7) 30%,
        rgba(245,241,234,0.2) 55%,
        transparent 75%);
    z-index: 1;
  }
  .sgb__txt {
    position: absolute;
    z-index: 2;
    top: 0; bottom: 0; left: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 6rem;
    max-width: 40rem;
  }
  .sgb__ey {
    font: 300 0.7rem/1 'Inter', sans-serif;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.5);
    margin: 0 0 1rem;
  }
  .sgb__h {
    font: 300 clamp(5rem, 10vw, 9rem)/0.88 'Cormorant Garamond', serif;
    font-style: italic;
    color: #1A1A1A;
    margin: 0 0 1.8rem;
    text-shadow: 0 1px 2px rgba(255,255,255,0.3);
  }
  .sgb__cta {
    font: 400 0.72rem/1 'Inter', sans-serif;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    border-bottom: 1px solid rgba(26,26,26,0.4);
    padding-bottom: 0.4rem;
    align-self: flex-start;
    transition: color .2s, border-color .2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .sgb__cta:hover {
    color: var(--seym-wine, #8E2244);
    border-color: var(--seym-wine, #8E2244);
  }

  @media(max-width:749px) {
    .sgb { height: clamp(24rem, 60vh, 36rem); }
    .sgb__txt { padding: 2.4rem; max-width: none; }
    .sgb__scrim {
      background:
        linear-gradient(to bottom,
          rgba(245,241,234,0.9) 0%,
          rgba(245,241,234,0.6) 50%,
          transparent 100%);
    }
    .sgb__txt {
      top: 0; bottom: auto; left: 0; right: 0;
      justify-content: flex-start;
      padding-top: 3rem;
    }
  }
</style>

{%- liquid
  assign plain = false
  if section.settings.show_text == false
    assign plain = true
  endif
-%}
{%- capture media -%}
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
       loading: 'lazy', widths: '600,1000,1400,2000', sizes: '100vw' }}
  {%- endif -%}
{%- endcapture -%}

<section class="sgb{% if plain %} sgb--plain{% endif %}" data-reveal>
  {%- if plain -%}
    {%- if section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="sgb__media" aria-label="{{ section.settings.cta_label | default: section.settings.heading | default: 'Gift' }}">{{ media }}</a>
    {%- else -%}
      <div class="sgb__media">{{ media }}</div>
    {%- endif -%}
  {%- else -%}
    <div class="sgb__media">{{ media }}</div>
    <div class="sgb__scrim"></div>
    <div class="sgb__txt">
      {%- if section.settings.eyebrow != blank -%}<p class="sgb__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="sgb__h">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="sgb__cta">{{ section.settings.cta_label }} →</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "show_text", "label": "Show text overlay", "info": "Turn off when the image already has its own text/CTA baked in — the whole banner becomes a clickable, full (uncropped) image.", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find the ideal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "GIFT" },
    { "type": "text", "id": "cta_label", "label": "CTA", "default": "Discover the selection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Gift Banner" }]
}
{% endschema %}
