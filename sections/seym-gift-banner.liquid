{%- comment -%}
  Seym Gift Banner — full-width lifestyle image with text overlay CTA.
{%- endcomment -%}

<style>
  .seym-gb {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .seym-gb__media {
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
  }
  .seym-gb__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.4s cubic-bezier(0.22,1,0.36,1);
  }
  .seym-gb:hover .seym-gb__media img { transform: scale(1.03); }
  .seym-gb__content {
    position: absolute;
    z-index: 2;
    top: 0;
    left: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 6rem;
    max-width: 42rem;
  }
  .seym-gb__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.45);
    margin: 0 0 1rem;
  }
  .seym-gb__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(4rem, 7vw, 9rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: #1A1A1A;
    margin: 0 0 2rem;
    font-style: italic;
  }
  .seym-gb__cta {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    border-bottom: 1px solid #1A1A1A;
    padding-bottom: 0.4rem;
    transition: color 220ms ease, border-color 220ms ease;
    align-self: flex-start;
    min-height: 44px;
  }
  .seym-gb__cta:hover {
    color: var(--seym-wine, #8E2244);
    border-color: var(--seym-wine, #8E2244);
  }

  @media (max-width: 989px) {
    .seym-gb__media { aspect-ratio: 16 / 9; }
    .seym-gb__content { padding: 3rem 3.6rem; }
  }
  @media (max-width: 749px) {
    .seym-gb__media { aspect-ratio: 4 / 3; }
    .seym-gb__content { padding: 2.4rem; max-width: none; }
    .seym-gb__heading { font-size: clamp(3rem, 12vw, 5rem); }
  }
</style>

<section class="seym-gb">
  <div class="seym-gb__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag:
         loading: 'lazy', widths: '600,1000,1400,1800,2400',
         sizes: '100vw' }}
    {%- endif -%}
  </div>
  <div class="seym-gb__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="seym-gb__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="seym-gb__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="seym-gb__cta">{{ section.settings.cta_label }} →</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find the ideal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "GIFT" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Discover the selection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Gift Banner" }]
}
{% endschema %}
