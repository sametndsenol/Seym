{%- comment -%}
  Daum Gift Banner — full-width image, text overlay left-aligned.
{%- endcomment -%}

<style>
  .sgb {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .sgb__media { width: 100%; }
  .sgb__media img {
    width: 100%; height: auto;
    display: block;
    object-fit: cover;
    max-height: 36rem;
  }
  .sgb__scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.15) 40%, transparent 65%);
    z-index: 1;
    pointer-events: none;
  }
  .sgb__txt {
    position: absolute;
    z-index: 2;
    top: 0; bottom: 0; left: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 5rem;
    max-width: 36rem;
  }
  .sgb__ey {
    font: 300 0.64rem/1 'Inter', sans-serif;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.45);
    margin: 0 0 0.8rem;
  }
  .sgb__h {
    font: 300 clamp(4rem,8vw,7rem)/0.9 'Cormorant Garamond', serif;
    font-style: italic;
    color: #1A1A1A;
    margin: 0 0 1.6rem;
  }
  .sgb__cta {
    font: 300 0.68rem/1 'Inter', sans-serif;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    border-bottom: 1px solid rgba(26,26,26,0.35);
    padding-bottom: 0.3rem;
    align-self: flex-start;
    transition: color .2s, border-color .2s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .sgb__cta:hover { color: var(--seym-wine, #8E2244); border-color: var(--seym-wine, #8E2244); }

  @media(max-width:749px){
    .sgb__txt { padding: 2rem; max-width: none; }
    .sgb__media img { max-height: 28rem; }
  }
</style>

<section class="sgb" data-reveal>
  <div class="sgb__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag:
         loading: 'lazy', widths: '600,1000,1400,2000', sizes: '100vw' }}
    {%- endif -%}
  </div>
  <div class="sgb__scrim"></div>
  <div class="sgb__txt">
    {%- if section.settings.eyebrow != blank -%}<p class="sgb__ey">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="sgb__h">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="sgb__cta">{{ section.settings.cta_label }} →</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gift Banner",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find the ideal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "GIFT" },
    { "type": "text", "id": "cta_label", "label": "CTA", "default": "Discover the selection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Gift Banner" }]
}
{% endschema %}
