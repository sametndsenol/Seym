{%- comment -%}
  Seym Spin Showcase — 2 featured products, continuous 360° Y-axis rotation.
  Front face: product image on parchment.
  Back face: dark panel with product name (revealed as piece turns).
{%- endcomment -%}

<style>
  .seym-spin-section {
    padding: 10rem 0 12rem;
    background: #fafaf7;
  }

  .seym-spin__intro {
    text-align: center;
    margin-bottom: 8rem;
    padding: 0 5rem;
  }

  .seym-spin__eyebrow {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: #c9a96e;
    margin-bottom: 2.4rem;
  }

  .seym-spin__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.6rem, 5.5vw, 7rem);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: #0d0d0d;
    margin: 0;
  }

  .seym-spin__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    max-width: 112rem;
    margin: 0 auto;
    padding: 0 5rem;
  }

  .seym-spin__card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* 3D stage */
  .seym-spin__stage {
    perspective: 1400px;
    width: 100%;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .seym-spin__flipper {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    animation: seymSpinY 20s linear infinite;
  }

  /* Pause on hover — user can examine the piece */
  .seym-spin__item:hover .seym-spin__flipper {
    animation-play-state: paused;
  }

  @keyframes seymSpinY {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  /* Stagger the two cards so they're never at the same angle */
  .seym-spin__item:nth-child(2) .seym-spin__flipper {
    animation-delay: -10s;
  }

  .seym-spin__front,
  .seym-spin__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
  }

  /* Front: product photo on warm parchment */
  .seym-spin__front {
    background: #f0ede8;
  }
  .seym-spin__front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .seym-spin__item:hover .seym-spin__front img {
    transform: scale(1.03);
  }

  /* Back: dark void — product name and price */
  .seym-spin__back {
    transform: rotateY(180deg);
    background: #0d0d0d;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.4rem;
    padding: 4rem;
  }

  .seym-spin__back-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 3.8vw, 5rem);
    font-weight: 300;
    font-style: italic;
    color: #fafaf7;
    letter-spacing: -0.02em;
    line-height: 1;
    text-align: center;
  }

  .seym-spin__back-rule {
    display: block;
    width: 3.2rem;
    height: 1px;
    background: #c9a96e;
  }

  .seym-spin__back-price {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(250, 250, 247, 0.5);
  }

  /* Caption below each card */
  .seym-spin__meta {
    margin-top: 2.6rem;
    text-align: center;
    padding: 0 1rem;
  }

  .seym-spin__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0;
    color: #0d0d0d;
    margin: 0 0 0.6rem;
    line-height: 1.2;
  }

  .seym-spin__price {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(13, 13, 13, 0.42);
    margin: 0;
  }

  .seym-spin__cta {
    text-align: center;
    margin-top: 7rem;
  }

  .seym-spin__cta a {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #0d0d0d;
    text-decoration: none;
    border-bottom: 1px solid rgba(13,13,13,0.3);
    padding-bottom: 3px;
    transition: border-color 300ms ease, opacity 300ms ease;
  }
  .seym-spin__cta a:hover {
    border-color: #0d0d0d;
    opacity: 0.65;
  }

  @media (max-width: 749px) {
    .seym-spin-section { padding: 7rem 0 8rem; }
    .seym-spin__intro { padding: 0 2.4rem; margin-bottom: 5rem; }
    .seym-spin__grid {
      grid-template-columns: 1fr;
      gap: 5rem;
      padding: 0 2.4rem;
    }
    .seym-spin__back-name { font-size: clamp(2.4rem, 7vw, 3.8rem); }
  }

  @media (min-width: 750px) and (max-width: 989px) {
    .seym-spin__grid { padding: 0 3rem; gap: 3rem; }
  }
</style>

<section class="seym-spin-section">
  <div class="seym-spin__intro">
    {%- if section.settings.eyebrow != blank -%}
      <span class="seym-spin__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="seym-spin__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="seym-spin__grid">
      {%- for block in section.blocks -%}
        {%- assign _bprod = block.settings.product | strip -%}
        {%- if _bprod != blank -%}
          {%- assign product = all_products[_bprod] -%}
        {%- endif -%}
        {%- if product == blank and block.settings.collection != blank -%}
          {%- assign product = collections[block.settings.collection].products.first -%}
        {%- endif -%}
        {%- if product != blank -%}
          <div class="seym-spin__item" {{ block.shopify_attributes }}>
            <a href="{{ product.url }}" class="seym-spin__card-link" aria-label="{{ product.title }}">
              <div class="seym-spin__stage">
                <div class="seym-spin__flipper">

                  <div class="seym-spin__front">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 900 }}"
                        alt="{{ product.featured_image.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="900"
                        height="900"
                      />
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>

                  <div class="seym-spin__back">
                    <span class="seym-spin__back-name">{{ product.title }}</span>
                    <span class="seym-spin__back-rule"></span>
                    <span class="seym-spin__back-price">{{ product.price | money }}</span>
                  </div>

                </div>
              </div>

              <div class="seym-spin__meta">
                <h3 class="seym-spin__title">{{ product.title }}</h3>
                <p class="seym-spin__price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="seym-spin__cta">
        <a href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Spin Showcase",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Selected Pieces"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for those who notice."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link text",
      "default": "Explore the full collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link URL"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product (specific)"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (uses first product)"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Spin Showcase",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}
