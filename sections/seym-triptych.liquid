{%- comment -%}
  Daum Triptych — 3 tall portrait cards on white background.
  Center card: text overlay (eyebrow + brand + CTA) over dark image.
  Side cards: product/lifestyle image with small caption at bottom.
{%- endcomment -%}

<style>
  .sdt {
    background: #fff;
    padding: 1.2rem 1.2rem 0;
  }
  .sdt__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 140rem;
    margin: 0 auto;
  }
  .sdt__card {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: #fff;
  }
  .sdt__card img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.6s cubic-bezier(0.22,1,0.36,1);
  }
  .sdt__card:hover img { transform: scale(1.05); }

  /* Side cards: gradient only at bottom for caption */
  .sdt__card--side::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.45) 100%);
    z-index: 1;
  }
  .sdt__side-txt {
    position: absolute;
    z-index: 2;
    bottom: 2.4rem; left: 2.4rem; right: 2.4rem;
  }
  .sdt__side-ey {
    font: 300 0.6rem/1 'Inter', sans-serif;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0 0 0.5rem;
  }
  .sdt__side-name {
    font: 400 1.4rem/1.2 'Cormorant Garamond', serif;
    color: #fff;
    margin: 0 0 0.3rem;
  }
  .sdt__side-price {
    font: 300 0.8rem/1 'Inter', sans-serif;
    color: rgba(255,255,255,0.7);
  }

  /* Center card: full overlay with centered text */
  .sdt__card--center::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.32);
    z-index: 1;
  }
  .sdt__center-txt {
    position: absolute; inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem;
  }
  .sdt__center-ey {
    font: 300 0.65rem/1 'Inter', sans-serif;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin: 0 0 1.2rem;
  }
  .sdt__center-h {
    font: 300 clamp(2.8rem,4.5vw,5rem)/0.95 'Cormorant Garamond', serif;
    letter-spacing: 0.06em;
    color: #fff;
    margin: 0 0 2.4rem;
  }
  .sdt__center-cta {
    font: 400 0.64rem/1 'Inter', sans-serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
    padding: 0.95rem 2.4rem;
    transition: background .25s, border-color .25s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .sdt__card--center:hover .sdt__center-cta {
    background: rgba(255,255,255,0.1);
    border-color: #fff;
  }

  @media(max-width:749px){
    .sdt { padding: 0.6rem; }
    .sdt__grid { grid-template-columns: 1fr; gap: 0.6rem; }
    .sdt__card { aspect-ratio: 3 / 4; }
    .sdt__card--center { order: -1; }
  }
</style>

<section class="sdt" data-reveal>
  <div class="sdt__grid">
    {%- for block in section.blocks -%}
      {%- if forloop.index == 2 -%}
        {%- comment -%} CENTER CARD {%- endcomment -%}
        <a class="sdt__card sdt__card--center" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag:
               loading: 'lazy', widths: '400,600,800,1000',
               sizes: '(max-width:749px) 100vw, 33vw' }}
          {%- endif -%}
          <div class="sdt__center-txt">
            {%- if block.settings.eyebrow != blank -%}<span class="sdt__center-ey">{{ block.settings.eyebrow }}</span>{%- endif -%}
            {%- if block.settings.title != blank -%}<h2 class="sdt__center-h">{{ block.settings.title }}</h2>{%- endif -%}
            {%- if block.settings.cta_label != blank -%}<span class="sdt__center-cta">{{ block.settings.cta_label }}</span>{%- endif -%}
          </div>
        </a>
      {%- else -%}
        {%- comment -%} SIDE CARDS {%- endcomment -%}
        <a class="sdt__card sdt__card--side" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag:
               loading: 'lazy', widths: '400,600,800,1000',
               sizes: '(max-width:749px) 100vw, 33vw' }}
          {%- endif -%}
          <div class="sdt__side-txt">
            {%- if block.settings.eyebrow != blank -%}<span class="sdt__side-ey">{{ block.settings.eyebrow }}</span>{%- endif -%}
            {%- if block.settings.title != blank -%}<h3 class="sdt__side-name">{{ block.settings.title }}</h3>{%- endif -%}
            {%- if block.settings.subtitle != blank -%}<span class="sdt__side-price">{{ block.settings.subtitle }}</span>{%- endif -%}
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Triptych Banners",
  "tag": "div",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle / price (side cards)" },
        { "type": "text", "id": "cta_label", "label": "CTA (center card only)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Triptych Banners",
    "blocks": [
      { "type": "card", "settings": { "eyebrow": "In Collection", "title": "Flos", "subtitle": "€ 420" } },
      { "type": "card", "settings": { "eyebrow": "Art de la Table", "title": "SEYM", "cta_label": "Discover the collection" } },
      { "type": "card", "settings": { "eyebrow": "Featured", "title": "Maris Vase", "subtitle": "€ 680" } }
    ]
  }]
}
{% endschema %}
