{%- comment -%}
  SEYM Hero — Cinematic scroll-reveal stage.
  Adds: (2) 3D perspective on object, (4) per-word text reveal,
        (6) drifting luminous particles.
{%- endcomment -%}

{%- liquid
  assign overlay_color = section.settings.bg_color | default: '#0a1424'
  assign accent_color = section.settings.text_color | default: '#efecec'
-%}

{%- style -%}
  .seym-hero-{{ section.id }} {
    --seym-hero-bg: {{ overlay_color }};
    --seym-hero-fg: {{ accent_color }};
    position: relative;
    background: var(--seym-hero-bg);
    color: var(--seym-hero-fg);
    height: calc({{ section.blocks.size | at_least: 1 }} * 100vh + 100vh);
    overflow: visible;
    margin: 0 -5rem 0 -5rem;
  }

  .seym-hero-stage-{{ section.id }} {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(27, 54, 93, 0.55), transparent 55%),
      radial-gradient(ellipse at 50% 110%, rgba(27, 54, 93, 0.4), transparent 55%),
      var(--seym-hero-bg);
    /* (2) 3D perspective */
    perspective: 1600px;
    perspective-origin: 50% 50%;
  }

  /* Vignette */
  .seym-hero-stage-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(75% 100% at 50% 50%, transparent 35%, rgba(10, 20, 36, 0.55) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .seym-hero-light-{{ section.id }} {
    position: absolute;
    width: 60vmin;
    height: 60vmin;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 50% 60%, rgba(239, 236, 236, 0.18), transparent 60%);
    pointer-events: none;
    z-index: 2;
    filter: blur(20px);
    will-change: transform, opacity;
  }

  /* (6) Drifting particles layer */
  .seym-hero-particles-{{ section.id }} {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }
  .seym-hero-particles-{{ section.id }} .particle {
    position: absolute;
    bottom: -40px;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(239, 236, 236, 0.7);
    box-shadow: 0 0 6px rgba(239, 236, 236, 0.5);
    animation: seym-particle-rise-{{ section.id }} linear infinite;
    will-change: transform, opacity;
  }
  @keyframes seym-particle-rise-{{ section.id }} {
    0%   { transform: translate3d(0, 0, 0) scale(0.6); opacity: 0; }
    10%  { opacity: 0.9; }
    50%  { transform: translate3d(8px, -50vh, 0) scale(1); opacity: 0.7; }
    90%  { opacity: 0.4; }
    100% { transform: translate3d(-8px, -110vh, 0) scale(0.5); opacity: 0; }
  }

  .seym-hero-object-{{ section.id }} {
    position: relative;
    width: 50vmin;
    height: 70vmin;
    max-width: 720px;
    max-height: 820px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    /* (2) 3D depth */
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .seym-hero-object-{{ section.id }} img,
  .seym-hero-object-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.6))
            drop-shadow(0 -10px 30px rgba(239, 236, 236, 0.05));
    transition: opacity 0.6s ease;
  }
  .seym-hero-object-{{ section.id }} svg.seym-hero-svg {
    animation: seym-orb-breathe 6s ease-in-out infinite;
  }
  @keyframes seym-orb-breathe {
    0%, 100% { filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)) drop-shadow(0 -10px 30px rgba(239,236,236,0.06)); }
    50% { filter: drop-shadow(0 35px 70px rgba(0,0,0,0.5)) drop-shadow(0 -10px 50px rgba(239,236,236,0.18)); }
  }

  .seym-hero-object-{{ section.id }} img + img {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .seym-hero-eyebrow-{{ section.id }} {
    position: absolute;
    top: 12vh;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    font-size: 1rem;
    font-weight: 400;
    color: var(--seym-hero-fg);
    opacity: 0.55;
    text-align: center;
    white-space: nowrap;
  }

  .seym-hero-step-{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 6vw 12vh;
    pointer-events: none;
    opacity: 0;
    transform: translateY(20px);
    will-change: opacity, transform;
  }

  .seym-hero-step-{{ section.id }} .step-inner {
    max-width: 760px;
    text-align: center;
    color: var(--seym-hero-fg);
  }

  .seym-hero-step-{{ section.id }} .step-eyebrow {
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.36em;
    font-size: 0.95rem;
    font-weight: 400;
    opacity: 0.55;
    display: block;
    margin-bottom: 1.6rem;
  }

  .seym-hero-step-{{ section.id }} .step-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    font-size: clamp(3.2rem, 5vw, 6rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 1.6rem 0;
    color: var(--seym-hero-fg);
  }

  .seym-hero-step-{{ section.id }} .step-headline em {
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    color: var(--seym-hero-fg);
    opacity: 0.85;
  }

  /* (4) Per-word text reveal */
  .seym-hero-step-{{ section.id }} .step-headline .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    filter: blur(10px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform, filter;
  }
  .seym-hero-step-{{ section.id }}.is-active .step-headline .word {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .seym-hero-step-{{ section.id }} .step-body {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.4rem;
    line-height: 1.7;
    letter-spacing: 0.005em;
    opacity: 0.7;
    max-width: 56ch;
    margin: 0 auto;
  }

  .seym-hero-cue-{{ section.id }} {
    position: absolute;
    bottom: 4vh;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--seym-hero-fg);
    opacity: 0.4;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    transition: opacity 0.6s ease;
  }
  .seym-hero-cue-{{ section.id }} .cue-line {
    width: 60px;
    height: 1px;
    background: currentColor;
    animation: seym-cue-drop 2.4s cubic-bezier(0.22,1,0.36,1) infinite;
    transform-origin: top;
  }
  @keyframes seym-cue-drop {
    0%, 30% { transform: scaleY(0); transform-origin: top; opacity: 0.3; }
    60% { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  .scrolled-active-{{ section.id }} .seym-hero-cue-{{ section.id }} { opacity: 0; }

  @media (max-width: 749px) {
    .seym-hero-{{ section.id }} {
      margin: 0 -2.4rem;
      height: calc({{ section.blocks.size | at_least: 1 }} * 90vh + 90vh);
    }
    .seym-hero-stage-{{ section.id }} { height: 100vh; perspective: 1000px; }
    .seym-hero-object-{{ section.id }} { width: 78vmin; height: 78vmin; }
    .seym-hero-step-{{ section.id }} { padding: 0 6vw 10vh; }
    .seym-hero-step-{{ section.id }} .step-headline { font-size: clamp(2.6rem, 8vw, 4rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .seym-hero-particles-{{ section.id }} .particle { animation: none; opacity: 0; }
    .seym-hero-step-{{ section.id }} .step-headline .word {
      opacity: 1; transform: none; filter: none; transition: none;
    }
  }
{%- endstyle -%}

<section class="seym-hero-{{ section.id }}" id="seym-hero-{{ section.id }}">
  <div class="seym-hero-stage-{{ section.id }}" id="seym-hero-stage-{{ section.id }}">

    {%- comment -%} (6) Drifting particles {%- endcomment -%}
    <div class="seym-hero-particles-{{ section.id }}" aria-hidden="true">
      {%- assign particle_count = 14 -%}
      {%- for i in (1..particle_count) -%}
        {%- assign delay_seed = i | times: 1.317 | modulo: 8 -%}
        {%- assign duration = i | modulo: 5 | plus: 9 -%}
        {%- assign left_pos = i | times: 7 | modulo: 100 -%}
        {%- assign size = i | modulo: 3 | plus: 2 -%}
        <span class="particle"
              style="left:{{ left_pos }}%;
                     width:{{ size }}px;height:{{ size }}px;
                     animation-duration:{{ duration }}s;
                     animation-delay:-{{ delay_seed }}s;"></span>
      {%- endfor -%}
    </div>

    <div class="seym-hero-light-{{ section.id }}" id="seym-hero-light-{{ section.id }}"></div>

    {%- if section.settings.eyebrow != blank -%}
      <span class="seym-hero-eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <div class="seym-hero-object-{{ section.id }}" id="seym-hero-object-{{ section.id }}">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'seym-hero-img-primary' }}
      {% else %}
        <svg
          class="seym-hero-img-primary seym-hero-svg"
          viewBox="0 0 600 800"
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Seym Glass Studio luminous object"
        >
          <defs>
            <radialGradient id="seym-orb-{{ section.id }}" cx="50%" cy="38%" r="55%">
              <stop offset="0%" stop-color="#f7f5ee" stop-opacity="0.95"/>
              <stop offset="35%" stop-color="#cfd9eb" stop-opacity="0.65"/>
              <stop offset="70%" stop-color="#1b365d" stop-opacity="0.85"/>
              <stop offset="100%" stop-color="#0a1424" stop-opacity="0.95"/>
            </radialGradient>
            <radialGradient id="seym-orb-glow-{{ section.id }}" cx="35%" cy="28%" r="35%">
              <stop offset="0%" stop-color="#ffffff" stop-opacity="0.85"/>
              <stop offset="60%" stop-color="#ffffff" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
            </radialGradient>
            <radialGradient id="seym-orb-shadow-{{ section.id }}" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#000000" stop-opacity="0.55"/>
              <stop offset="60%" stop-color="#000000" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="#000000" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="seym-orb-rim-{{ section.id }}" x1="50%" y1="0%" x2="50%" y2="100%">
              <stop offset="0%" stop-color="#efecec" stop-opacity="0.8"/>
              <stop offset="40%" stop-color="#efecec" stop-opacity="0.05"/>
              <stop offset="100%" stop-color="#efecec" stop-opacity="0.45"/>
            </linearGradient>
          </defs>
          <ellipse cx="300" cy="700" rx="180" ry="22" fill="url(#seym-orb-shadow-{{ section.id }})"/>
          <circle cx="300" cy="380" r="240" fill="url(#seym-orb-{{ section.id }})" stroke="url(#seym-orb-rim-{{ section.id }})" stroke-width="1"/>
          <ellipse cx="300" cy="400" rx="170" ry="180" fill="none" stroke="rgba(239,236,236,0.18)" stroke-width="0.5"/>
          <ellipse cx="300" cy="400" rx="120" ry="130" fill="none" stroke="rgba(239,236,236,0.14)" stroke-width="0.5"/>
          <ellipse cx="240" cy="290" rx="80" ry="55" fill="url(#seym-orb-glow-{{ section.id }})"/>
          <ellipse cx="220" cy="270" rx="22" ry="14" fill="rgba(255,255,255,0.85)"/>
          <circle cx="380" cy="320" r="2" fill="rgba(255,255,255,0.7)"/>
          <circle cx="350" cy="450" r="1.4" fill="rgba(255,255,255,0.5)"/>
          <circle cx="260" cy="500" r="1" fill="rgba(255,255,255,0.4)"/>
        </svg>
      {% endif %}
      {% if section.settings.image_secondary != blank %}
        {{ section.settings.image_secondary | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'seym-hero-img-secondary' }}
      {% endif %}
    </div>

    {% for block in section.blocks %}
      <div
        class="seym-hero-step-{{ section.id }} seym-hero-step seym-hero-step-{{ forloop.index }}"
        data-step-index="{{ forloop.index0 }}"
        id="seym-hero-step-{{ block.id }}"
      >
        <div class="step-inner">
          {% if block.settings.eyebrow != blank %}
            <span class="step-eyebrow">{{ block.settings.eyebrow }}</span>
          {% endif %}
          {% if block.settings.headline != blank %}
            {%- comment -%} (4) Wrap each word in <span class="word"> for staggered reveal {%- endcomment -%}
            <h2 class="step-headline">
              {%- assign words = block.settings.headline | split: ' ' -%}
              {%- for w in words -%}
                <span class="word" style="transition-delay: {{ forloop.index0 | times: 60 }}ms">{{ w }}</span>{% unless forloop.last %} {% endunless %}
              {%- endfor -%}
            </h2>
          {% endif %}
          {% if block.settings.body != blank %}
            <div class="step-body">{{ block.settings.body }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}

    <div class="seym-hero-cue-{{ section.id }}">
      {{ section.settings.scroll_label | default: 'Scroll' }}
      <span class="cue-line"></span>
    </div>

  </div>
</section>

<script>
(function() {
  const sectionId = "{{ section.id }}";
  const container = document.getElementById('seym-hero-' + sectionId);
  const stage = document.getElementById('seym-hero-stage-' + sectionId);
  const obj = document.getElementById('seym-hero-object-' + sectionId);
  const light = document.getElementById('seym-hero-light-' + sectionId);
  const steps = container ? container.querySelectorAll('.seym-hero-step') : [];
  const primary = obj ? obj.querySelector('.seym-hero-img-primary') : null;
  const secondary = obj ? obj.querySelector('.seym-hero-img-secondary') : null;

  if (!container || !obj || steps.length === 0) return;

  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    steps.forEach((s) => { s.style.opacity = 1; s.style.transform = 'none'; s.classList.add('is-active'); });
    return;
  }

  let ticking = false;
  const totalSteps = steps.length;

  function lerp(a, b, t) { return a + (b - a) * t; }
  function clamp01(v) { return Math.max(0, Math.min(1, v)); }
  function easeInOut(t) { return t < 0.5 ? 2*t*t : 1 - Math.pow(-2*t+2, 2)/2; }

  function update() {
    const rect = container.getBoundingClientRect();
    const total = container.offsetHeight - window.innerHeight;
    if (total <= 0) return;
    const scrolled = clamp01(-rect.top / total);

    if (scrolled > 0.02) container.classList.add('scrolled-active-' + sectionId);
    else container.classList.remove('scrolled-active-' + sectionId);

    const baseScale = 0.92;
    const scaleAdd = 0.18 * easeInOut(scrolled);
    /* (2) Subtle 3D rotation tied to scroll progress */
    const rotateZ = (Math.sin(scrolled * Math.PI * (totalSteps + 1)) * 14) - 4;
    const rotateY = Math.sin(scrolled * Math.PI * 2) * 18;     // sway left-right
    const rotateX = -6 + Math.cos(scrolled * Math.PI) * 10;    // tilt forward/back
    const yShift = -20 * easeInOut(scrolled);

    obj.style.transform =
      'translate3d(0,' + yShift + 'px, 0) ' +
      'rotateX(' + rotateX.toFixed(2) + 'deg) ' +
      'rotateY(' + rotateY.toFixed(2) + 'deg) ' +
      'rotateZ(' + rotateZ.toFixed(2) + 'deg) ' +
      'scale(' + (baseScale + scaleAdd).toFixed(3) + ')';

    if (light) {
      const lightScale = 0.9 + 0.6 * easeInOut(scrolled);
      const lightOpacity = 0.4 + 0.6 * easeInOut(scrolled);
      light.style.transform = 'translate(-50%, -50%) scale(' + lightScale.toFixed(3) + ')';
      light.style.opacity = lightOpacity.toFixed(3);
    }

    if (secondary) {
      const fadeIn = clamp01((scrolled - 0.55) / 0.25);
      secondary.style.opacity = fadeIn.toFixed(3);
      primary.style.opacity = (1 - fadeIn).toFixed(3);
    }

    steps.forEach((step, i) => {
      const stepStart = i / totalSteps;
      const stepEnd = (i + 1) / totalSteps;
      const stepRange = stepEnd - stepStart;

      let local = (scrolled - stepStart) / stepRange;
      let opacity = 0;
      let translate = 30;
      let isActive = false;

      if (local < 0.25) {
        const t = clamp01(local / 0.25);
        opacity = t;
        translate = lerp(30, 0, t);
        if (t > 0.25) isActive = true;
      } else if (local < 0.75) {
        opacity = 1;
        translate = 0;
        isActive = true;
      } else if (local <= 1.05) {
        const t = clamp01((local - 0.75) / 0.3);
        opacity = 1 - t;
        translate = lerp(0, -30, t);
      }

      step.style.opacity = opacity.toFixed(3);
      step.style.transform = 'translate3d(0, ' + translate.toFixed(2) + 'px, 0)';
      /* (4) Toggle is-active so per-word reveal animates in/out */
      if (isActive) step.classList.add('is-active');
      else step.classList.remove('is-active');
    });

    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(update);
      ticking = true;
    }
  }

  update();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
})();
</script>

{% schema %}
{
  "name": "Seym Hero",
  "tag": "section",
  "class": "section seym-hero-section",
  "settings": [
    { "type": "header", "content": "Stage" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Primary object (PNG with transparent background)",
      "info": "Use a high-resolution PNG. Transparent background gives the cinematic spotlight effect."
    },
    {
      "type": "image_picker",
      "id": "image_secondary",
      "label": "Secondary object (optional, cross-fades near the end)"
    },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#0a1424" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#efecec" },
    { "type": "header", "content": "Labels" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Top eyebrow label",
      "default": "Seym Glass Studio · Istanbul"
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Scroll cue label",
      "default": "Scroll"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Scroll step",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Chapter I" },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "default": "A unique aesthetic approach that combines glass art with a mysterious story."
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Caption",
          "default": "<p>Mouth-blown in Istanbul. Inspired by mythology and nature.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seym Hero",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "eyebrow": "Chapter I — Origin",
            "headline": "A unique aesthetic approach that combines glass art with a mysterious story.",
            "body": "<p>Mouth-blown in Istanbul. Inspired by mythology and nature.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "eyebrow": "Chapter II — Craft",
            "headline": "Each piece begins as breath, becomes <em>memory</em>.",
            "body": "<p>Universal glass art tradition shaped by master hands in our atelier.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "eyebrow": "Chapter III — Presence",
            "headline": "Modern heritage, designed to <em>endure</em>.",
            "body": "<p>Story-driven, sculptural, never repeated. A quiet companion to contemporary living spaces.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
