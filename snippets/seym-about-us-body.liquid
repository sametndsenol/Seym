{%- comment -%}
  About Seym hub body. Pulls live content from Catalog/Press/
  Achievements page handles. Settings pass-through:
    eyebrow, title, lead, atelier_heading, atelier_text,
    catalog_handle, press_handle, achievements_handle,
    cta_eyebrow, cta_heading,
    cta_primary_label, cta_primary_link,
    cta_secondary_label, cta_secondary_link,
    padding_top, padding_bottom
{%- endcomment -%}

{%- liquid
  assign _iso = localization.language.iso_code | default: request.locale.iso_code | downcase
  assign _is_tr = false
  if _iso contains 'tr'
    assign _is_tr = true
  endif

  if _is_tr
    assign _d_eyebrow = 'Seym Hakkında'
    assign _d_title   = 'Cam, nefesle <em>yazılır</em>.'
    assign _d_lead    = 'Seym Glass Studio, Çengelköy’ün dar sokaklarında yanan küçük bir ocaktır. Her parça nefesle başlar, elle biter — ve karakterini taşımıyorsa, atölyeden çıkmaz.'
    assign _d_atelier_heading = 'Yavaşlığın <em>başka bir adı</em> var.'
    assign _d_atelier_text    = '<p>2022’de doğan Seym, küçük bir ustalar takımının tek ilkeye olan inadıdır: <strong>kusursuzluk yerine karakter</strong>. Her parça <em>adlandırılır</em>, numaralandırılmaz; her seri <em>on ikide</em> kapanır, hiçbiri geri dönmez.</p>'
    assign _d_ch01 = '01 · Atölye'
    assign _d_ch02 = '02 · Katalog'
    assign _d_ch03 = '03 · Basın'
    assign _d_ch04 = '04 · Başarılar'
    assign _d_rooms_eyebrow = 'Bağlı odalar'
    assign _d_rooms_heading = 'Atölyenin <em>üç köşesi</em>.'
    assign _d_catalog_title  = 'Dijital Katalog'
    assign _d_catalog_cta    = 'Aç →'
    assign _d_catalog_body   = 'Atölyeden çıkmış her parçanın sessiz kaydı.'
    assign _d_press_title    = 'Basın'
    assign _d_press_cta      = 'Oku →'
    assign _d_press_body     = 'Dışarıdan içeri bakanın sesi.'
    assign _d_awards_title   = 'Başarılarımız'
    assign _d_awards_cta     = 'Gör →'
    assign _d_awards_body    = 'Şekillendirilmiş parçalarla ölçülen yol.'
    assign _d_cta_eyebrow = 'İçeri buyrun'
    assign _d_cta_heading = 'Galeri açık.'
    assign _d_cta_primary = 'Koleksiyonları keşfet'
    assign _d_cta_secondary = 'İletişim'
    assign _d_manifest_lead = 'Atölyenin <em>beş sözü</em>'
    assign _d_manifest = 'Ocak. — Nefes. — El. — Adlandırma. — On iki.'
  else
    assign _d_eyebrow = 'About Seym'
    assign _d_title   = 'Glass, written in <em>breath</em>.'
    assign _d_lead    = 'Seym Glass Studio is a small kiln burning in the narrow streets of Çengelköy. Each piece begins with breath, ends in hand — and never leaves the atelier unless it carries weight.'
    assign _d_atelier_heading = 'A quieter <em>way of making</em>.'
    assign _d_atelier_text    = '<p>Born in 2022, Seym is the work of a small team bound to one principle: <strong>character over perfection</strong>. Each piece is <em>named</em>, never numbered; each series closes at <em>twelve</em>, and nothing returns.</p>'
    assign _d_ch01 = '01 · The Atelier'
    assign _d_ch02 = '02 · The Catalog'
    assign _d_ch03 = '03 · Press'
    assign _d_ch04 = '04 · Achievements'
    assign _d_rooms_eyebrow = 'Linked rooms'
    assign _d_rooms_heading = 'Three <em>corners</em> of the atelier.'
    assign _d_catalog_title  = 'Digital Catalog'
    assign _d_catalog_cta    = 'Open →'
    assign _d_catalog_body   = 'A quiet record of every piece.'
    assign _d_press_title    = 'Press'
    assign _d_press_cta      = 'Read →'
    assign _d_press_body     = 'Voices from the world looking in.'
    assign _d_awards_title   = 'Our Achievements'
    assign _d_awards_cta     = 'See →'
    assign _d_awards_body    = 'The road measured in shaped pieces.'
    assign _d_cta_eyebrow = 'Step inside'
    assign _d_cta_heading = 'The gallery is open.'
    assign _d_cta_primary = 'Explore Collections'
    assign _d_cta_secondary = 'Get in Touch'
    assign _d_manifest_lead = 'The atelier’s <em>five words</em>'
    assign _d_manifest = 'Kiln. — Breath. — Hand. — Naming. — Twelve.'
  endif

  assign _eyebrow = eyebrow | default: _d_eyebrow
  assign _title   = title   | default: _d_title
  assign _lead    = lead    | default: _d_lead

  assign _atelier_heading = atelier_heading | default: _d_atelier_heading
  assign _atelier_text    = atelier_text    | default: _d_atelier_text

  assign _ch_catalog = catalog_handle      | default: 'digital-catalog'
  assign _ch_press   = press_handle        | default: 'press'
  assign _ch_awards  = achievements_handle | default: 'our-achievements'

  assign p_catalog = pages[_ch_catalog]
  assign p_press   = pages[_ch_press]
  assign p_awards  = pages[_ch_awards]

  assign _cta_eyebrow = cta_eyebrow | default: _d_cta_eyebrow
  assign _cta_heading = cta_heading | default: _d_cta_heading
  assign _cta_primary_label   = cta_primary_label   | default: _d_cta_primary
  assign _cta_primary_link    = cta_primary_link    | default: '/collections'
  assign _cta_secondary_label = cta_secondary_label | default: _d_cta_secondary
  assign _cta_secondary_link  = cta_secondary_link  | default: '/pages/contact'

  assign _pt = padding_top    | default: 40
  assign _pb = padding_bottom | default: 48
-%}

<style>
  .seym-au {
    background: var(--seym-ivory, #F5F1EA);
    color: var(--seym-ink, #1A1A1A);
    padding: {{ _pt }}px 0 {{ _pb }}px;
  }
  .seym-au__wrap { max-width: 132rem; margin: 0 auto; padding: 0 4rem; }

  .seym-au__hero {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 4.8rem;
    align-items: end;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(26,26,26,0.1);
    margin-bottom: 2.4rem;
  }
  .seym-au__eyebrow {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.6rem;
    padding-left: 2.6rem;
  }
  .seym-au__eyebrow::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    width: 2rem; height: 1px;
    background: var(--seym-wine, #8E2244);
  }
  .seym-au__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.4rem, 4.6vw, 6.4rem);
    line-height: 1;
    letter-spacing: -0.018em;
    color: #1A1A1A;
    margin: 0;
  }
  .seym-au__title em { font-style: italic; color: var(--seym-wine, #8E2244); }
  .seym-au__lead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.7rem, 1.8vw, 2.05rem);
    line-height: 1.55;
    color: rgba(26,26,26,0.78);
    margin: 0;
  }

  .seym-au__manifest {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 4.8rem;
    align-items: baseline;
    padding: 0 0 1.8rem;
    margin-bottom: 1.6rem;
    border-bottom: 1px solid rgba(26,26,26,0.08);
  }
  .seym-au__manifest-tag {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.4rem, 1.4vw, 1.7rem);
    line-height: 1.4;
    letter-spacing: 0.01em;
    color: rgba(26,26,26,0.55);
    margin: 0;
  }
  .seym-au__manifest-tag em { color: var(--seym-wine, #8E2244); font-style: italic; }
  .seym-au__manifest-line {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: normal;
    font-size: clamp(1.6rem, 1.7vw, 2.1rem);
    line-height: 1.4;
    letter-spacing: 0.03em;
    color: #1A1A1A;
    margin: 0;
  }

  .seym-au__chapter {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 4rem;
    align-items: start;
    padding: 2.4rem 0 2.8rem;
    border-top: 1px solid rgba(26,26,26,0.08);
  }
  .seym-au__chapter:first-of-type { border-top: 0; padding-top: 0; }
  .seym-au__chapter--flip { grid-template-columns: 7fr 5fr; }
  .seym-au__chapter--flip .seym-au__chapter-lead { order: 2; }
  .seym-au__chapter--flip .seym-au__chapter-body { order: 1; }

  .seym-au__chapter-lead { position: sticky; top: 12rem; }
  .seym-au__chapter-tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.6rem;
  }
  .seym-au__chapter-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 2.6vw, 3.2rem);
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: #1A1A1A;
    margin: 0 0 1.2rem;
  }
  .seym-au__chapter-heading em { font-style: italic; color: var(--seym-wine, #8E2244); }

  .seym-au__chapter-meta {
    display: block;
    margin-top: 2.4rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #1A1A1A;
    transition: padding-right 280ms ease, color 220ms ease, border-color 220ms ease;
  }
  .seym-au__chapter-meta::after {
    content: '→';
    display: inline-block;
    margin-left: 0.6rem;
    transition: transform 280ms ease;
  }
  .seym-au__chapter-meta:hover {
    padding-right: 0.6rem;
    color: var(--seym-wine, #8E2244);
    border-color: var(--seym-wine, #8E2244);
  }
  .seym-au__chapter-meta:hover::after { transform: translateX(4px); }

  .seym-au__chapter-body {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.5rem;
    line-height: 1.8;
    color: rgba(26,26,26,0.85);
  }
  .seym-au__chapter-body p { margin: 0 0 1.4rem; }
  .seym-au__chapter-body p:last-child { margin-bottom: 0; }
  .seym-au__chapter-body strong { color: #1A1A1A; font-weight: 500; }
  .seym-au__chapter-body em { font-style: italic; color: rgba(26,26,26,0.78); }
  .seym-au__chapter-body a {
    color: var(--seym-wine, #8E2244);
    text-decoration: none;
    border-bottom: 1px solid rgba(142, 34, 68, 0.35);
  }
  .seym-au__chapter-body a:hover { border-color: var(--seym-wine, #8E2244); }
  .seym-au__chapter-body ul,
  .seym-au__chapter-body ol { margin: 0 0 1.6rem; padding-left: 2rem; }
  .seym-au__chapter-body li { margin-bottom: 0.6rem; }
  .seym-au__chapter-body h2,
  .seym-au__chapter-body h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    color: #1A1A1A;
    margin: 3rem 0 1rem;
  }
  .seym-au__chapter-body h2 { font-size: clamp(2rem, 2.2vw, 2.6rem); }
  .seym-au__chapter-body h3 { font-size: 1.8rem; }
  .seym-au__chapter-body img { display: block; width: 100%; height: auto; margin: 2rem 0; }
  .seym-au__chapter-body--placeholder { font-style: italic; color: rgba(26,26,26,0.55); }

  .seym-au__rooms {
    padding: 2.4rem 0 0;
    border-top: 1px solid rgba(26,26,26,0.08);
  }
  .seym-au__rooms-head {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 4rem;
    align-items: baseline;
    margin-bottom: 1.8rem;
  }
  .seym-au__rooms-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 2.8vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -0.012em;
    color: #1A1A1A;
    margin: 0;
  }
  .seym-au__rooms-heading em { font-style: italic; color: var(--seym-wine, #8E2244); }
  .seym-au__rooms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .seym-au__room {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 2rem 1.8rem;
    background: rgba(255,255,255,0.4);
    border: 1px solid rgba(26,26,26,0.08);
    text-decoration: none;
    color: inherit;
    transition: border-color 220ms ease, background 220ms ease, transform 220ms ease;
  }
  .seym-au__room:hover {
    border-color: var(--seym-wine, #8E2244);
    background: rgba(255,255,255,0.65);
    transform: translateY(-2px);
  }
  .seym-au__room-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
  }
  .seym-au__room-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 2vw, 2.2rem);
    line-height: 1.15;
    color: #1A1A1A;
    margin: 0;
  }
  .seym-au__room-lead {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.4rem;
    line-height: 1.45;
    color: rgba(26,26,26,0.7);
    margin: 0;
    flex: 1;
  }
  .seym-au__room-cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #1A1A1A;
    margin-top: 0.4rem;
    transition: color 220ms ease;
  }
  .seym-au__room:hover .seym-au__room-cta { color: var(--seym-wine, #8E2244); }

  .seym-au__cta {
    margin-top: 2.8rem;
    padding: 2.6rem 0 0.6rem;
    border-top: 1px solid rgba(26,26,26,0.1);
    text-align: center;
  }
  .seym-au__cta-eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.6rem;
  }
  .seym-au__cta-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(2.6rem, 3.4vw, 4rem);
    line-height: 1.1;
    color: #1A1A1A;
    margin: 0 0 3rem;
  }
  .seym-au__cta-row {
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .seym-au__btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1.2rem 2.2rem;
    transition: background 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .seym-au__btn--primary {
    background: var(--seym-wine, #8E2244);
    color: var(--seym-ivory, #F5F1EA);
    border: 1px solid var(--seym-wine, #8E2244);
  }
  .seym-au__btn--primary:hover { background: transparent; color: var(--seym-wine, #8E2244); }
  .seym-au__btn--ghost {
    background: transparent;
    color: #1A1A1A;
    border: 1px solid rgba(26,26,26,0.4);
  }
  .seym-au__btn--ghost:hover { color: var(--seym-wine, #8E2244); border-color: var(--seym-wine, #8E2244); }

  @media (max-width: 989px) {
    .seym-au__wrap { padding: 0 2.4rem; }
    .seym-au__hero,
    .seym-au__manifest,
    .seym-au__rooms-head,
    .seym-au__chapter,
    .seym-au__chapter--flip {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }
    .seym-au__manifest { padding-bottom: 2.4rem; margin-bottom: 1.6rem; }
    .seym-au__chapter { padding: 2.8rem 0; gap: 2rem; }
    .seym-au__rooms-grid { grid-template-columns: 1fr; gap: 1.2rem; }
    .seym-au__rooms { padding-top: 2.8rem; }
    .seym-au__chapter--flip .seym-au__chapter-lead { order: 1; }
    .seym-au__chapter--flip .seym-au__chapter-body { order: 2; }
    .seym-au__chapter-lead { position: static; }
    .seym-au__hero { margin-bottom: 2.8rem; }
    .seym-au__cta { margin-top: 2.8rem; padding: 2.8rem 0 1rem; }
  }
</style>

<section class="seym-au">
  <div class="seym-au__wrap">

    <header class="seym-au__hero">
      <div>
        <span class="seym-au__eyebrow">{{ _eyebrow }}</span>
        <h1 class="seym-au__title">{{ _title }}</h1>
      </div>
      {%- if _lead != blank -%}
        <p class="seym-au__lead">{{ _lead }}</p>
      {%- endif -%}
    </header>

    <div class="seym-au__manifest" aria-hidden="false">
      <p class="seym-au__manifest-tag">{{ _d_manifest_lead }}</p>
      <p class="seym-au__manifest-line">{{ _d_manifest }}</p>
    </div>

    <article class="seym-au__chapter">
      <div class="seym-au__chapter-lead">
        <span class="seym-au__chapter-tag">{{ _d_ch01 }}</span>
        <h2 class="seym-au__chapter-heading">{{ _atelier_heading }}</h2>
      </div>
      <div class="seym-au__chapter-body rte">{{ _atelier_text }}</div>
    </article>

    <section class="seym-au__rooms" aria-label="{{ _d_rooms_eyebrow }}">
      <div class="seym-au__rooms-head">
        <span class="seym-au__chapter-tag">{{ _d_rooms_eyebrow }}</span>
        <h2 class="seym-au__rooms-heading">{{ _d_rooms_heading }}</h2>
      </div>
      <div class="seym-au__rooms-grid">
        <a class="seym-au__room" href="{{ p_catalog.url | default: '/pages/digital-catalog' }}">
          <span class="seym-au__room-tag">{{ _d_ch02 }}</span>
          <h3 class="seym-au__room-title">{{ p_catalog.title | default: _d_catalog_title }}</h3>
          <p class="seym-au__room-lead">{{ _d_catalog_body }}</p>
          <span class="seym-au__room-cta">{{ _d_catalog_cta }}</span>
        </a>
        <a class="seym-au__room" href="{{ p_press.url | default: '/pages/press' }}">
          <span class="seym-au__room-tag">{{ _d_ch03 }}</span>
          <h3 class="seym-au__room-title">{{ p_press.title | default: _d_press_title }}</h3>
          <p class="seym-au__room-lead">{{ _d_press_body }}</p>
          <span class="seym-au__room-cta">{{ _d_press_cta }}</span>
        </a>
        <a class="seym-au__room" href="{{ p_awards.url | default: '/pages/our-achievements' }}">
          <span class="seym-au__room-tag">{{ _d_ch04 }}</span>
          <h3 class="seym-au__room-title">{{ p_awards.title | default: _d_awards_title }}</h3>
          <p class="seym-au__room-lead">{{ _d_awards_body }}</p>
          <span class="seym-au__room-cta">{{ _d_awards_cta }}</span>
        </a>
      </div>
    </section>

    <footer class="seym-au__cta">
      {%- if _cta_eyebrow != blank -%}
        <span class="seym-au__cta-eyebrow">{{ _cta_eyebrow }}</span>
      {%- endif -%}
      {%- if _cta_heading != blank -%}
        <p class="seym-au__cta-heading">{{ _cta_heading }}</p>
      {%- endif -%}
      <div class="seym-au__cta-row">
        {%- if _cta_primary_label != blank and _cta_primary_link != blank -%}
          <a class="seym-au__btn seym-au__btn--primary" href="{{ _cta_primary_link }}">{{ _cta_primary_label }}</a>
        {%- endif -%}
        {%- if _cta_secondary_label != blank and _cta_secondary_link != blank -%}
          <a class="seym-au__btn seym-au__btn--ghost" href="{{ _cta_secondary_link }}">{{ _cta_secondary_label }}</a>
        {%- endif -%}
      </div>
    </footer>

  </div>
</section>
