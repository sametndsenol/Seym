{%- liquid
  assign lang = localization.language.iso_code
  assign is_tr = false
  if lang == 'tr'
    assign is_tr = true
  endif
-%}

<style>
  .seym-ach {
    background: var(--seym-ivory, #F5F1EA);
    color: var(--seym-ink, #1A1A1A);
    padding: 48px 0 64px;
  }
  .seym-ach__wrap { max-width: 72rem; margin: 0 auto; padding: 0 4rem; }

  .seym-ach__hero {
    margin: 0 0 4rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(26,26,26,0.1);
  }
  .seym-ach__eyebrow {
    display: inline-block;
    position: relative;
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: var(--seym-wine, #8E2244);
    margin-bottom: 1.6rem;
    padding-left: 2.6rem;
  }
  .seym-ach__eyebrow::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    width: 2rem; height: 1px;
    background: var(--seym-wine, #8E2244);
  }
  .seym-ach__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.2rem, 5vw, 6.4rem);
    line-height: 1.02;
    letter-spacing: -0.018em;
    color: #1A1A1A;
    margin: 0;
  }
  .seym-ach__title em { font-style: italic; color: var(--seym-wine, #8E2244); }
  .seym-ach__lead {
    margin: 1.6rem 0 0;
    max-width: 56ch;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 1.6vw, 1.9rem);
    line-height: 1.55;
    color: rgba(26,26,26,0.72);
  }

  .seym-ach__list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: milestone;
  }
  .seym-ach__item {
    display: grid;
    grid-template-columns: 4.8rem 1fr;
    gap: 2.4rem;
    padding: 2.4rem 0;
    border-bottom: 1px solid rgba(26,26,26,0.08);
    counter-increment: milestone;
  }
  .seym-ach__item:last-child { border-bottom: none; }

  .seym-ach__num {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 2.8rem;
    line-height: 1;
    color: var(--seym-wine, #8E2244);
    text-align: right;
    padding-top: 0.2rem;
  }
  .seym-ach__num::before { content: counter(milestone, decimal-leading-zero); }

  .seym-ach__body {}
  .seym-ach__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 1.8vw, 2.2rem);
    line-height: 1.2;
    color: #1A1A1A;
    margin: 0 0 0.6rem;
  }
  .seym-ach__desc {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(26,26,26,0.7);
    margin: 0;
  }

  .seym-ach__content {
    margin-top: 3.6rem;
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.4rem;
    line-height: 1.8;
    color: rgba(26,26,26,0.82);
    max-width: 72ch;
  }
  .seym-ach__content p { margin: 0 0 1.4rem; }
  .seym-ach__content p:last-child { margin-bottom: 0; }
  .seym-ach__content a {
    color: var(--seym-wine, #8E2244);
    text-decoration: none;
    border-bottom: 1px solid rgba(142,34,68,0.35);
  }
  .seym-ach__content a:hover { border-color: var(--seym-wine, #8E2244); }

  .seym-ach__back {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(26,26,26,0.1);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .seym-ach__back a {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid rgba(26,26,26,0.3);
    transition: color 220ms ease, border-color 220ms ease;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .seym-ach__back a:hover { color: var(--seym-wine, #8E2244); border-color: var(--seym-wine, #8E2244); }

  /* 3D stage inside the milestones block */
  .seym-ach__stage {
    position: relative;
    margin: 0 0 3.2rem;
    aspect-ratio: 16 / 10;
    background:
      radial-gradient(70% 70% at 50% 40%, rgba(142,34,68,0.06), transparent 70%),
      #f0ede8;
    border: 1px solid rgba(26,26,26,0.08);
    overflow: hidden;
  }
  .seym-ach__stage model-viewer {
    width: 100%;
    height: 100%;
    --poster-color: transparent;
  }
  .seym-ach__stage-hint {
    position: absolute;
    left: 50%; bottom: 1.4rem;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.55);
    background: rgba(245,241,234,0.7);
    padding: 0.4rem 0.9rem;
    border-radius: 2rem;
    pointer-events: none;
    transition: opacity 400ms ease;
  }

  @media (max-width: 749px) {
    .seym-ach__wrap { padding: 0 2.4rem; }
    .seym-ach__item { grid-template-columns: 3.6rem 1fr; gap: 1.6rem; }
    .seym-ach__num { font-size: 2.2rem; }
    .seym-ach__stage { aspect-ratio: 4 / 5; }
  }
</style>

<section class="seym-ach">
  <div class="seym-ach__wrap">
    <header class="seym-ach__hero">
      <span class="seym-ach__eyebrow">
        {%- if is_tr -%}Başarılarımız{%- else -%}Achievements{%- endif -%}
      </span>
      <h1 class="seym-ach__title">
        {%- if is_tr -%}Sessiz <em>Kilometre Taşları</em>{%- else -%}Quiet <em>Milestones</em>{%- endif -%}
      </h1>
      <p class="seym-ach__lead">
        {%- if is_tr -%}
          Genç bir atölyenin adımları — şekillendirilen parçalarla, doğan koleksiyonlarla, girilen evlerle ölçülen.
        {%- else -%}
          Milestones of a young atelier — measured in pieces shaped, in collections born, in homes entered.
        {%- endif -%}
      </p>
    </header>

    {%- assign ach_model = 'kTXk9osi445YD8EzpWGkU_trellis2_71a8b9e8726840be83e2fc9258984f12.glb' -%}
    <div class="seym-ach__stage" id="SeymAchStage">
      <model-viewer
        id="SeymAchModel"
        src="{{ ach_model | asset_url }}"
        alt="{%- if is_tr -%}Seym el üflemesi cam — etkileşimli 3D model{%- else -%}Seym mouth-blown glass — interactive 3D model{%- endif -%}"
        camera-controls
        interaction-prompt="none"
        camera-orbit="0deg 75deg 105%"
        min-camera-orbit="auto auto 80%"
        max-camera-orbit="auto auto 130%"
        environment-image="neutral"
        shadow-intensity="0"
        exposure="1.0"
        loading="lazy"
        reveal="auto"
        disable-zoom
        disable-tap
      ></model-viewer>
      <span class="seym-ach__stage-hint">
        {%- if is_tr -%}Döndürmek için sürükleyin{%- else -%}Drag to rotate{%- endif -%}
      </span>
    </div>

    <ol class="seym-ach__list">
      <li class="seym-ach__item">
        <span class="seym-ach__num"></span>
        <div class="seym-ach__body">
          <h3 class="seym-ach__heading">
            {%- if is_tr -%}12 Koleksiyon{%- else -%}12 Collections{%- endif -%}
          </h3>
          <p class="seym-ach__desc">
            {%- if is_tr -%}
              Her biri doğanın bir dilinden esinlenen on iki koleksiyon.
            {%- else -%}
              Twelve collections, each inspired by a language of nature.
            {%- endif -%}
          </p>
        </div>
      </li>
      <li class="seym-ach__item">
        <span class="seym-ach__num"></span>
        <div class="seym-ach__body">
          <h3 class="seym-ach__heading">
            {%- if is_tr -%}70+ Ürün{%- else -%}70+ Pieces{%- endif -%}
          </h3>
          <p class="seym-ach__desc">
            {%- if is_tr -%}
              Yetmişten fazla parça — Çengelköy atölyesinden dünyaya.
            {%- else -%}
              More than seventy pieces — from the Çengelköy atelier to the world.
            {%- endif -%}
          </p>
        </div>
      </li>
      <li class="seym-ach__item">
        <span class="seym-ach__num"></span>
        <div class="seym-ach__body">
          <h3 class="seym-ach__heading">
            {%- if is_tr -%}El Üflemesi{%- else -%}Mouth-Blown{%- endif -%}
          </h3>
          <p class="seym-ach__desc">
            {%- if is_tr -%}
              Her biri usta ellerde, nefesle şekillenen — seri üretim değil, sanat.
            {%- else -%}
              Each shaped by master hands and breath — not mass production, but art.
            {%- endif -%}
          </p>
        </div>
      </li>
    </ol>

    {%- if page.content != blank -%}
      <div class="seym-ach__content rte">
        {{ page.content }}
      </div>
    {%- endif -%}

    <script>
      (function () {
        var stage = document.getElementById('SeymAchStage');
        if (!stage) return;
        var loaded = false;
        function inject() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.type = 'module';
          s.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js';
          document.head.appendChild(s);
        }
        if ('IntersectionObserver' in window) {
          var obs = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { inject(); obs.disconnect(); }
            });
          }, { rootMargin: '200px 0px' });
          obs.observe(stage);
        } else { inject(); }

        var viewer = document.getElementById('SeymAchModel');
        if (!viewer) return;
        viewer.addEventListener('load', function () {
          var hint = stage.querySelector('.seym-ach__stage-hint');
          if (hint) setTimeout(function () { hint.style.opacity = '0'; }, 4000);
        });
        var spinning = false;
        function startSpin() {
          if (spinning) return;
          spinning = true;
          viewer.setAttribute('auto-rotate', '');
          viewer.setAttribute('rotation-per-second', '8deg');
        }
        function stopSpin() {
          if (!spinning) return;
          spinning = false;
          viewer.removeAttribute('auto-rotate');
        }
        viewer.addEventListener('mouseenter', startSpin);
        viewer.addEventListener('mouseleave', stopSpin);
        viewer.addEventListener('touchstart', startSpin, { passive: true });
        viewer.addEventListener('touchend', function () { setTimeout(stopSpin, 2000); }, { passive: true });
        if ('IntersectionObserver' in window) {
          var visObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (!e.isIntersecting) stopSpin(); });
          }, { threshold: 0 });
          visObs.observe(viewer);
        }
      })();
    </script>

    <nav class="seym-ach__back" aria-label="Related">
      <a href="/pages/about-us">
        ← {%- if is_tr -%}Hakkımızda{%- else -%}About Seym{%- endif -%}
      </a>
      <a href="/pages/digital-catalog">
        {%- if is_tr -%}Katalog{%- else -%}Catalog{%- endif -%} →
      </a>
    </nav>
  </div>
</section>
