<style>
  [data-reveal] {
    opacity: 0;
    transform: translateY(2.4rem);
    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);
  }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal-child] > * {
    opacity: 0;
    transform: translateY(1.6rem);
    transition: opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1);
  }
  [data-reveal-child].revealed > * { opacity: 1; transform: none; }
  [data-reveal-child].revealed > *:nth-child(1) { transition-delay: 0ms; }
  [data-reveal-child].revealed > *:nth-child(2) { transition-delay: 120ms; }
  [data-reveal-child].revealed > *:nth-child(3) { transition-delay: 240ms; }
  [data-reveal-child].revealed > *:nth-child(4) { transition-delay: 360ms; }
  [data-reveal-child].revealed > *:nth-child(5) { transition-delay: 480ms; }
  [data-reveal-child].revealed > *:nth-child(6) { transition-delay: 600ms; }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal], [data-reveal-child] > * { opacity: 1; transform: none; transition: none; }
  }
</style>
<script>
  (function(){
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add('revealed'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('[data-reveal],[data-reveal-child]').forEach(function(el){ io.observe(el); });
  })();
</script>
