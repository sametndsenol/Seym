    "values": {
      "type": "multicolumn",
      "blocks": {
        "col_1": {
          "type": "column",
          "settings": {
            "title": "Handcraftsmanship",
            "text": "<p>Every piece is shaped by master hands. Time is the only craftsman that cannot be hurried.</p>"
          }
        },
        "col_2": {
          "type": "column",
          "settings": {
            "title": "Nature-inspired",
            "text": "<p>Forms drawn from sea, sky, stone, flame. The universe distilled into glass.</p>"
          }
        },
        "col_3": {
          "type": "column",
          "settings": {
            "title": "Artistic Storytelling",
            "text": "<p>Each object carries a quiet narrative. A fragment of myth, a memory of nature.</p>"
          }
        },
        "col_4": {
          "type": "column",
          "settings": {
            "title": "Universal Tradition",
            "text": "<p>Universal glass-art heritage reshaped by a singular contemporary voice.</p>"
          }
        }
      },
      "block_order": ["col_1", "col_2", "col_3", "col_4"],
