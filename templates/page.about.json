          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "A unique aesthetic approach that combines glass art with a mysterious story.",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Founded in 2022 in the historical Çengelköy district of Istanbul, Seym Glass Studio is a design workshop bearing the traces of universal glass-art tradition.</p>"
          }
        }
      },
      "block_order": ["caption", "heading", "text"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "",
