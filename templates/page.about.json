        "padding_bottom": 100
      }
    },
    "atelier": {
      "type": "image-with-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "The Atelier",
            "heading_size": "h2"
          }
        },
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "Our Method",
            "text_style": "caption-with-letter-spacing",
            "text_size": "medium"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Each Seym piece begins as molten glass, shaped by breath and master hands in our Çengelköy atelier. Mouth-blown using the finest crystal, every object passes through stages no machine can replicate. Sand becomes light. Light becomes story.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": ["heading", "caption", "text"],
      "settings": {
