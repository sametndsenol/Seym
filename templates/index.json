{"sections":{"seym_hero":{"type":"lux-scroll-showcase","settings":{"bg_color":"#0a1424","text_color":"#efecec","eyebrow":"Seym Glass Studio · Istanbul","scroll_label":"Scroll"},"blocks":{"step_1":{"type":"step","settings":{"eyebrow":"Chapter I — Origin","headline":"A unique aesthetic approach that combines glass art with a mysterious story.","body":"<p>Mouth-blown in Istanbul. Inspired by mythology and nature.</p>"}},"step_2":{"type":"step","settings":{"eyebrow":"Chapter II — Craft","headline":"Each piece begins as breath, becomes <em>memory</em>.","body":"<p>Universal glass-art tradition shaped by master hands in our Çengelköy atelier.</p>"}},"step_3":{"type":"step","settings":{"eyebrow":"Chapter III — Presence","headline":"Modern heritage, designed to <em>endure</em>.","body":"<p>Story-driven, sculptural, never repeated. A quiet companion to contemporary living spaces.</p>"}}},"block_order":["step_1","step_2","step_3"]},"intro":{"type":"rich-text","blocks":{"caption":{"type":"caption","settings":{"caption":"The Atelier","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading":{"type":"heading","settings":{"heading":"An Istanbul workshop where glass becomes story.","heading_size":"h1"}},"text":{"type":"text","settings":{"text":"<p>Founded in 2022, Seym Glass Studio creates handcrafted, mouth-blown glass objects inspired by mythology and nature. We blend universal glass-art tradition with a singular aesthetic — story-driven, artistic pieces that carry the beauty of the universe into modern living spaces.</p>"}},"button":{"type":"button","settings":{"button_label":"Discover Our Story","button_link":"shopify://pages/about-us","button_style_secondary":true,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["caption","heading","text","button"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":140,"padding_bottom":140}},"collections_intro":{"type":"rich-text","blocks":{"caption":{"type":"caption","settings":{"caption":"Elemenduo Collection","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading":{"type":"heading","settings":{"heading":"Twelve characters, born of earth and sky.","heading_size":"h1"}},"text":{"type":"text","settings":{"text":"<p>Our first collection draws from a story full of mythological elements. Each piece carries a name — <em>Flos, Solis, Glacies, Luminis, Maris, Luna</em> — fragments of nature reshaped as living objects.</p>"}}},"block_order":["caption","heading","text"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":80,"padding_bottom":40}},"collections":{"type":"collection-list","blocks":{"c1":{"type":"featured_collection","settings":{"collection":"flos-koleksi̇yonu"}},"c2":{"type":"featured_collection","settings":{"collection":"soli̇s"}},"c3":{"type":"featured_collection","settings":{"collection":"glacies"}},"c4":{"type":"featured_collection","settings":{"collection":"luminis"}},"c5":{"type":"featured_collection","settings":{"collection":"mari̇s"}},"c6":{"type":"featured_collection","settings":{"collection":"luna"}}},"block_order":["c1","c2","c3","c4","c5","c6"],"settings":{"title":"","heading_size":"h2","image_ratio":"square","columns_desktop":3,"color_scheme":"","show_view_all":true,"columns_mobile":"2","swipe_on_mobile":false,"padding_top":24,"padding_bottom":120}},"manifesto":{"type":"rich-text","blocks":{"caption":{"type":"caption","settings":{"caption":"Manifesto","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading":{"type":"heading","settings":{"heading":"We choose character over perfection.","heading_size":"h1"}},"text":{"type":"text","settings":{"text":"<p>We honour the heritage of glassblowing — every object shaped not to impress, but to <em>express</em>. Crafted by master hands in Istanbul, our creations carry the silence of nature and the depth of myth, balanced with quiet nobility.</p><p>Identity over trend. Each piece carries its own presence — never shouting, yet never ignored.</p><p><strong>This is not glass as you know it. This is Seym.</strong></p>"}}},"block_order":["caption","heading","text"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":160,"padding_bottom":160}},"video_section":{"type":"video","settings":{"heading":"","heading_size":"h2","enable_video_looping":true,"video":"shopify://files/videos/Final v3.mp4","video_url":"https://www.youtube.com/watch?v=_9VUPq3SxOc","description":"","full_width":true,"color_scheme":"","padding_top":0,"padding_bottom":0}},"closing":{"type":"rich-text","blocks":{"caption":{"type":"caption","settings":{"caption":"Begin","text_style":"caption-with-letter-spacing","text_size":"medium"}},"heading":{"type":"heading","settings":{"heading":"Step inside the gallery.","heading_size":"h1"}},"button":{"type":"button","settings":{"button_label":"Explore All Pieces","button_link":"shopify://collections","button_style_secondary":false,"button_label_2":"Read the Journal","button_link_2":"shopify://blogs/news","button_style_secondary_2":true}}},"block_order":["caption","heading","button"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":140,"padding_bottom":140}}},"order":["seym_hero","intro","collections_intro","collections","manifesto","video_section","closing"]}
